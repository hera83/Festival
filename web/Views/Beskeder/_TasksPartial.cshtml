@model web.Models.TasksViewModel

@* Opret standalone opgave modal *@
<div class="modal fade" id="createStandaloneTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); border: 1px solid var(--clr-border); color: var(--clr-text);">
            <div class="modal-header" style="border-bottom: 1px solid var(--clr-border); background: var(--clr-bg);">
                <h6 class="modal-title mb-0"><i class="bi bi-plus-square me-2" style="color: var(--clr-brand);"></i>Opret opgave</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body" style="background: var(--clr-surface);">
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Titel <span style="color:var(--clr-alarm);">*</span></label>
                    <input type="text" id="cstTitle" class="form-control form-control-sm"
                           style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);"
                           placeholder="Opgavens titel" />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Beskrivelse</label>
                    <textarea id="cstDescription" class="form-control form-control-sm" rows="3"
                              style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text); resize:vertical;"
                              placeholder="Valgfri beskrivelse…"></textarea>
                </div>
                <div class="mb-1">
                    <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Forfaldsdato</label>
                    <input type="date" id="cstDueDate" class="form-control form-control-sm"
                           style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />
                </div>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--clr-border); background: var(--clr-bg);">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x me-1"></i>Annuller
                </button>
                <button type="button" id="cstSaveBtn" class="btn btn-sm" style="background: var(--clr-brand); color: #fff; border: none;">
                    <i class="bi bi-check2-square me-1"></i>Opret opgave
                </button>
            </div>
        </div>
    </div>
</div>

@* Åbn/rediger opgave modal *@
<div class="modal fade" id="openTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); border: 1px solid var(--clr-border); color: var(--clr-text);">
            <div class="modal-header" style="border-bottom: 1px solid var(--clr-border); background: var(--clr-bg);">
                <h6 class="modal-title mb-0"><i class="bi bi-check2-square me-2" style="color: var(--clr-brand);"></i>Åbn opgave</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body" style="background: var(--clr-surface);">
                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <label for="openTaskTitle" class="form-label" style="font-size:0.8rem; color: var(--clr-text-muted);">Titel</label>
                        <input id="openTaskTitle" type="text" class="form-control form-control-sm mb-3" readonly
                               style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />

                        <label for="openTaskDescription" class="form-label" style="font-size:0.8rem; color: var(--clr-text-muted);">Beskrivelse</label>
                        <textarea id="openTaskDescription" class="form-control form-control-sm mb-3" rows="7"
                                  style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text); resize: vertical;"
                                  placeholder="Skriv beskrivelse…"></textarea>

                        <label for="openTaskDueDate" class="form-label" style="font-size:0.8rem; color: var(--clr-text-muted);">Forfaldsdato</label>
                        <input id="openTaskDueDate" type="date" class="form-control form-control-sm mb-3"
                               style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />

                        <label class="form-label" style="font-size:0.8rem; color: var(--clr-text-muted);">Status</label>
                        <div class="d-flex flex-wrap gap-2" id="openTaskStatusGroup">
                            <button type="button" class="btn btn-sm btn-secondary task-status-select" data-status="0">
                                <i class="bi bi-circle me-1"></i>Åben
                            </button>
                            <button type="button" class="btn btn-sm btn-secondary task-status-select" data-status="1">
                                <i class="bi bi-arrow-repeat me-1"></i>I gang
                            </button>
                            <button type="button" class="btn btn-sm btn-secondary task-status-select" data-status="2">
                                <i class="bi bi-check-circle me-1"></i>Udført
                            </button>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <p class="mb-2 fw-semibold" style="font-size:0.85rem; color: var(--clr-text-muted);">
                            <i class="bi bi-clock-history me-1"></i>Hændelseslog
                        </p>
                        <div id="openTaskLogList" class="d-flex flex-column gap-2 mb-3"
                             style="max-height: 360px; overflow-y: auto; padding-right: 2px;"></div>

                        <label for="openTaskNewNote" class="form-label" style="font-size:0.8rem; color: var(--clr-text-muted);">Ny note</label>
                        <textarea id="openTaskNewNote" class="form-control form-control-sm" rows="4"
                                  style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text); resize: vertical;"
                                  placeholder="Skriv hvordan det går med opgaven…"></textarea>
                        <div class="d-flex justify-content-end mt-2">
                            <button type="button" class="btn btn-sm btn-secondary" id="openTaskAddNoteBtn">
                                <i class="bi bi-plus-lg me-1"></i>Gem note
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--clr-border); background: var(--clr-bg);">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x me-1"></i>Luk
                </button>
                <button type="button" class="btn btn-sm" id="openTaskSaveBtn" style="background: var(--clr-brand); color:#fff; border:none;">
                    <i class="bi bi-save me-1"></i>Gem
                </button>
            </div>
        </div>
    </div>
</div>

@* Slet opgave modal *@
<div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background: var(--clr-surface); border: 1px solid var(--clr-border); color: var(--clr-text);">
            <div class="modal-header" style="border-bottom: 1px solid var(--clr-border); background: var(--clr-bg);">
                <h6 class="modal-title mb-0"><i class="bi bi-trash me-2" style="color: var(--clr-alarm);"></i>Slet opgave</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body text-center py-4" style="background: var(--clr-surface);">
                <i class="bi bi-exclamation-triangle fs-2 d-block mb-2" style="color: var(--clr-alarm);"></i>
                <p class="mb-0">Er du sikker på du vil slette denne opgave?</p>
            </div>
            <div class="modal-footer justify-content-center" style="border-top: 1px solid var(--clr-border); background: var(--clr-bg);">
                <button type="button" class="btn btn-sm btn-secondary me-2" data-bs-dismiss="modal">
                    <i class="bi bi-x me-1"></i>Annuller
                </button>
                <button type="button" id="deleteTaskConfirm" class="btn btn-sm" style="background: var(--clr-alarm); color: #fff; border: none;">
                    <i class="bi bi-trash me-1"></i>Slet
                </button>
            </div>
        </div>
    </div>
</div>

@* Søgefelt *@
<div class="d-flex align-items-center justify-content-between mb-3 gap-2">
    <div class="input-group input-group-sm" style="max-width: 340px;">
        <span class="input-group-text" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
            <i class="bi bi-search"></i>
        </span>
        <input type="text" id="tasksSearchInput" class="form-control form-control-sm"
               placeholder="Søg titel, frivillig eller besked…"
               style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);"
               autocomplete="off" />
        <button type="button" id="tasksSearchClear" class="btn btn-sm d-none"
                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted); border-left: none;"
                tabindex="-1" aria-label="Ryd søgning">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <button type="button" class="btn btn-sm" id="createStandaloneTaskBtn"
            style="background: var(--clr-brand); color: #fff; border: none; white-space: nowrap;">
        <i class="bi bi-plus-lg me-1"></i>Opret opgave
    </button>
</div>

@* Resultat-zone *@
<div id="tasks-result-zone">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-check2-square me-2"></i>Opgaver (<span>@Model.TotalCount</span>)</span>
            <button type="button" id="btnRefreshTasks" class="btn btn-sm" style="background:transparent;border:1px solid var(--clr-border);color:var(--clr-text-muted);" title="Opdater tabel">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="color: var(--clr-text);">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--clr-border);">
                            <th class="ps-3">Titel</th>
                            <th>Frivillig</th>
                            <th>Fra besked</th>
                            <th>Status</th>
                            <th>Forfald</th>
                            <th>Oprettet</th>
                            <th class="pe-3" style="width:90px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Tasks.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4" style="color: var(--clr-text-muted);">
                                    <i class="bi bi-check2-square fs-4 d-block mb-1"></i>
                                    Ingen opgaver fundet
                                </td>
                            </tr>
                        }
                        @foreach (var t in Model.Tasks)
                        {
                            <tr style="border-bottom: 1px solid var(--clr-border);">
                                <td class="ps-3 align-middle fw-semibold">@t.Title</td>
                                <td class="align-middle">
                                    <span>@t.VolunteerName</span><br />
                                    <span class="badge badge-info" style="font-size:0.7rem;">@t.VolunteerKey</span>
                                </td>
                                <td class="align-middle" style="color: var(--clr-text-muted); font-size:0.85rem;">@t.MessageSubject</td>
                                <td class="align-middle">
                                    @if (t.Status == web.Models.MessageTaskStatus.Åben)
                                    {
                                        <span class="badge badge-info"><i class="bi bi-circle me-1"></i>Åben</span>
                                    }
                                    else if (t.Status == web.Models.MessageTaskStatus.IGang)
                                    {
                                        <span class="badge badge-warn"><i class="bi bi-arrow-repeat me-1"></i>I gang</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-ok"><i class="bi bi-check-circle me-1"></i>Udført</span>
                                    }
                                </td>
                                <td class="align-middle" style="font-size:0.85rem; white-space:nowrap;">
                                    @if (t.DueDate.HasValue)
                                    {
                                        var overdue = t.DueDate.Value < DateTime.Now && t.Status != web.Models.MessageTaskStatus.Udført;
                                        <span style="color: @(overdue ? "var(--clr-alarm)" : "var(--clr-text)")">@t.DueDate.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else { <span style="color: var(--clr-text-muted);">—</span> }
                                </td>
                                <td class="align-middle" style="font-size:0.85rem; white-space:nowrap;">@t.CreatedAt.ToString("dd/MM HH:mm")</td>
                                <td class="pe-3 align-middle text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button type="button" class="btn btn-sm btn-secondary task-open-btn"
                                                title="Åbn opgave"
                                                data-id="@t.Id">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm task-delete-btn"
                                                style="background: var(--clr-alarm); color: #fff; border: none;"
                                                title="Slet opgave" data-id="@t.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <span style="color: var(--clr-text-muted); font-size: 0.85rem;">
            @if (Model.TotalCount == 0) { <span>Ingen resultater</span> }
            else { <span>@Model.RangeFrom–@Model.RangeTo af @Model.TotalCount</span> }
        </span>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: var(--clr-text-muted);">
                <span>Pr. side</span>
                <select id="tasksPageSizeSelect" class="form-select form-select-sm"
                        style="width: auto; background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text); font-size: 0.85rem;">
                    @foreach (var size in new[] { 10, 25, 50 })
                    {
                        if (Model.PageSize == size) { <option value="@size" selected>@size</option> }
                        else { <option value="@size">@size</option> }
                    }
                </select>
            </div>
            <nav aria-label="Sidenavigation">
                <ul class="pagination pagination-sm mb-0">
                    @{
                        var cp = Model.Page; var tp = Model.TotalPages;
                        var shown = new System.Collections.Generic.SortedSet<int> { 1, Math.Max(1, tp) };
                        for (var i = Math.Max(1, cp - 1); i <= Math.Min(Math.Max(1, tp), cp + 1); i++) shown.Add(i);
                    }
                    <li class="page-item @(cp == 1 ? "disabled" : "")">
                        <button class="page-link tasks-page-btn" data-page="@(cp - 1)" @(cp == 1 ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @{ int? lastShown = null; }
                    @foreach (var p in shown)
                    {
                        if (lastShown.HasValue && p - lastShown.Value > 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">…</span>
                            </li>
                        }
                        <li class="page-item @(p == cp ? "active" : "")">
                            <button class="page-link tasks-page-btn" data-page="@p"
                                    style="@(p == cp ? "background: var(--clr-brand); border-color: var(--clr-brand); color: #fff;" : "background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);")">@p</button>
                        </li>
                        lastShown = p;
                    }
                    <li class="page-item @(cp >= tp ? "disabled" : "")">
                        <button class="page-link tasks-page-btn" data-page="@(cp + 1)" @(cp >= tp ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
(function () {
    var searchUrl       = '@Url.Action("TasksSearch",         "Beskeder")';
    var taskDataUrl     = '@Url.Action("GetTaskEditorData",    "Beskeder")';
    var updateTaskUrl   = '@Url.Action("UpdateTaskEditor",     "Beskeder")';
    var addTaskNoteUrl  = '@Url.Action("AddTaskEditorNote",    "Beskeder")';
    var deletePostUrl             = '@Url.Action("DeleteTask",              "Beskeder")';
    var createStandaloneTaskUrl   = '@Url.Action("CreateStandaloneTask",    "Beskeder")';

    var debounce;
    var currentSize = @Model.PageSize;
    var currentPage = @Model.Page;
    var pendingOpenId = null;
    var pendingOpenStatus = 0;
    var pendingDeleteId = null;

    async function loadPage(page, size) {
        currentPage = page; currentSize = size;
        var q   = document.getElementById('tasksSearchInput').value.trim();
        var url = searchUrl + '?q=' + encodeURIComponent(q) + '&page=' + page + '&pageSize=' + size;
        try {
            var res = await fetch(url);
            if (!res.ok) { showToast('Kunne ikke hente opgaver.', 'error'); return; }
            var doc  = new DOMParser().parseFromString(await res.text(), 'text/html');
            var zone = doc.getElementById('tasks-result-zone');
            if (!zone) return;
            document.getElementById('tasks-result-zone').innerHTML = zone.innerHTML;
            bindZoneEvents();
        } catch (e) { showToast('Netværksfejl – prøv igen.', 'error'); }
    }

    var input = document.getElementById('tasksSearchInput');
    var clear = document.getElementById('tasksSearchClear');
    input.addEventListener('input', function () { clear.classList.toggle('d-none', this.value === ''); });
    clear.addEventListener('click', function () { input.value = ''; clear.classList.add('d-none'); loadPage(1, currentSize); input.focus(); });
    input.addEventListener('keyup', function () { clearTimeout(debounce); debounce = setTimeout(function () { loadPage(1, currentSize); }, 250); });

    function bindZoneEvents() {
        var sel = document.getElementById('tasksPageSizeSelect');
        if (sel) sel.addEventListener('change', function () { loadPage(1, parseInt(this.value)); });
        document.querySelectorAll('.tasks-page-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { var p = parseInt(this.dataset.page); if (!isNaN(p) && p >= 1) loadPage(p, currentSize); });
        });
        bindRowActions();
    }

    // ── Åbn/rediger opgave modal ─────────────────────────────────
    var openTaskModalEl = document.getElementById('openTaskModal');
    var bsOpenTaskModal = new bootstrap.Modal(openTaskModalEl);
    var titleInput = document.getElementById('openTaskTitle');
    var descriptionInput = document.getElementById('openTaskDescription');
    var dueDateInput = document.getElementById('openTaskDueDate');
    var noteInput = document.getElementById('openTaskNewNote');
    var logList = document.getElementById('openTaskLogList');

    function setStatusVisual() {
        document.querySelectorAll('.task-status-select').forEach(function (b) {
            var status = parseInt(b.dataset.status);
            var isActive = status === pendingOpenStatus;

            if (!isActive) {
                b.style.background = 'var(--clr-surface-2)';
                b.style.color = 'var(--clr-text)';
                b.style.border = '1px solid var(--clr-border)';
                b.style.boxShadow = 'none';
                b.style.opacity = '1';
                return;
            }

            if (status === 0) {
                b.style.background = 'var(--clr-info-bg)';
                b.style.color = 'var(--clr-info)';
                b.style.border = '1px solid var(--clr-info)';
            } else if (status === 1) {
                b.style.background = 'var(--clr-warn-bg)';
                b.style.color = 'var(--clr-warn)';
                b.style.border = '1px solid var(--clr-warn)';
            } else {
                b.style.background = 'var(--clr-ok-bg)';
                b.style.color = 'var(--clr-ok)';
                b.style.border = '1px solid var(--clr-ok)';
            }

            b.style.boxShadow = '0 0 0 2px var(--clr-brand-dim)';
            b.style.opacity = '1';
        });
    }

    document.querySelectorAll('.task-status-select').forEach(function (btn) {
        btn.addEventListener('click', function () {
            pendingOpenStatus = parseInt(this.dataset.status);
            setStatusVisual();
        });
    });

    function renderTaskNotes(notes) {
        if (!notes || notes.length === 0) {
            logList.innerHTML = '<div class="rounded-2 p-3" style="border:1px solid var(--clr-border); background:var(--clr-bg); color:var(--clr-text-muted); font-size:.85rem;">Ingen noter endnu.</div>';
            return;
        }
        logList.innerHTML = notes.map(function (n) {
            return '<div class="rounded-2 p-2" style="border:1px solid var(--clr-border); background:var(--clr-bg);">' +
                   '<div style="font-size:.75rem;color:var(--clr-text-muted);margin-bottom:4px;">' +
                   '<i class="bi bi-person me-1"></i>' + n.author + ' <span>&nbsp;·&nbsp;</span>' + n.createdAt +
                   '</div>' +
                   '<div style="font-size:.85rem;white-space:pre-wrap;word-break:break-word;">' + n.note + '</div>' +
                   '</div>';
        }).join('');
    }

    async function loadTaskEditorData(id) {
        var res = await fetch(taskDataUrl + '?id=' + id);
        if (!res.ok) throw new Error();
        var json = await res.json();
        if (!json.success) throw new Error();
        titleInput.value = json.title || '';
        descriptionInput.value = json.description || '';
        dueDateInput.value = json.dueDate || '';
        pendingOpenStatus = parseInt(json.status || 0);
        setStatusVisual();
        renderTaskNotes(json.notes || []);
    }

    document.getElementById('openTaskSaveBtn').addEventListener('click', async function () {
            if (!pendingOpenId) return;
            var btn = this;
            btn.disabled = true;
            var description = descriptionInput.value;
            var fd = new FormData();
            fd.append('id', pendingOpenId);
            fd.append('description', description);
            fd.append('dueDate', dueDateInput.value || '');
            fd.append('status', pendingOpenStatus);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
            try {
                var res  = await fetch(updateTaskUrl, { method: 'POST', body: fd });
                var json = await res.json();
                bsOpenTaskModal.hide();
                if (json.success) {
                    showToast(json.message, 'success');
                    document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                    await loadPage(currentPage, currentSize);
                } else { showToast(json.message, 'error'); }
            } catch (e) { bsOpenTaskModal.hide(); showToast('Netværksfejl.', 'error'); }
            finally { pendingOpenId = null; btn.disabled = false; }
        });

    document.getElementById('openTaskAddNoteBtn').addEventListener('click', async function () {
        if (!pendingOpenId) return;
        var note = noteInput.value.trim();
        if (!note) { showToast('Skriv en note først.', 'warn'); return; }

        var btn = this;
        btn.disabled = true;
        var fd = new FormData();
        fd.append('id', pendingOpenId);
        fd.append('note', note);
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        try {
            var res = await fetch(addTaskNoteUrl, { method: 'POST', body: fd });
            var json = await res.json();
            if (!json.success) { showToast(json.message, 'error'); return; }
            noteInput.value = '';
            await loadTaskEditorData(pendingOpenId);
            showToast(json.message, 'success');
        } catch (e) {
            showToast('Netværksfejl.', 'error');
        } finally {
            btn.disabled = false;
        }
    });

    // ── Slet modal ────────────────────────────────────────────────
    var deleteModalEl = document.getElementById('deleteTaskModal');
    var bsDeleteModal = new bootstrap.Modal(deleteModalEl);

    document.getElementById('deleteTaskConfirm').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        var btn = this; btn.disabled = true;
        try {
            var fd = new FormData();
            fd.append('id', pendingDeleteId);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
            var res  = await fetch(deletePostUrl, { method: 'POST', body: fd });
            var json = await res.json();
            bsDeleteModal.hide();
            if (json.success) {
                showToast(json.message, 'success');
                document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                await loadPage(currentPage, currentSize);
            } else { showToast(json.message, 'error'); }
        } catch (e) { bsDeleteModal.hide(); showToast('Netværksfejl.', 'error'); }
        finally { btn.disabled = false; pendingDeleteId = null; }
    });

    function bindRowActions() {
        document.querySelectorAll('.task-open-btn').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                pendingOpenId = parseInt(this.dataset.id);
                noteInput.value = '';
                try {
                    await loadTaskEditorData(pendingOpenId);
                } catch (e) {
                    showToast('Kunne ikke hente opgavedata.', 'error');
                    pendingOpenId = null;
                    return;
                }
                bsOpenTaskModal.show();
            });
        });
        document.querySelectorAll('.task-delete-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { pendingDeleteId = parseInt(this.dataset.id); bsDeleteModal.show(); });
        });
    }

    bindZoneEvents();

    // ── Opret standalone opgave ───────────────────────────────────
    var bsCreateStandaloneModal = new bootstrap.Modal(document.getElementById('createStandaloneTaskModal'));
    document.getElementById('createStandaloneTaskBtn').addEventListener('click', function () {
        document.getElementById('cstTitle').value = '';
        document.getElementById('cstDescription').value = '';
        document.getElementById('cstDueDate').value = '';
        bsCreateStandaloneModal.show();
    });
    document.getElementById('cstSaveBtn').addEventListener('click', async function () {
        var title = document.getElementById('cstTitle').value.trim();
        if (!title) { showToast('Titel er påkrævet.', 'warn'); document.getElementById('cstTitle').focus(); return; }
        var btn = this; btn.disabled = true;
        var fd = new FormData();
        fd.append('title', title);
        fd.append('description', document.getElementById('cstDescription').value);
        fd.append('dueDate', document.getElementById('cstDueDate').value || '');
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
        try {
            var res  = await fetch(createStandaloneTaskUrl, { method: 'POST', body: fd });
            var json = await res.json();
            bsCreateStandaloneModal.hide();
            if (json.success) {
                showToast(json.message, 'success');
                document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                await loadPage(1, currentSize);
            } else { showToast(json.message, 'error'); }
        } catch (e) { bsCreateStandaloneModal.hide(); showToast('Netværksfejl.', 'error'); }
        finally { btn.disabled = false; }
    });

    if (window.pendingBeskederTaskId) {
        var wanted = parseInt(window.pendingBeskederTaskId);
        window.pendingBeskederTaskId = null;
        var openBtn = document.querySelector('.task-open-btn[data-id="' + wanted + '"]');
        if (openBtn) openBtn.click();
    }

    bindZoneEvents();
})();
</script>
