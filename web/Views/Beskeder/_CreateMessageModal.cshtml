@model web.Models.CreateMessageViewModel

<form id="createMsgForm">
    @Html.AntiForgeryToken()
    <div class="modal-header" style="border-bottom: 1px solid var(--clr-border); background: var(--clr-bg);">
        <h6 class="modal-title mb-0">
            <i class="bi bi-pencil-square me-2" style="color: var(--clr-brand);"></i>Ny besked
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
    </div>
    <div class="modal-body" style="background: var(--clr-surface);">
        <div class="mb-3">
            <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Frivillig</label>
            <select name="VolunteerId" class="form-select form-select-sm"
                    style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);" required>
                <option value="">— Vælg frivillig —</option>
                @foreach (var v in Model.AvailableVolunteers)
                {
                    <option value="@v.Id">@v.Name (@v.Key)</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Emne</label>
            <input type="text" name="Subject" class="form-control form-control-sm"
                   style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);"
                   placeholder="Beskedens emne" required />
        </div>
        <div class="mb-3">
            <label class="form-label" style="font-size:0.85rem; color: var(--clr-text-muted);">Besked</label>
            <textarea name="Body" class="form-control form-control-sm" rows="5"
                      style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text); resize:vertical;"
                      placeholder="Skriv din besked her…" required></textarea>
        </div>
    </div>
    <div class="modal-footer" style="border-top: 1px solid var(--clr-border); background: var(--clr-bg);">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
            <i class="bi bi-x me-1"></i>Annuller
        </button>
        <button type="submit" id="createMsgSubmit" class="btn btn-sm" style="background: var(--clr-brand); color: #fff; border: none;">
            <i class="bi bi-send me-1"></i>Send
        </button>
    </div>
</form>
