@model web.Models.ReadMessagesViewModel

@* Opret besked modal *@
<div class="modal fade" id="createMsgModalRead" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-border);">
            <div id="createMsgModalBodyRead">
                <div class="modal-body text-center py-5" style="color: var(--clr-text-muted);">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Detalje-modal *@
<div class="modal fade" id="detailMsgModalRead" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-border);">
            <div id="detailMsgModalBodyRead">
                <div class="modal-body text-center py-5" style="color: var(--clr-text-muted);">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Opret opgave modal *@
<div class="modal fade" id="createTaskModalRead" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-border);">
            <div id="createTaskModalBodyRead">
                <div class="modal-body text-center py-5" style="color: var(--clr-text-muted);">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Slet-modal *@
<div class="modal fade" id="deleteMsgModalRead" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background: var(--clr-surface); border: 1px solid var(--clr-border); color: var(--clr-text);">
            <div class="modal-header" style="border-bottom: 1px solid var(--clr-border); background: var(--clr-bg);">
                <h6 class="modal-title mb-0"><i class="bi bi-trash me-2" style="color: var(--clr-alarm);"></i>Slet besked</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body text-center py-4" style="background: var(--clr-surface);">
                <i class="bi bi-exclamation-triangle fs-2 d-block mb-2" style="color: var(--clr-alarm);"></i>
                <p class="mb-0">Er du sikker på du vil slette denne besked?</p>
            </div>
            <div class="modal-footer justify-content-center" style="border-top: 1px solid var(--clr-border); background: var(--clr-bg);">
                <button type="button" class="btn btn-sm btn-secondary me-2" data-bs-dismiss="modal">
                    <i class="bi bi-x me-1"></i>Annuller
                </button>
                <button type="button" id="deleteMsgConfirmRead" class="btn btn-sm" style="background: var(--clr-alarm); color: #fff; border: none;">
                    <i class="bi bi-trash me-1"></i>Slet
                </button>
            </div>
        </div>
    </div>
</div>

@* Søgefelt + handling *@
<div class="d-flex align-items-center justify-content-between mb-3 gap-2">
    <div class="input-group input-group-sm" style="max-width: 340px;">
        <span class="input-group-text" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
            <i class="bi bi-search"></i>
        </span>
        <input type="text" id="readSearchInput" class="form-control form-control-sm"
               placeholder="Søg emne, navn eller nøgle…"
               style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);"
               autocomplete="off" />
        <button type="button" id="readSearchClear" class="btn btn-sm d-none"
                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted); border-left: none;"
                tabindex="-1" aria-label="Ryd søgning">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <button type="button" id="btnOpenCreateMsgRead" class="btn btn-sm"
            style="background: var(--clr-brand); color: #fff; border: none; white-space: nowrap;">
        <i class="bi bi-pencil-square me-1"></i>Ny besked
    </button>
</div>

@* Resultat-zone *@
<div id="read-result-zone">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-envelope-open me-2"></i>Læste beskeder (<span>@Model.TotalCount</span>)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="color: var(--clr-text);">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--clr-border);">
                            <th class="ps-3">Frivillig</th>
                            <th>Emne</th>
                            <th>Forhåndsvisning</th>
                            <th>Modtaget</th>
                            <th>Læst</th>
                            <th class="pe-3" style="width:130px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Messages.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4" style="color: var(--clr-text-muted);">
                                    <i class="bi bi-envelope-open fs-4 d-block mb-1"></i>
                                    Ingen læste beskeder fundet
                                </td>
                            </tr>
                        }
                        @foreach (var m in Model.Messages)
                        {
                            <tr style="border-bottom: 1px solid var(--clr-border);">
                                <td class="ps-3 align-middle">
                                    <span class="fw-semibold">@m.VolunteerName</span><br />
                                    <span class="badge badge-info" style="font-size:0.7rem;">@m.VolunteerKey</span>
                                </td>
                                <td class="align-middle fw-semibold">
                                    @m.Subject
                                    @if (m.AttachmentCount > 0)
                                    {
                                        <i class="bi bi-paperclip ms-1" style="color: var(--clr-text-muted); font-size:0.85rem;" title="@m.AttachmentCount vedhæftning(er)"></i>
                                    }
                                </td>
                                <td class="align-middle" style="color: var(--clr-text-muted); font-size:0.85rem;">@m.BodyPreview</td>
                                <td class="align-middle" style="font-size:0.85rem; white-space:nowrap;">@m.SentAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                <td class="align-middle" style="font-size:0.85rem; white-space:nowrap;">
                                    @if (m.ReadAt.HasValue)
                                    {
                                        <span style="color: var(--clr-ok);">@m.ReadAt.Value.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                    }
                                </td>
                                <td class="pe-3 align-middle text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button type="button" class="btn btn-sm read-task-btn"
                                                style="background: var(--clr-warn); color: #fff; border: none;"
                                                title="Opret opgave" data-id="@m.Id">
                                            <i class="bi bi-check2-square"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm read-markUnread-btn"
                                                style="background: var(--clr-surface); color: var(--clr-text-muted); border: 1px solid var(--clr-border);"
                                                title="Marker som ulæst" data-id="@m.Id">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm read-detail-btn"
                                                style="background: var(--clr-info); color: #fff; border: none;"
                                                title="Vis besked" data-id="@m.Id">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm read-delete-btn"
                                                style="background: var(--clr-alarm); color: #fff; border: none;"
                                                title="Slet besked" data-id="@m.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <span style="color: var(--clr-text-muted); font-size: 0.85rem;">
            @if (Model.TotalCount == 0) { <span>Ingen resultater</span> }
            else { <span>@Model.RangeFrom–@Model.RangeTo af @Model.TotalCount</span> }
        </span>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: var(--clr-text-muted);">
                <span>Pr. side</span>
                <select id="readPageSizeSelect" class="form-select form-select-sm"
                        style="width: auto; background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text); font-size: 0.85rem;">
                    @foreach (var size in new[] { 10, 25, 50 })
                    {
                        if (Model.PageSize == size) { <option value="@size" selected>@size</option> }
                        else { <option value="@size">@size</option> }
                    }
                </select>
            </div>
            <nav aria-label="Sidenavigation">
                <ul class="pagination pagination-sm mb-0">
                    @{
                        var cp = Model.Page; var tp = Model.TotalPages;
                        var shown = new System.Collections.Generic.SortedSet<int> { 1, Math.Max(1, tp) };
                        for (var i = Math.Max(1, cp - 1); i <= Math.Min(Math.Max(1, tp), cp + 1); i++) shown.Add(i);
                    }
                    <li class="page-item @(cp == 1 ? "disabled" : "")">
                        <button class="page-link read-page-btn" data-page="@(cp - 1)" @(cp == 1 ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @{ int? lastShown = null; }
                    @foreach (var p in shown)
                    {
                        if (lastShown.HasValue && p - lastShown.Value > 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">…</span>
                            </li>
                        }
                        <li class="page-item @(p == cp ? "active" : "")">
                            <button class="page-link read-page-btn" data-page="@p"
                                    style="@(p == cp ? "background: var(--clr-brand); border-color: var(--clr-brand); color: #fff;" : "background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);")">@p</button>
                        </li>
                        lastShown = p;
                    }
                    <li class="page-item @(cp >= tp ? "disabled" : "")">
                        <button class="page-link read-page-btn" data-page="@(cp + 1)" @(cp >= tp ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
(function () {
    var searchUrl      = '@Url.Action("ReadSearch",         "Beskeder")';
    var createFormUrl  = '@Url.Action("GetCreateForm",      "Beskeder")';
    var createPostUrl  = '@Url.Action("CreateMessage",      "Beskeder")';
    var detailUrl      = '@Url.Action("Detail",             "Beskeder")';
    var deletePostUrl  = '@Url.Action("DeleteMessage",      "Beskeder")';
    var markUnreadUrl  = '@Url.Action("MarkUnread",         "Beskeder")';
    var taskFormUrl    = '@Url.Action("GetCreateTaskForm",  "Beskeder")';
    var taskPostUrl    = '@Url.Action("CreateTask",         "Beskeder")';

    var debounce;
    var currentSize  = @Model.PageSize;
    var currentPage  = @Model.Page;

    async function loadPage(page, size) {
        currentPage = page; currentSize = size;
        var q   = document.getElementById('readSearchInput').value.trim();
        var url = searchUrl + '?q=' + encodeURIComponent(q) + '&page=' + page + '&pageSize=' + size;
        try {
            var res = await fetch(url);
            if (!res.ok) { showToast('Kunne ikke hente beskeder.', 'error'); return; }
            var doc  = new DOMParser().parseFromString(await res.text(), 'text/html');
            var zone = doc.getElementById('read-result-zone');
            if (!zone) return;
            document.getElementById('read-result-zone').innerHTML = zone.innerHTML;
            bindZoneEvents();
        } catch (e) { showToast('Netværksfejl – prøv igen.', 'error'); }
    }

    var input = document.getElementById('readSearchInput');
    var clear = document.getElementById('readSearchClear');
    input.addEventListener('input', function () { clear.classList.toggle('d-none', this.value === ''); });
    clear.addEventListener('click', function () { input.value = ''; clear.classList.add('d-none'); loadPage(1, currentSize); input.focus(); });
    input.addEventListener('keyup', function () { clearTimeout(debounce); debounce = setTimeout(function () { loadPage(1, currentSize); }, 250); });

    function bindZoneEvents() {
        var sel = document.getElementById('readPageSizeSelect');
        if (sel) sel.addEventListener('change', function () { loadPage(1, parseInt(this.value)); });
        document.querySelectorAll('.read-page-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { var p = parseInt(this.dataset.page); if (!isNaN(p) && p >= 1) loadPage(p, currentSize); });
        });
        bindRowActions();
    }

    // ── Slet modal ────────────────────────────────────────────────
    var deleteModalEl   = document.getElementById('deleteMsgModalRead');
    var bsDeleteModal   = new bootstrap.Modal(deleteModalEl);
    var pendingDeleteId = null;

    document.getElementById('deleteMsgConfirmRead').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        var btn = this; btn.disabled = true;
        try {
            var fd = new FormData();
            fd.append('id', pendingDeleteId);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
            var res  = await fetch(deletePostUrl, { method: 'POST', body: fd });
            var json = await res.json();
            bsDeleteModal.hide();
            if (json.success) {
                showToast(json.message, 'success');
                document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                await loadPage(currentPage, currentSize);
            } else { showToast(json.message, 'error'); }
        } catch (e) { bsDeleteModal.hide(); showToast('Netværksfejl.', 'error'); }
        finally { btn.disabled = false; pendingDeleteId = null; }
    });

    // ── Detalje modal ─────────────────────────────────────────────
    var detailModalEl   = document.getElementById('detailMsgModalRead');
    var detailModalBody = document.getElementById('detailMsgModalBodyRead');
    var bsDetailModal   = new bootstrap.Modal(detailModalEl);

    async function openDetail(id) {
        detailModalBody.innerHTML = spinner();
        bsDetailModal.show();
        try {
            var res = await fetch(detailUrl + '?id=' + id);
            if (res.ok) {
                detailModalBody.innerHTML = await res.text();
                execScripts(detailModalBody);
            }
            else { bsDetailModal.hide(); showToast('Kunne ikke hente besked.', 'error'); }
        } catch (e) { bsDetailModal.hide(); showToast('Netværksfejl.', 'error'); }
    }

    // ── Opgave modal ──────────────────────────────────────────────
    var taskModalEl   = document.getElementById('createTaskModalRead');
    var taskModalBody = document.getElementById('createTaskModalBodyRead');
    var bsTaskModal   = new bootstrap.Modal(taskModalEl);

    async function openTaskModal(msgId) {
        taskModalBody.innerHTML = spinner();
        bsTaskModal.show();
        try {
            var res = await fetch(taskFormUrl + '?messageId=' + msgId);
            if (res.ok) { taskModalBody.innerHTML = await res.text(); bindTaskForm(); }
            else { bsTaskModal.hide(); showToast('Kunne ikke hente opgave-formular.', 'error'); }
        } catch (e) { bsTaskModal.hide(); showToast('Netværksfejl.', 'error'); }
    }

    function bindTaskForm() {
        var form = document.getElementById('createTaskForm');
        if (!form) return;
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var submitEl = document.getElementById('createTaskSubmit');
            submitEl.disabled = true;
            try {
                var res  = await fetch(taskPostUrl, { method: 'POST', body: new FormData(form) });
                var json = await res.json();
                if (json.success) {
                    bsTaskModal.hide();
                    showToast(json.message, 'success');
                    document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                } else { showToast(json.message || 'Fejl.', 'error'); submitEl.disabled = false; }
            } catch (e) { showToast('Netværksfejl.', 'error'); submitEl.disabled = false; }
        });
    }

    // ── Opret besked modal ────────────────────────────────────────
    var createModalEl   = document.getElementById('createMsgModalRead');
    var createModalBody = document.getElementById('createMsgModalBodyRead');
    var bsCreateModal   = new bootstrap.Modal(createModalEl);

    document.getElementById('btnOpenCreateMsgRead').addEventListener('click', async function () {
        createModalBody.innerHTML = spinner();
        bsCreateModal.show();
        try {
            var res = await fetch(createFormUrl);
            if (res.ok) { createModalBody.innerHTML = await res.text(); bindCreateForm(); }
            else { bsCreateModal.hide(); showToast('Kunne ikke hente formular.', 'error'); }
        } catch (e) { bsCreateModal.hide(); showToast('Netværksfejl.', 'error'); }
    });

    function bindCreateForm() {
        var form = document.getElementById('createMsgForm');
        if (!form) return;
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var submitEl = document.getElementById('createMsgSubmit');
            submitEl.disabled = true;
            try {
                var res  = await fetch(createPostUrl, { method: 'POST', body: new FormData(form) });
                var json = await res.json();
                if (json.success) {
                    bsCreateModal.hide();
                    showToast(json.message, 'success');
                    document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                    await loadPage(1, currentSize);
                } else { showToast(json.message || 'Fejl.', 'error'); submitEl.disabled = false; }
            } catch (e) { showToast('Netværksfejl.', 'error'); submitEl.disabled = false; }
        });
    }

    function bindRowActions() {
        document.querySelectorAll('.read-detail-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { openDetail(parseInt(this.dataset.id)); });
        });
        document.querySelectorAll('.read-delete-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { pendingDeleteId = parseInt(this.dataset.id); bsDeleteModal.show(); });
        });
        document.querySelectorAll('.read-task-btn').forEach(function (btn) {
            btn.addEventListener('click', function () { openTaskModal(parseInt(this.dataset.id)); });
        });
        document.querySelectorAll('.read-markUnread-btn').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var id = parseInt(this.dataset.id);
                var fd = new FormData();
                fd.append('id', id);
                fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                try {
                    var res  = await fetch(markUnreadUrl, { method: 'POST', body: fd });
                    var json = await res.json();
                    if (json.success) {
                        showToast(json.message, 'success');
                        document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
                        await loadPage(currentPage, currentSize);
                    } else { showToast(json.message, 'error'); }
                } catch (e) { showToast('Netværksfejl.', 'error'); }
            });
        });
    }

    function execScripts(container) {
        container.querySelectorAll('script').forEach(function (oldScript) {
            var s = document.createElement('script');
            s.textContent = oldScript.textContent;
            oldScript.parentNode.replaceChild(s, oldScript);
        });
    }

    function spinner() {
        return '<div class="modal-body text-center py-5" style="color:var(--clr-text-muted);"><div class="spinner-border spinner-border-sm" role="status"></div></div>';
    }

    bindZoneEvents();
})();
</script>
