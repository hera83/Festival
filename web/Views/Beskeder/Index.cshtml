@model web.Models.BeskederIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div class="page-header mb-0" style="border-bottom:none; padding-bottom:0;">
        <h1><i class="bi bi-chat-dots me-2" style="color: var(--clr-brand);"></i>Besked Center</h1>
        <p class="mb-0">Beskeder mellem koordinatorer og frivillige</p>
    </div>

    <div class="d-flex flex-wrap gap-2" id="statCards">
        <div class="card stat-card" data-panel="unread" style="cursor:pointer; min-width:155px;" title="Vis ulæste beskeder">
            <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
                <div style="width:32px;height:32px;border-radius:var(--radius-md);background:var(--clr-alarm-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-envelope" style="color:var(--clr-alarm);font-size:0.9rem;"></i>
                </div>
                <div>
                    <div id="countUnread" style="font-size:1.1rem;font-weight:700;line-height:1;color:#e6edf3;">@Model.UnreadCount</div>
                    <div style="font-size:0.75rem;color:var(--clr-text-muted);">Ulæste</div>
                </div>
            </div>
        </div>
        <div class="card stat-card" data-panel="read" style="cursor:pointer; min-width:155px;" title="Vis læste beskeder">
            <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
                <div style="width:32px;height:32px;border-radius:var(--radius-md);background:var(--clr-ok-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-envelope-open" style="color:var(--clr-ok);font-size:0.9rem;"></i>
                </div>
                <div>
                    <div id="countRead" style="font-size:1.1rem;font-weight:700;line-height:1;color:#e6edf3;">@Model.ReadCount</div>
                    <div style="font-size:0.75rem;color:var(--clr-text-muted);">Læste</div>
                </div>
            </div>
        </div>
        <div class="card stat-card" data-panel="tasks" style="cursor:pointer; min-width:155px;" title="Vis opgaver">
            <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
                <div style="width:32px;height:32px;border-radius:var(--radius-md);background:var(--clr-warn-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-check2-square" style="color:var(--clr-warn);font-size:0.9rem;"></i>
                </div>
                <div>
                    <div id="countTasks" style="font-size:1.1rem;font-weight:700;line-height:1;color:#e6edf3;">@Model.TaskCount</div>
                    <div style="font-size:0.75rem;color:var(--clr-text-muted);">Opgaver</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="tableSpinner" class="d-none text-center py-5">
    <div class="spinner-border" style="color: var(--clr-brand);" role="status">
        <span class="visually-hidden">Indlæser...</span>
    </div>
</div>
<div id="tablePane"></div>

@section Scripts {
    <script>
    (function () {
        const panelUrls = {
            unread: '@Url.Action("UnreadPartial", "Beskeder")',
            read:   '@Url.Action("ReadPartial",   "Beskeder")',
            tasks:  '@Url.Action("TasksPartial",  "Beskeder")',
        };
        const countsUrl = '@Url.Action("GetCounts", "Beskeder")';

        async function refreshCounts() {
            const r = await fetch(countsUrl);
            if (!r.ok) return;
            const d = await r.json();
            document.getElementById('countUnread').textContent = d.unreadCount;
            document.getElementById('countRead').textContent   = d.readCount;
            document.getElementById('countTasks').textContent  = d.taskCount;

            if (typeof window.refreshBeskedMenuIndicator === 'function') {
                window.refreshBeskedMenuIndicator();
            }
        }

        document.addEventListener('beskeder:countsChanged', refreshCounts);

        const pane    = document.getElementById('tablePane');
        const spinner = document.getElementById('tableSpinner');
        let   active  = null;

        async function loadPanel(key, forceReload) {
            if (!forceReload && active === key) {
                pane.innerHTML = '';
                active = null;
                document.querySelectorAll('.stat-card').forEach(c => c.classList.remove('stat-card-active'));
                return;
            }
            active = key;
            document.querySelectorAll('.stat-card').forEach(c => {
                c.classList.toggle('stat-card-active', c.dataset.panel === key);
            });
            spinner.classList.remove('d-none');
            pane.innerHTML = '';
            const res  = await fetch(panelUrls[key]);
            const html = await res.text();
            pane.innerHTML = html;
            pane.querySelectorAll('script').forEach(function (oldScript) {
                const newScript = document.createElement('script');
                newScript.textContent = oldScript.textContent;
                document.body.appendChild(newScript);
                document.body.removeChild(newScript);
            });
            spinner.classList.add('d-none');
        }

        window.openBeskedTaskFromMessage = async function (taskId) {
            window.pendingBeskederTaskId = taskId;
            await loadPanel('tasks', true);
        };

        document.querySelectorAll('.stat-card').forEach(card => {
            card.addEventListener('click', function () {
                loadPanel(this.dataset.panel, false);
            });
        });

        async function backgroundRefresh() {
            await refreshCounts();
            if (active === 'unread' && typeof window.refreshUnreadMessagesTable === 'function') {
                window.refreshUnreadMessagesTable();
            }
        }

        setInterval(backgroundRefresh, 30000);
        document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'visible') backgroundRefresh();
        });

        // Åbn Ulæste som standard
        loadPanel('unread', false);
    })();
    </script>
    <style>
        .stat-card { transition: outline 0.15s, box-shadow 0.15s; }
        .stat-card:hover { outline: 2px solid var(--clr-brand); }
        .stat-card-active { outline: 2px solid var(--clr-brand); box-shadow: 0 0 0 4px var(--clr-brand-dim); }
    </style>
}
