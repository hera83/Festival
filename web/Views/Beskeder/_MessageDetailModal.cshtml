@model web.Models.MessageDetailViewModel
@{
    var msg = Model.Message;
    var downloadUrl = Url.Action("DownloadAttachment", "Beskeder");
    var replyUrl    = Url.Action("ReplyMessage", "Beskeder");
    var token       = Html.AntiForgeryToken();
}<div class="modal-header">
    <div>
        <h6 class="modal-title mb-0">
            <i class="bi bi-envelope-open me-2" style="color: var(--clr-brand);"></i>@msg.Subject
        </h6>
        <small style="color: var(--clr-text-muted);">
            @msg.Volunteer.Name
            <span class="badge badge-info ms-1" style="font-size:0.7rem;">@msg.Volunteer.Key</span>
        </small>
    </div>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
</div>
<div class="modal-body">

    @* ── Originale besked ── *@
    <div class="mb-3">
        <div class="d-flex flex-wrap gap-2 mb-1" style="font-size:0.8rem; color: var(--clr-text-muted);">
            <span><i class="bi bi-person me-1"></i>
                @if (msg.Direction == web.Models.MessageDirection.Inbound)
                {
                    @msg.Volunteer.Name
                    <span class="badge badge-info ms-1">Frivillig</span>
                }
                else
                {
                    @Model.SentByName
                    <span class="badge badge-ok ms-1">Koordinator</span>
                }
            </span>
            <span><i class="bi bi-clock me-1"></i>@msg.SentAt.ToString("dd/MM/yyyy HH:mm")</span>
            @if (msg.Direction == web.Models.MessageDirection.Inbound && msg.Latitude.HasValue && msg.Longitude.HasValue)
            {
                <button type="button"
                        onclick="obsShowGpsMap(@msg.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @msg.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), 'Besked – @System.Web.HttpUtility.JavaScriptStringEncode(msg.Volunteer.Name)')"
                        title="Vis GPS-lokation for denne besked"
                        style="background:none;border:none;padding:0 2px;cursor:pointer;color:var(--clr-brand);font-size:1rem;line-height:1;vertical-align:middle;">
                    <i class="bi bi-geo-alt-fill"></i>
                </button>
            }
        </div>
        <div class="p-3 rounded-3"
             style="background: var(--clr-bg); border: 1px solid var(--clr-border); white-space: pre-line; line-height:1.6; font-size:0.9rem; text-align:left; word-break:break-word;">@msg.Body</div>

        @* Vedhæftninger på original besked *@
        @if (msg.Attachments.Any())
        {
            <div class="mt-2 d-flex flex-wrap gap-2">
                @foreach (var att in msg.Attachments)
                {
                    var isImage = att.ContentType.StartsWith("image/");
                    var isVideo = att.ContentType.StartsWith("video/");
                    var attUrl  = $"{downloadUrl}?id={att.Id}";
                    var hasGps  = att.Latitude.HasValue && att.Longitude.HasValue;
                    <div class="rounded-2 overflow-hidden"
                         style="border: 1px solid var(--clr-border); background: var(--clr-bg); max-width:180px;">
                        @if (isImage)
                        {
                            <button type="button"
                                    class="msg-media-preview-trigger"
                                    data-media-type="image"
                                    data-media-src="@attUrl"
                                    data-media-name="@att.OriginalFileName"
                                    style="border:none;background:none;padding:0;width:100%;display:block;">
                                <img src="@attUrl" alt="@att.OriginalFileName"
                                     style="width:180px; height:120px; object-fit:cover; display:block; cursor:zoom-in;" />
                            </button>
                        }
                        else if (isVideo)
                        {
                            <button type="button"
                                    class="msg-media-preview-trigger"
                                    data-media-type="video"
                                    data-media-src="@attUrl"
                                    data-media-content-type="@att.ContentType"
                                    data-media-name="@att.OriginalFileName"
                                    style="border:none;background:none;padding:0;width:100%;display:block;">
                                <video muted style="width:180px; height:120px; display:block; object-fit:cover; pointer-events:none;">
                                    <source src="@attUrl" type="@att.ContentType" />
                                </video>
                            </button>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center"
                                 style="width:180px; height:80px;">
                                <i class="bi bi-file-earmark fs-3" style="color: var(--clr-text-muted);"></i>
                            </div>
                        }
                        <div class="px-2 py-1 d-flex align-items-center justify-content-between gap-1"
                             style="font-size:0.7rem; color: var(--clr-text-muted);">
                            <div class="d-flex align-items-center gap-2" style="min-width:0;">
                                <a href="@attUrl" download="@att.OriginalFileName"
                                   style="color: var(--clr-info); text-decoration:none; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:95px;">
                                    <i class="bi bi-download me-1"></i>@att.OriginalFileName
                                </a>
                                @if (isImage || isVideo)
                                {
                                    <button type="button"
                                            class="btn btn-sm msg-media-preview-trigger"
                                            data-media-type="@(isImage ? "image" : "video")"
                                            data-media-src="@attUrl"
                                            data-media-content-type="@att.ContentType"
                                            data-media-name="@att.OriginalFileName"
                                            style="padding:0 .35rem;line-height:1.25;font-size:.68rem;background:var(--clr-surface);border:1px solid var(--clr-border);color:var(--clr-text);flex-shrink:0;">
                                        <i class="bi bi-arrows-fullscreen"></i>
                                    </button>
                                }
                            </div>
                            @if (hasGps)
                            {
                                <button type="button"
                                        onclick="obsShowGpsMap(@att.Latitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @att.Longitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), '@System.Web.HttpUtility.JavaScriptStringEncode(att.OriginalFileName)')"
                                        title="Vis GPS-lokation"
                                        style="flex-shrink:0;background:none;border:none;padding:0;cursor:pointer;color:var(--clr-brand);font-size:0.95rem;line-height:1;">
                                    <i class="bi bi-geo-alt-fill"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Svar-tråd ── *@
    <div id="thread-messages-@msg.Id" class="d-flex flex-column gap-2 mb-3">
        @foreach (var r in Model.Replies)
            {
                var isOutbound = r.Direction == web.Models.MessageDirection.Outbound;
                var hasReplyGps = !isOutbound && r.Latitude.HasValue && r.Longitude.HasValue;
                <div class="d-flex @(isOutbound ? "justify-content-end" : "justify-content-start")">
                    <div style="max-width: 85%;">
                        <div class="px-3 py-2 rounded-3"
                             style="background: @(isOutbound ? "var(--clr-brand)" : "var(--clr-bg)");
                                    border: 1px solid var(--clr-border);
                                    white-space: pre-line; font-size:0.9rem; line-height:1.5;
                                    color: @(isOutbound ? "#fff" : "var(--clr-text)");
                                    text-align:left; word-break:break-word;
                                    border-bottom-@(isOutbound ? "right" : "left")-radius: 4px;">@r.Body</div>
                        <div class="mt-1 px-1 d-flex align-items-center gap-1"
                             style="font-size: 0.72rem; color: var(--clr-text-muted);
                             justify-content: @(isOutbound ? "flex-end" : "flex-start");">
                            <span><i class="bi bi-person me-1"></i>@r.SenderName</span>
                            <span>&nbsp;·&nbsp;</span>
                            <span><i class="bi bi-clock me-1"></i>@r.SentAt.ToString("dd/MM HH:mm")</span>
                            @if (hasReplyGps)
                            {
                                <button type="button"
                                        onclick="obsShowGpsMap(@r.Latitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @r.Longitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), 'Svar – @System.Web.HttpUtility.JavaScriptStringEncode(r.SenderName)')"
                                        title="Vis GPS-lokation for dette svar"
                                        style="background:none;border:none;padding:0 2px;cursor:pointer;color:var(--clr-brand);font-size:1rem;line-height:1;">
                                    <i class="bi bi-geo-alt-fill"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
    </div>

    @* ── Opgaver ── *@
    @if (msg.Tasks.Any())
    {
        <div class="mb-3">
            <p class="mb-2 fw-semibold" style="font-size:0.85rem; color: var(--clr-text-muted);">
                <i class="bi bi-check2-square me-1"></i>Tilknyttede opgaver (@msg.Tasks.Count)
            </p>
            <div class="d-flex flex-column gap-1">
                @foreach (var t in msg.Tasks)
                {
                    <div class="d-flex align-items-center justify-content-between px-3 py-2 rounded-2"
                         style="background: var(--clr-bg); border: 1px solid var(--clr-border); font-size:0.85rem;">
                        <span class="fw-semibold">@t.Title</span>
                        <div class="d-flex align-items-center gap-2">
                            @if (t.Status == web.Models.MessageTaskStatus.Åben)
                            {
                                <span class="badge badge-info">Åben</span>
                            }
                            else if (t.Status == web.Models.MessageTaskStatus.IGang)
                            {
                                <span class="badge badge-warn">I gang</span>
                            }
                            else
                            {
                                <span class="badge badge-ok">Udført</span>
                            }
                            <button type="button" class="btn btn-sm btn-secondary detail-open-task-btn" data-task-id="@t.Id" title="Åbn opgave">
                                <i class="bi bi-box-arrow-up-right"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Besvar-formular ── *@
    <div class="mt-3 pt-3" style="border-top: 1px solid var(--clr-border);">
        <p class="mb-2 fw-semibold" style="font-size:0.85rem; color: var(--clr-text-muted);">
            <i class="bi bi-reply me-1"></i>Svar
        </p>
        <form id="replyForm-@msg.Id">
            @token
            <input type="hidden" name="messageId" value="@msg.Id" />
            <textarea name="body" class="form-control mb-2" rows="3" placeholder="Skriv svar her…"
                      style="background: var(--clr-bg); border: 1px solid var(--clr-border);
                             color: var(--clr-text); resize: vertical; font-size:0.9rem;"></textarea>
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-send me-1"></i>Send
                </button>
            </div>
        </form>
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-sm btn-warning detail-create-task-btn" data-message-id="@msg.Id">
        <i class="bi bi-check2-square me-1"></i>Opret
    </button>
    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
        <i class="bi bi-x-lg me-1"></i>Luk
    </button>
</div>

<div class="modal fade" id="messageMediaPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title mb-0" id="messageMediaPreviewTitle">
                    <i class="bi bi-arrows-fullscreen me-2" style="color: var(--clr-brand);"></i>Vedhæftning
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body p-2 p-md-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center"
                     style="min-height: 55vh; background: var(--clr-bg); border: 1px solid var(--clr-border);">
                    <img id="messageMediaPreviewImage" alt="Preview" style="display:none;max-width:100%;max-height:75vh;object-fit:contain;" />
                    <video id="messageMediaPreviewVideo" controls style="display:none;max-width:100%;max-height:75vh;object-fit:contain;">
                        <source id="messageMediaPreviewVideoSource" src="" type="video/mp4" />
                    </video>
                </div>
            </div>
            <div class="modal-footer">
                <a id="messageMediaPreviewDownload"
                   class="btn btn-sm btn-info"
                   href="#"
                   download>
                    <i class="bi bi-download me-1"></i>Download
                </a>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Luk
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    document.querySelectorAll('.detail-open-task-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var taskId = parseInt(this.dataset.taskId);
            var detailModalEl = document.getElementById('detailMsgModal') || document.getElementById('detailMsgModalRead');
            if (detailModalEl) {
                var modal = bootstrap.Modal.getInstance(detailModalEl);
                if (modal) modal.hide();
            }
            if (typeof window.openBeskedTaskFromMessage === 'function') {
                window.openBeskedTaskFromMessage(taskId);
            }
        });
    });

    const form = document.getElementById('replyForm-@msg.Id');
    const mediaModalEl = document.getElementById('messageMediaPreviewModal');
    const mediaImage = document.getElementById('messageMediaPreviewImage');
    const mediaVideo = document.getElementById('messageMediaPreviewVideo');
    const mediaVideoSource = document.getElementById('messageMediaPreviewVideoSource');
    const mediaTitle = document.getElementById('messageMediaPreviewTitle');
    const mediaDownload = document.getElementById('messageMediaPreviewDownload');
    const mediaModal = mediaModalEl ? new bootstrap.Modal(mediaModalEl) : null;

    document.querySelectorAll('.msg-media-preview-trigger').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (!mediaModal) return;
            const type = this.dataset.mediaType;
            const src = this.dataset.mediaSrc;
            const contentType = this.dataset.mediaContentType || 'video/mp4';
            const name = this.dataset.mediaName || 'Vedhæftning';

            mediaTitle.innerHTML = '<i class="bi bi-arrows-fullscreen me-2" style="color: var(--clr-brand);"></i>' + name;
            mediaDownload.href = src;
            mediaDownload.setAttribute('download', name);

            if (type === 'video') {
                mediaImage.style.display = 'none';
                mediaImage.removeAttribute('src');
                mediaVideo.style.display = 'block';
                mediaVideoSource.src = src;
                mediaVideoSource.type = contentType;
                mediaVideo.load();
            } else {
                mediaVideo.pause();
                mediaVideo.style.display = 'none';
                mediaVideoSource.src = '';
                mediaVideo.load();
                mediaImage.style.display = 'block';
                mediaImage.src = src;
            }

            mediaModal.show();
        });
    });

    if (mediaModalEl) {
        mediaModalEl.addEventListener('hidden.bs.modal', function () {
            mediaVideo.pause();
            mediaVideoSource.src = '';
            mediaVideo.load();
            mediaImage.removeAttribute('src');
        });
    }

    if (!form) return;
    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        const textarea = form.querySelector('textarea[name="body"]');
        const body = textarea.value.trim();
        if (!body) { showToast('Svar kan ikke være tomt.', 'warning'); return; }
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        try {
            const fd = new FormData(form);
            const res = await fetch('@replyUrl', { method: 'POST', body: fd });
            const json = await res.json();
            if (json.success) {
                showToast(json.message, 'success');
                textarea.value = '';
                // Tilføj svar-boble direkte til tråden
                const container = document.getElementById('thread-messages-@msg.Id');
                if (container) {
                    const now = new Date();
                    const timeStr = now.getDate().toString().padStart(2,'0') + '/' + (now.getMonth()+1).toString().padStart(2,'0') + ' ' + now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
                    const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                    const div = document.createElement('div');
                    div.className = 'd-flex justify-content-end';
                    div.innerHTML = `<div style="max-width:85%;">
                        <div class="px-3 py-2 rounded-3" style="background:var(--clr-brand);border:1px solid transparent;white-space:pre-line;font-size:.9rem;line-height:1.5;color:#fff;text-align:left;word-break:break-word;border-bottom-right-radius:4px;">${esc(body)}</div>
                        <div class="mt-1 px-1" style="font-size:.72rem;color:var(--clr-text-muted);text-align:right;"><i class="bi bi-person me-1"></i>Dig &nbsp;·&nbsp; <i class="bi bi-clock me-1"></i>${timeStr}</div>
                    </div>`;
                    container.appendChild(div);
                    container.scrollTop = container.scrollHeight;
                }
                document.dispatchEvent(new CustomEvent('beskeder:countsChanged'));
            } else {
                showToast(json.message, 'danger');
            }
        } catch {
            showToast('Netværksfejl.', 'danger');
        } finally {
            submitBtn.disabled = false;
        }
    });
})();
</script>

<!-- GPS kort popup -->
<div id="obs-gps-modal-overlay" onclick="obsCloseGpsMap()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.72);z-index:9050;align-items:center;justify-content:center;">
    <div onclick="event.stopPropagation()"
         style="background:var(--clr-surface);border-radius:14px;width:min(96vw,700px);
                box-shadow:0 8px 40px rgba(0,0,0,0.55);overflow:hidden;display:flex;flex-direction:column;">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;
                    border-bottom:1px solid var(--clr-border);flex-shrink:0;">
            <span style="font-weight:700;font-size:0.95rem;color:var(--clr-text);">
                <i class="bi bi-geo-alt-fill me-2" style="color:var(--clr-brand);"></i>
                <span id="obs-gps-modal-title">GPS-lokation</span>
            </span>
            <button onclick="obsCloseGpsMap()" type="button"
                    style="background:none;border:none;color:var(--clr-text-muted);font-size:1.2rem;cursor:pointer;padding:0 4px;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div style="width:100%;height:480px;flex-shrink:0;background:#e0e0e0;">
            <iframe id="obs-gps-iframe"
                    src="about:blank"
                    style="width:100%;height:100%;border:none;display:block;"
                    loading="lazy"
                    referrerpolicy="no-referrer"
                    allowfullscreen></iframe>
        </div>
        <div id="obs-gps-coords"
             style="padding:8px 16px;font-size:0.78rem;color:var(--clr-text-muted);
                    border-top:1px solid var(--clr-border);display:flex;align-items:center;
                    justify-content:space-between;gap:8px;flex-shrink:0;">
        </div>
    </div>
</div>

<script>
    window.obsShowGpsMap = function (lat, lng, filename) {
        const overlay = document.getElementById('obs-gps-modal-overlay');
        overlay.style.display = 'flex';

        document.getElementById('obs-gps-modal-title').textContent = filename || 'GPS-lokation';
        document.getElementById('obs-gps-coords').innerHTML =
            `<span><i class="bi bi-crosshair me-1"></i>${lat.toFixed(6)}, ${lng.toFixed(6)}</span>` +
            `<a href="https://www.google.com/maps?q=${lat},${lng}" target="_blank" rel="noopener noreferrer" ` +
            `style="color:var(--clr-brand);text-decoration:none;font-size:0.78rem;">` +
            `<i class="bi bi-box-arrow-up-right me-1"></i>Åbn i Google Maps</a>`;

        // OpenStreetMap embed via iframe — virker altid uden CDN eller scripts
        const zoom = 16;
        const delta = 0.003; // omtrent 300m bounding box
        const bbox = `${lng - delta},${lat - delta},${lng + delta},${lat + delta}`;
        const src = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat},${lng}`;
        document.getElementById('obs-gps-iframe').src = src;
    };

    window.obsCloseGpsMap = function () {
        document.getElementById('obs-gps-modal-overlay').style.display = 'none';
        document.getElementById('obs-gps-iframe').src = 'about:blank';
    };

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') obsCloseGpsMap();
    });
</script>
