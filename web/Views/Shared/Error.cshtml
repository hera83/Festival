@model ErrorViewModel

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 error-card mt-4">
            <div class="card-body p-4 p-md-5">
                @if (Model.StatusCode.HasValue)
                {
                    <div class="error-code">@Model.StatusCode</div>
                }

                <h1 class="text-danger mb-3">@Model.Title</h1>
                <p class="lead mb-4">@Model.Message</p>

                @if (Model.ShowRequestId)
                {
                    <p class="text-muted mb-4">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Til forsiden</a>
                    <button class="btn btn-outline-secondary" type="button" onclick="history.back()">Gå tilbage</button>
                </div>
            </div>
        </div>
    </div>
</div>
