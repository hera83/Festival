@using web.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Antiforgery
@inject UserManager<AppUser> UserManager
@inject IAntiforgery Antiforgery
<!DOCTYPE html>
@{
    AppUser? layoutUser = null;
    if (User.Identity?.IsAuthenticated == true)
        layoutUser = await UserManager.GetUserAsync(User);
    var colorMode = layoutUser?.ColorMode ?? "system";
}
<html lang="en" data-theme="@colorMode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Festival Vagtstyring</title>
    <script>
        // Løs system-mode FØR CSS renderes, så ingen flash opstår
        (function () {
            var el = document.documentElement;
            if (el.getAttribute('data-theme') === 'system') {
                el.setAttribute('data-theme',
                    window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
            }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/web.styles.css" asp-append-version="true" />
    <meta name="RequestVerificationToken" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = layoutUser;
        var displayName = string.IsNullOrWhiteSpace(currentUser?.DisplayName)
            ? User.Identity?.Name
            : currentUser.DisplayName;
        var avatarFile = currentUser?.AvatarFileName;
        var avatarUrl  = avatarFile is not null
            ? Url.Action("Avatar", "Profile", new { fileName = avatarFile })
            : null;

        <div class="app-shell sidebar-collapsed" id="appShell">
        <script>if(localStorage.getItem("sidebarCollapsed")==="false"){document.getElementById("appShell").classList.remove("sidebar-collapsed");}</script>
            <aside class="side-menu">
                <div class="side-menu-top">

                    <!-- Brand / Toggle -->
                    <button id="menuToggle" type="button" class="menu-item menu-brand" aria-expanded="false" aria-label="Skift menuvisning">
                        <span class="menu-icon"><i class="bi bi-music-note-beamed"></i></span>
                        <span class="menu-text fw-semibold">Festival Controller</span>
                    </button>

                    <hr class="menu-divider" />

                    <!-- Navigation -->
                    <nav class="menu-nav" aria-label="Hovednavigation">
                        <a class="menu-item" asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <span class="menu-icon"><i class="bi bi-speedometer2"></i></span>
                            <span class="menu-text">Dashboard</span>
                        </a>
                        <a class="menu-item" asp-area="" asp-controller="Frivillig" asp-action="Index">
                            <span class="menu-icon"><i class="bi bi-person-heart"></i></span>
                            <span class="menu-text">Frivillig</span>
                        </a>
                        <a class="menu-item" href="/BeskedCenter" id="menuItemBeskeder">
                            <span class="menu-icon menu-icon-notify">
                                <i class="bi bi-chat-dots"></i>
                                <span class="menu-notify-badge" id="menuBeskedBadge"></span>
                            </span>
                            <span class="menu-text">Besked Center</span>
                        </a>
                        <a class="menu-item" asp-area="" asp-controller="Kort" asp-action="Index">
                            <span class="menu-icon"><i class="bi bi-map"></i></span>
                            <span class="menu-text">Kort</span>
                        </a>
                        <a class="menu-item" asp-area="" asp-controller="Vejledninger" asp-action="Index">
                            <span class="menu-icon"><i class="bi bi-book"></i></span>
                            <span class="menu-text">Vejledninger</span>
                        </a>

                    </nav>
                </div>

                <div class="side-menu-bottom">

                    <!-- Bruger / Profil -->
                    <a class="menu-item menu-item-user" href="/MinProfile">
                        <span class="menu-icon">
                            @if (avatarUrl is not null)
                            {
                                <img src="@avatarUrl" alt="Avatar"
                                     style="width:28px;height:28px;border-radius:50%;object-fit:cover;" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle"></i>
                            }
                        </span>
                        <span class="menu-text">
                            <span class="menu-username d-block">@displayName</span>
                            <span class="menu-userrole d-block">@(User.IsInRole("Administrator") ? "Administrator" : User.IsInRole("Koordinator") ? "Koordinator" : "Bruger")</span>
                        </span>
                    </a>

                    <hr class="menu-divider" />

                    <!-- Administrator -->
                    @if (User.IsInRole("Administrator"))
                    {
                        <a class="menu-item" href="/Administration">
                            <span class="menu-icon"><i class="bi bi-gear"></i></span>
                            <span class="menu-text">Administration</span>
                        </a>
                        <hr class="menu-divider" />
                    }

                    <!-- Log ud -->
                    <form asp-controller="Account" asp-action="Logout" method="post" class="menu-form">
                        <button type="submit" class="menu-item menu-item-logout">
                            <span class="menu-icon"><i class="bi bi-box-arrow-left"></i></span>
                            <span class="menu-text">Log ud</span>
                        </button>
                    </form>
                </div>
            </aside>

            <main role="main" class="app-content" id="app-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <div id="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // ── Global toast ──────────────────────────────────────────
        function showToast(message, type) {
            type = type || 'success';
            var icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warn: 'bi-exclamation-triangle-fill', info: 'bi-info-circle-fill' };
            var icon  = icons[type] || icons.success;
            var el    = document.createElement('div');
            el.className = 'fv-toast fv-toast-' + type;
            el.innerHTML =
                '<i class="bi ' + icon + ' fv-toast-icon"></i>' +
                '<span>' + message + '</span>' +
                '<button class="fv-toast-close" aria-label="Luk"><i class="bi bi-x"></i></button>';
            document.getElementById('toast-container').appendChild(el);
            el.querySelector('.fv-toast-close').addEventListener('click', function () { dismissToast(el); });
            setTimeout(function () { dismissToast(el); }, 3000);
        }
        function dismissToast(el) {
            if (el._dismissing) return;
            el._dismissing = true;
            el.classList.add('fv-toast-hide');
            setTimeout(function () { el.remove(); }, 300);
        }
        // ── TempData toasts ───────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            @if (TempData["Success"] is string s) { <text>showToast('@Html.Raw(s.Replace("'", "\\'"))', 'success');</text> }
            @if (TempData["Error"]   is string e) { <text>showToast('@Html.Raw(e.Replace("'", "\\'"))', 'error');</text> }
            @if (TempData["Warning"] is string w) { <text>showToast('@Html.Raw(w.Replace("'", "\\'"))', 'warn');</text> }
            @if (TempData["Info"]    is string i) { <text>showToast('@Html.Raw(i.Replace("'", "\\'"))', 'info');</text> }
        });
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const appShell = document.getElementById("appShell");
            const menuToggle = document.getElementById("menuToggle");

            if (!appShell || !menuToggle) {
                return;
            }

            // Sæt aria-expanded korrekt baseret på aktuel tilstand (sat synkront ovenfor)
            menuToggle.setAttribute("aria-expanded", String(!appShell.classList.contains("sidebar-collapsed")));

            menuToggle.addEventListener("click", function () {
                const isCollapsed = appShell.classList.toggle("sidebar-collapsed");
                menuToggle.setAttribute("aria-expanded", String(!isCollapsed));
                localStorage.setItem("sidebarCollapsed", String(isCollapsed));
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const badgeEl = document.getElementById('menuBeskedBadge');
            const itemEl = document.getElementById('menuItemBeskeder');
            if (!badgeEl || !itemEl) return;

            let previousUnread = null;

            async function refreshBeskedMenuIndicator() {
                try {
                    const res = await fetch('@Url.Action("GetCounts", "Beskeder")', {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!res.ok) return;

                    const data = await res.json();
                    const unread = Number(data.unreadCount || 0);

                    if (unread > 0) {
                        badgeEl.textContent = unread > 99 ? '99+' : String(unread);
                        badgeEl.classList.add('show');
                    } else {
                        badgeEl.classList.remove('show');
                        badgeEl.textContent = '';
                    }
                    previousUnread = unread;
                } catch {
                    // Netværksfejl ignoreres bevidst for ikke at forstyrre brugeren
                }
            }

            refreshBeskedMenuIndicator();
            setInterval(refreshBeskedMenuIndicator, 30000);

            document.addEventListener('visibilitychange', function () {
                if (document.visibilityState === 'visible') refreshBeskedMenuIndicator();
            });

            document.addEventListener('beskeder:countsChanged', function () {
                refreshBeskedMenuIndicator();
            });

            window.refreshBeskedMenuIndicator = refreshBeskedMenuIndicator;
        });
    </script>
    <div id="page-scripts">
        @await RenderSectionAsync("Scripts", required: false)
    </div>
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        @* ── Global QR Pit-scanner – overlever sidenavigation ── *@
        <video id="qrPitVideo" autoplay playsinline muted
               style="display:none;position:fixed;bottom:12px;right:12px;width:1px;height:1px;opacity:0;pointer-events:none;"></video>
        <canvas id="qrPitCanvas" style="display:none;"></canvas>

        @* Flydende indikator – synlig på sider uden dashboard-knap *@
        <button id="qrGlobalIndicator" type="button"
                title="QR Scanner aktiv – klik for at slukke"
                style="display:none;position:fixed;bottom:18px;right:18px;z-index:8500;
                       background:var(--clr-brand);color:#fff;border:none;border-radius:50%;
                       width:42px;height:42px;font-size:1.1rem;cursor:pointer;
                       box-shadow:0 2px 10px rgba(0,0,0,.45);align-items:center;justify-content:center;">
            <i class="bi bi-qr-code-scan"></i>
        </button>

        <script>
        (function () {
            // ── Konstanter ────────────────────────────────────────────────
            const STORAGE_KEY = 'qrScannerActive';
            const scanUrl     = '@Url.Action("QrScanPit",           "Dashboard")';
            const prefGetUrl  = '@Url.Action("GetCameraPreference",  "Dashboard")';
            const prefSaveUrl = '@Url.Action("SaveCameraPreference", "Dashboard")';
            const prefClrUrl  = '@Url.Action("ClearCameraPreference","Dashboard")';

            const video   = document.getElementById('qrPitVideo');
            const canvas  = document.getElementById('qrPitCanvas');
            const ctx     = canvas.getContext('2d', { willReadFrequently: true });
            const indicator = document.getElementById('qrGlobalIndicator');

            let active      = false;
            let stream      = null;
            let rafId       = null;
            let lastKey     = null;
            let cooldown    = false;
            let workerBusy  = false;
            let lastScanTime = 0;

            // ── Audio ─────────────────────────────────────────────────────
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            function playBeep(type) {
                const seqs = {
                    success:      [{ f: 880, d: 0.12 }, { f: 1320, d: 0.18 }],
                    error:        [{ f: 440, d: 0.08 }, { f: 280,  d: 0.30 }],
                    alreadyinpit: [{ f: 600, d: 0.06 }, { f: 400,  d: 0.06 }, { f: 280, d: 0.20 }],
                };
                let t = audioCtx.currentTime + 0.05;
                for (const n of (seqs[type] || seqs.error)) {
                    const osc = audioCtx.createOscillator();
                    const g   = audioCtx.createGain();
                    osc.connect(g); g.connect(audioCtx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(n.f, t);
                    g.gain.setValueAtTime(0.35, t);
                    g.gain.exponentialRampToValueAtTime(0.001, t + n.d);
                    osc.start(t); osc.stop(t + n.d);
                    t += n.d + 0.04;
                }
            }

            // ── Toast ─────────────────────────────────────────────────────
            function showQrToast(message, type) {
                const colorMap = { success: 'var(--clr-ok)', warning: 'var(--clr-brand)', error: 'var(--clr-alarm)' };
                const iconMap  = { success: 'bi-check-circle-fill', warning: 'bi-exclamation-triangle-fill', error: 'bi-x-circle-fill' };
                const color    = colorMap[type] || colorMap.warning;
                const icon     = iconMap[type]  || iconMap.warning;

                const el = document.createElement('div');
                el.style.cssText = `position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:9999;
                    background:var(--clr-surface);border:1px solid ${color};border-left:4px solid ${color};
                    color:var(--clr-text);padding:.65rem 1.1rem;border-radius:8px;font-size:.88rem;
                    display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.4);
                    min-width:260px;max-width:420px;`;
                el.innerHTML = `<i class="bi ${icon}" style="color:${color};font-size:1rem;flex-shrink:0;"></i><span>${message}</span>`;
                document.body.appendChild(el);
                setTimeout(() => {
                    el.style.transition = 'opacity .5s';
                    el.style.opacity = '0';
                    setTimeout(() => el.remove(), 500);
                }, 10000);
            }

            // ── Kamera-præference ─────────────────────────────────────────
            function buildFingerprint(devices) {
                return devices.filter(d => d.kind === 'videoinput').map(d => d.deviceId).sort().join(',');
            }
            async function loadCamPref() {
                try {
                    const res = await fetch(prefGetUrl);
                    if (res.ok) return await res.json();
                } catch { /* ignorer */ }
                return { deviceId: null, deviceFingerprint: null };
            }

            // ── Web Worker ────────────────────────────────────────────────
            const worker = new Worker('/js/qr-worker.js');
            worker.onmessage = function (e) {
                workerBusy = false;
                if (!active || cooldown) return;
                const key = e.data;
                if (key && key !== lastKey) {
                    lastKey = key;
                    handleScan(key);
                }
            };

            // ── Scan-loop (~8 fps) ────────────────────────────────────────
            const SCAN_W = 640;
            const SCAN_H = 480;
            function tick(now) {
                if (active) rafId = requestAnimationFrame(tick);
                if (workerBusy || cooldown) return;
                if (now - lastScanTime < 125) return;
                lastScanTime = now;
                if (video.readyState !== video.HAVE_ENOUGH_DATA) return;
                canvas.width  = SCAN_W;
                canvas.height = SCAN_H;
                ctx.filter = 'contrast(1.5) brightness(1.05) saturate(0)';
                ctx.drawImage(video, 0, 0, SCAN_W, SCAN_H);
                ctx.filter = 'none';
                const imgData = ctx.getImageData(0, 0, SCAN_W, SCAN_H);
                workerBusy = true;
                worker.postMessage({ data: imgData.data, width: SCAN_W, height: SCAN_H }, [imgData.data.buffer]);
            }

            // ── Opslag ────────────────────────────────────────────────────
            async function handleScan(key) {
                cooldown = true;
                setTimeout(() => { cooldown = false; lastKey = null; }, 3500);
                const csrfToken = document.querySelector('meta[name="RequestVerificationToken"]').content;
                try {
                    const res  = await fetch(scanUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({ key })
                    });
                    const data = await res.json();
                    switch (data.result) {
                        case 'checkedin':
                            playBeep('success');
                            showQrToast(data.message, 'success');
                            if (typeof loadPitVolunteers === 'function') loadPitVolunteers('');
                            if (typeof loadAllPosts === 'function') loadAllPosts();
                            if (typeof updateCheckedInCount === 'function') updateCheckedInCount();
                            break;
                        case 'moved':
                            playBeep('success');
                            showQrToast(data.message, 'success');
                            document.querySelectorAll(`[data-volunteer-id="${data.volunteerId}"]`).forEach(el => el.remove());
                            if (typeof loadPitVolunteers === 'function') loadPitVolunteers('');
                            if (typeof loadAllPosts === 'function') loadAllPosts();
                            break;
                        case 'alreadyinpit':
                            playBeep('alreadyinpit');
                            showQrToast(data.message, 'warning');
                            break;
                        default:
                            playBeep('error');
                            showQrToast(data.message || 'Ukendt fejl', 'error');
                    }
                } catch {
                    playBeep('error');
                    showQrToast('Netværksfejl – kunne ikke kontakte server', 'error');
                }
            }

            // ── Start / Stop ──────────────────────────────────────────────
            async function startScanner() {
                let devices = [];
                try {
                    const tmp = await navigator.mediaDevices.getUserMedia({ video: true });
                    tmp.getTracks().forEach(t => t.stop());
                    devices = await navigator.mediaDevices.enumerateDevices();
                } catch { /* ignorer */ }

                const currentFp = buildFingerprint(devices);
                const pref = await loadCamPref();

                let videoConstraints;
                if (pref.deviceId && pref.deviceFingerprint === currentFp) {
                    videoConstraints = { deviceId: { exact: pref.deviceId }, width: { ideal: 1280 }, height: { ideal: 720 } };
                } else {
                    if (pref.deviceFingerprint && pref.deviceFingerprint !== currentFp) {
                        const csrfToken = document.querySelector('meta[name="RequestVerificationToken"]').content;
                        try { await fetch(prefClrUrl, { method: 'POST', headers: { 'RequestVerificationToken': csrfToken } }); }
                        catch { /* ignorer */ }
                    }
                    videoConstraints = { facingMode: { ideal: 'environment' }, width: { ideal: 1280 }, height: { ideal: 720 } };
                }

                try {
                    stream = await navigator.mediaDevices.getUserMedia({ video: videoConstraints });
                } catch {
                    try { stream = await navigator.mediaDevices.getUserMedia({ video: true }); }
                    catch { showQrToast('Kamera ikke tilgængeligt', 'error'); return; }
                }
                video.srcObject = stream;
                await video.play();
                active = true;
                lastKey = null;
                workerBusy = false;
                lastScanTime = 0;
                sessionStorage.setItem(STORAGE_KEY, '1');
                updateUI();
                rafId = requestAnimationFrame(tick);
            }

            function stopScanner() {
                if (stream) stream.getTracks().forEach(t => t.stop());
                if (rafId)  cancelAnimationFrame(rafId);
                stream = null; rafId = null; active = false; lastKey = null; workerBusy = false;
                sessionStorage.removeItem(STORAGE_KEY);
                updateUI();
            }

            // ── UI-synkronisering ─────────────────────────────────────────
            function updateUI() {
                // Dashboard-knap (kun til stede på dashboard-siden)
                const btn = document.getElementById('qrPitScanBtn');
                if (btn) {
                    if (active) {
                        btn.style.background  = 'var(--clr-brand)';
                        btn.style.color       = '#fff';
                        btn.style.borderColor = 'var(--clr-brand)';
                        btn.title             = 'QR Scanner – sluk';
                    } else {
                        btn.style.background  = 'var(--clr-bg)';
                        btn.style.color       = 'var(--clr-text-muted)';
                        btn.style.borderColor = 'var(--clr-border)';
                        btn.title             = 'QR Scanner – tænd';
                    }
                }
                // Flydende indikator – vis kun på sider uden dashboard-knappen
                if (!btn) {
                    indicator.style.display = active ? 'flex' : 'none';
                } else {
                    indicator.style.display = 'none';
                }
            }

            // ── Globale API ───────────────────────────────────────────────
            window.toggleQrScanner  = function () { if (active) stopScanner(); else startScanner(); };
            window.isQrScannerActive = function () { return active; };
            window._qrUpdateUI       = updateUI;

            // ── Flydende indikator – klik slukker ─────────────────────────
            indicator.addEventListener('click', () => stopScanner());

            // ── Gendan tilstand ved sideindlæsning ────────────────────────
            document.addEventListener('DOMContentLoaded', function () {
                if (sessionStorage.getItem(STORAGE_KEY) === '1') {
                    startScanner();
                } else {
                    updateUI();
                }
            });
        })();
        </script>

        <script>
        // ── SPA-navigation: swapper kun #app-content så kameraet aldrig stoppes ──
        (function () {
            // Tracker side-specifikke intervals/timeouts så de kan ryddes ved navigation
            let _pageIntervals = [];
            let _pageTimeouts  = [];
            const _origSetInterval = window.setInterval;
            const _origSetTimeout  = window.setTimeout;
            const _origClearInterval = window.clearInterval;
            const _origClearTimeout  = window.clearTimeout;

            function clearPageTimers() {
                _pageIntervals.forEach(id => _origClearInterval(id));
                _pageTimeouts.forEach(id  => _origClearTimeout(id));
                _pageIntervals = [];
                _pageTimeouts  = [];
            }

            // Kan ikke patche window.setInterval/setTimeout globalt pga. strict IIFE –
            // vi sætter dem som properties, der kan overskrives af page-scripts under udførelse
            function patchTimers() {
                window.setInterval = function (fn, delay, ...args) {
                    const id = _origSetInterval(fn, delay, ...args);
                    _pageIntervals.push(id);
                    return id;
                };
                window.setTimeout = function (fn, delay, ...args) {
                    const id = _origSetTimeout(fn, delay, ...args);
                    _pageTimeouts.push(id);
                    return id;
                };
            }
            function unpatchTimers() {
                window.setInterval = _origSetInterval;
                window.setTimeout  = _origSetTimeout;
            }

            // Patcher DOMContentLoaded så page-scripts' DOMContentLoaded-callbacks
            // kører straks (DOM er allerede klar efter innerHTML-swap)
            let _domListeners = [];
            const _origAddEventListener = document.addEventListener.bind(document);
            function patchDOMReady() {
                document.addEventListener = function (type, fn, opts) {
                    if (type === 'DOMContentLoaded') {
                        _domListeners.push(fn);
                    } else {
                        _origAddEventListener(type, fn, opts);
                    }
                };
            }
            function unpatchDOMReady() {
                document.addEventListener = _origAddEventListener;
            }
            function flushDOMListeners() {
                const list = _domListeners.slice();
                _domListeners = [];
                list.forEach(fn => { try { fn(); } catch(e) { console.error('[SPA] DOMContentLoaded cb error', e); } });
            }

            // Udfør scripts fra en DOM-node (genskaber <script> så browseren evaluerer dem).
            // Returnerer et Promise – externe scripts indlæses sekventielt FØR inline-kode køres.
            // _loadedExternalSrcs sporer URLs der faktisk er indlæst i denne session.
            const _loadedExternalSrcs = new Set(
                [...document.head.querySelectorAll('script[src]')].map(s => s.src)
            );
            const _loadedExternalCss = new Set(
                [...document.head.querySelectorAll('link[rel="stylesheet"][href]')].map(l => l.href)
            );
            async function runScripts(container) {
                // Flyt <link rel="stylesheet"> permanent til <head> så de ikke forsvinder ved næste swap
                container.querySelectorAll('link[rel="stylesheet"][href]').forEach(old => {
                    const abs = new URL(old.href, location.href).href;
                    if (!_loadedExternalCss.has(abs)) {
                        _loadedExternalCss.add(abs);
                        const l = document.createElement('link');
                        l.rel  = 'stylesheet';
                        l.href = abs;
                        document.head.appendChild(l);
                    }
                    old.remove();
                });

                const nodes = [...container.querySelectorAll('script')];
                for (const old of nodes) {
                    if (old.src) {
                        // Normaliser URL til absolut så sammenligning er stabil
                        const abs = new URL(old.src, location.href).href;
                        if (!_loadedExternalSrcs.has(abs)) {
                            _loadedExternalSrcs.add(abs);
                            await new Promise(resolve => {
                                const s = document.createElement('script');
                                s.src     = abs;
                                s.onload  = resolve;
                                s.onerror = resolve; // fortsæt selv ved fejl så siden ikke hænger
                                document.head.appendChild(s);
                            });
                        }
                    } else {
                        const s = document.createElement('script');
                        s.textContent = old.textContent;
                        old.parentNode.replaceChild(s, old);
                    }
                }
            }

            // Opdatér aktiv menu-markering
            function updateActiveMenu(url) {
                document.querySelectorAll('.side-menu .menu-item').forEach(a => {
                    a.classList.remove('active');
                    if (a.tagName === 'A') {
                        const href = a.getAttribute('href');
                        if (href && url.startsWith(href) && href !== '/') {
                            a.classList.add('active');
                        }
                    }
                });
            }

            // Navigér til url uden fuld side-reload
            async function navigate(url) {
                try {
                    const res = await fetch(url, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest-SPA' }
                    });
                    if (!res.ok || res.redirected) {
                        // Fejl eller redirect (fx login) – tag fuld navigation
                        window.location.href = url;
                        return;
                    }

                    const html = await res.text();
                    const parser = new DOMParser();
                    const doc    = parser.parseFromString(html, 'text/html');

                    const newContent = doc.getElementById('app-content');
                    const newScripts = doc.getElementById('page-scripts');

                    if (!newContent) {
                        // Siden bruger ikke vores layout (fx login) – fuld navigation
                        window.location.href = url;
                        return;
                    }

                    // Opdater title
                    if (doc.title) document.title = doc.title;

                    // Opdater CSRF-token hvis siden har et nyt
                    const newToken = doc.querySelector('meta[name="RequestVerificationToken"]');
                    const curToken = document.querySelector('meta[name="RequestVerificationToken"]');
                    if (newToken && curToken) curToken.content = newToken.content;

                    // Ryd side-specifikke timere fra forrige side
                    clearPageTimers();

                    // Patch timers + DOMContentLoaded FØR vi kører de nye scripts
                    patchTimers();
                    patchDOMReady();

                    // Swap indhold
                    const main = document.getElementById('app-content');
                    main.innerHTML = newContent.innerHTML;

                    // Swap page-scripts
                    const ps = document.getElementById('page-scripts');
                    if (ps && newScripts) {
                        ps.innerHTML = newScripts.innerHTML;
                        await runScripts(ps);
                    }

                    // Kald patchede DOMContentLoaded callbacks
                    flushDOMListeners();

                    // Unpatch
                    unpatchTimers();
                    unpatchDOMReady();

                    // Synkronisér QR-knap
                    if (typeof window._qrUpdateUI === 'function') window._qrUpdateUI();

                    // Opdatér browser-historik og menu
                    history.pushState({ spa: true }, '', url);
                    updateActiveMenu(url);

                    // Scroll til top
                    main.scrollTop = 0;

                } catch (err) {
                    console.warn('[SPA] navigation fejl, falder tilbage til fuld load', err);
                    window.location.href = url;
                }
            }

            // Håndtér browser Back/Forward
            window.addEventListener('popstate', function (e) {
                if (e.state && e.state.spa) navigate(location.pathname + location.search);
            });

            // Markér initial state i history
            history.replaceState({ spa: true }, '', location.pathname + location.search);

            // Opfang klik på sidebar-links
            document.addEventListener('click', function (e) {
                const link = e.target.closest('.side-menu a[href]');
                if (!link) return;

                const href = link.getAttribute('href');
                // Lad eksterne links, ankre og ikke-GET-links gå igennem normalt
                if (!href || href.startsWith('http') || href.startsWith('#') || href.startsWith('//')) return;
                // Lad login/logout-forms gå igennem
                if (link.closest('form')) return;

                e.preventDefault();
                if (location.pathname + location.search === href) return; // allerede her
                navigate(href);
            });

            // Sæt aktiv menu ved første indlæsning
            updateActiveMenu(location.pathname);
        })();
        </script>
    }
</body>
</html>
