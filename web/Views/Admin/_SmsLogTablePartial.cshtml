@model web.Models.SmsLogViewModel
@{
    string StatusBadgeClass(string status) => status.ToLowerInvariant() switch
    {
        "sent" or "delivered" or "queued" or "modtaget" => "badge-ok",
        "failed" or "error" or "rejected" => "badge-alarm",
        _ => "badge-info"
    };
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-chat-dots me-2"></i>Sms'er (<span id="smsLogCount">@Model.TotalCount</span>)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="color: var(--clr-text);">
                <thead>
                    <tr style="border-bottom: 1px solid var(--clr-border);">
                        <th class="ps-3">Retning</th>
                        <th>Frivillig</th>
                        <th>Telefon</th>
                        <th>Besked</th>
                        <th>Status</th>
                        <th class="text-end">Pris</th>
                        <th>Tidspunkt</th>
                        <th class="pe-3">Sendt af</th>
                    </tr>
                </thead>
                <tbody id="smsLogTableBody">
                    @if (!Model.Items.Any())
                    {
                        <tr id="smsLogEmptyRow">
                            <td colspan="8" class="text-center py-4" style="color: var(--clr-text-muted);">
                                <i class="bi bi-chat-dots fs-4 d-block mb-1"></i>
                                Ingen sms'er endnu
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Items)
                    {
                        var isInbound = row.Direction == web.Models.SmsDirection.Inbound;
                        <tr style="border-bottom: 1px solid var(--clr-border);">
                            <td class="ps-3 align-middle">
                                @if (isInbound)
                                {
                                    <span class="badge-info"><i class="bi bi-arrow-down-left me-1"></i>Ind</span>
                                }
                                else
                                {
                                    <span style="background: var(--clr-brand-dim); color: var(--clr-brand); padding: 2px 8px; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">
                                        <i class="bi bi-arrow-up-right me-1"></i>Ud
                                    </span>
                                }
                            </td>
                            <td class="align-middle fw-semibold">@(row.VolunteerName ?? "Ukendt")</td>
                            <td class="align-middle" style="font-family: monospace; font-size: 0.85rem;">@row.PhoneNumberSnapshot</td>
                            <td class="align-middle" style="color: var(--clr-text-muted); font-size: 0.85rem; max-width: 280px;">
                                <span title="@row.MessageBody" style="display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@row.MessageBody</span>
                            </td>
                            <td class="align-middle"><span class="@StatusBadgeClass(row.Status)">@row.Status</span></td>
                            <td class="align-middle text-end" style="font-size: 0.85rem;">@(isInbound ? "–" : row.TotalPriceDkk.ToString("0.00") + " kr.")</td>
                            <td class="align-middle" style="font-size: 0.85rem; color: var(--clr-text-muted);">@row.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="pe-3 align-middle" style="font-size: 0.85rem; color: var(--clr-text-muted);">@(row.SentByDisplayName ?? "–")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Pagineringsbar ── *@
<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2" id="smsLogPagerBar">
    <small style="color: var(--clr-text-muted);" id="smsLogRangeText">@Model.RangeFrom–@Model.RangeTo af @Model.TotalCount</small>
    <div class="d-flex align-items-center gap-2">
        <span style="font-size: 0.8rem; color: var(--clr-text-muted);">Pr. side</span>
        <select id="smsLogPageSize" class="form-select form-select-sm" style="width: auto; background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">
            @foreach (var s in new[] { 10, 25, 50 })
            {
                <option value="@s" selected="@(Model.PageSize == s ? "selected" : null)">@s</option>
            }
        </select>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <button type="button" class="page-link smsLog-page-btn" data-page="@(Model.Page - 1)"
                            style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">&lsaquo;</button>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    if (p == 1 || p == Model.TotalPages || Math.Abs(p - Model.Page) <= 1)
                    {
                        var isActive = p == Model.Page;
                        var pgStyle = isActive
                            ? "background: var(--clr-brand); border-color: var(--clr-brand); color: #fff;"
                            : "background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);";
                        <li class="page-item @(isActive ? "active" : "")">
                            <button type="button" class="page-link smsLog-page-btn" data-page="@p" style="@pgStyle">@p</button>
                        </li>
                    }
                    else if (Math.Abs(p - Model.Page) == 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">…</span>
                        </li>
                    }
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <button type="button" class="page-link smsLog-page-btn" data-page="@(Model.Page + 1)"
                            style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">&rsaquo;</button>
                </li>
            </ul>
        </nav>
    </div>
</div>
