@model web.Models.KortStederViewModel
@{
    string CatLabel(string cat) => cat switch {
        "Pit"          => "👥 Pit",
        "Post"         => "📍 Post",
        "Scene"        => "🎵 Scene",
        "Toiletter"    => "🚽 Toiletter",
        "Førstehjælp"  => "🚑 Førstehjælp",
        "Parkering"    => "🅿️ Parkering",
        _              => cat
    };
}

@* ── Søgebar + Opret-knap ── *@
<div class="d-flex align-items-center justify-content-between mb-3 gap-2">
    <div class="input-group input-group-sm" style="max-width: 340px;">
        <span class="input-group-text" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
            <i class="bi bi-search"></i>
        </span>
        <input type="text" id="poiSearchInput" class="form-control form-control-sm"
               placeholder="Søg navn, kategori…"
               style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);"
               value="@Model.Q" autocomplete="off" />
    </div>
    <button type="button" class="btn btn-sm"
            style="background: var(--clr-brand); color: #fff; border: none; white-space: nowrap;"
            data-bs-toggle="modal" data-bs-target="#opretPoiModal">
        <i class="bi bi-pin-map me-1"></i>Opret sted
    </button>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-geo-alt me-2"></i>Kortsteder (<span id="poiCount">@Model.TotalCount</span>)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="color: var(--clr-text);">
                <thead>
                    <tr style="border-bottom: 1px solid var(--clr-border);">
                        <th class="ps-3">Navn</th>
                        <th>Kategori</th>
                        <th>Beskrivelse</th>
                        <th>Koordinater</th>
                        <th class="pe-3 text-end">Handlinger</th>
                    </tr>
                </thead>
                <tbody id="poiTableBody">
                    @if (!Model.Items.Any())
                    {
                        <tr id="poiEmptyRow">
                            <td colspan="5" class="text-center py-4" style="color: var(--clr-text-muted);">
                                <i class="bi bi-geo-alt fs-4 d-block mb-1"></i>
                                Ingen kortsteder fundet
                            </td>
                        </tr>
                    }
                    @foreach (var poi in Model.Items)
                    {
                        var latStr = poi.Latitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
                        var lngStr = poi.Longitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
                        <tr style="border-bottom: 1px solid var(--clr-border);">
                            <td class="ps-3 align-middle fw-semibold">@poi.Name</td>
                            <td class="align-middle">
                                <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.2rem 0.6rem;border-radius:999px;background:var(--clr-surface);border:1px solid var(--clr-border);font-size:0.8rem;font-weight:500;color:var(--clr-text);">@CatLabel(poi.Category)</span>
                            </td>
                            <td class="align-middle" style="color: var(--clr-text-muted); font-size: 0.85rem;">
                                @(poi.Description ?? "–")
                            </td>
                            <td class="align-middle" style="font-size: 0.8rem; color: var(--clr-text-muted); font-family: monospace;">
                                @latStr, @lngStr
                            </td>
                            <td class="pe-3 align-middle text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button type="button" class="btn btn-sm btn-secondary poi-rediger-btn"
                                            title="Rediger sted"
                                            data-id="@poi.Id"
                                            data-name="@poi.Name"
                                            data-category="@poi.Category"
                                            data-lat="@latStr"
                                            data-lng="@lngStr"
                                            data-description="@(poi.Description ?? "")">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-danger poi-slet-btn"
                                            title="Slet sted"
                                            data-id="@poi.Id"
                                            data-name="@poi.Name">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Pagineringsbar ── *@
<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2" id="poiPagerBar">
    <small style="color: var(--clr-text-muted);" id="poiRangeText">@Model.RangeFrom–@Model.RangeTo af @Model.TotalCount</small>
    <div class="d-flex align-items-center gap-2">
        <span style="font-size: 0.8rem; color: var(--clr-text-muted);">Pr. side</span>
        <select id="poiPageSize" class="form-select form-select-sm" style="width: auto; background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">
            @foreach (var s in new[] { 10, 25, 50 })
            {
                <option value="@s" selected="@(Model.PageSize == s ? "selected" : null)">@s</option>
            }
        </select>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <button type="button" class="page-link poi-page-btn" data-page="@(Model.Page - 1)"
                            style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">&lsaquo;</button>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    if (p == 1 || p == Model.TotalPages || Math.Abs(p - Model.Page) <= 1)
                    {
                        var isActive = p == Model.Page;
                        var pgStyle = isActive
                            ? "background: var(--clr-brand); border-color: var(--clr-brand); color: #fff;"
                            : "background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);";
                        <li class="page-item @(isActive ? "active" : "")">
                            <button type="button" class="page-link poi-page-btn" data-page="@p" style="@pgStyle">@p</button>
                        </li>
                    }
                    else if (Math.Abs(p - Model.Page) == 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">…</span>
                        </li>
                    }
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <button type="button" class="page-link poi-page-btn" data-page="@(Model.Page + 1)"
                            style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);">&rsaquo;</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@* ── Opret POI modal ── *@
<div class="modal fade" id="opretPoiModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="/Admin/KortStederOpret">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pin-map me-2" style="color: var(--clr-brand);"></i>Opret nyt sted</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-7">
                            <label class="form-label" style="color: var(--clr-text-muted); font-size: 0.82rem;">Navn *</label>
                            <input type="text" name="name" class="form-control form-control-sm" required
                                   style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />
                        </div>
                        <div class="col-sm-5">
                            <label class="form-label" style="color: var(--clr-text-muted); font-size: 0.82rem;">Kategori *</label>
                            <select name="category" class="form-select form-select-sm"
                                    style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);">
                                <option value="Pit">👥 Pit</option>
                                <option value="Post">📍 Post</option>
                                <option value="Scene">🎵 Scene</option>
                                <option value="Toiletter">🚽 Toiletter</option>
                                <option value="Førstehjælp">🚑 Førstehjælp</option>
                                <option value="Parkering">🅿️ Parkering</option>
                                <option value="Andet">📌 Andet</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color: var(--clr-text-muted); font-size: 0.82rem;">Beskrivelse</label>
                        <input type="text" name="description" class="form-control form-control-sm"
                               style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="color: var(--clr-text-muted); font-size: 0.82rem;">Breddegrad (Lat)</label>
                            <input type="text" inputmode="decimal" name="latitude" id="opretLat" class="form-control form-control-sm" required
                                   style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="color: var(--clr-text-muted); font-size: 0.82rem;">Længdegrad (Lng)</label>
                            <input type="text" inputmode="decimal" name="longitude" id="opretLng" class="form-control form-control-sm" required
                                   style="background: var(--clr-bg); border-color: var(--clr-border); color: var(--clr-text);" />
                        </div>
                    </div>
                    <div class="mb-1">
                        <small style="color: var(--clr-text-muted);"><i class="bi bi-cursor me-1"></i>Klik på kortet herunder for at sætte koordinater</small>
                    </div>
                    <div id="opretPoiMap" style="height: 300px; border-radius: var(--radius-md); border: 1px solid var(--clr-border);"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg me-1"></i>Annuller</button>
                    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-pin-map me-1"></i>Opret</button>
                </div>
            </form>
        </div>
    </div>
</div>

