@* ── Slet POI modal ── *@
<div class="modal fade" id="sletPoiModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/Admin/KortStederSlet">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="sletPoiId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-trash me-2" style="color: var(--clr-alarm);"></i>Slet sted</h5>
