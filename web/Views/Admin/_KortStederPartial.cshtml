                </div>
            </form>
        </div>
    </div>
</div>

@* ── Leaflet CSS + JS (dynamisk indlæsning, da partialen hentes via fetch) ── *@
<script>
(function () {
    var _opretMap = null, _opretMarker = null;
    var _redigerMap = null, _redigerMarker = null;

    function loadLeaflet(callback) {
        // Sikr altid at CSS er til stede i <head> (kan være fjernet ved SPA-navigation)
        if (!document.getElementById('leaflet-css')) {
            var css = document.createElement('link');
            css.id  = 'leaflet-css';
            css.rel = 'stylesheet';
            css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(css);
        }

        if (window.L) { callback(); return; }

        // Indlæs JS
        var script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.onload = callback;
        document.head.appendChild(script);
    }
    var poiSearchTimer = null;
    var poiCurrentPage = @Model.Page;
    var poiCurrentPageSize = @Model.PageSize;
    var poiCurrentQ = '@Html.Raw(Model.Q.Replace("'", "\\'").Replace("\\", "\\\\"))';

    // ── Søgning ──
    document.getElementById('poiSearchInput').addEventListener('keyup', function () {
        clearTimeout(poiSearchTimer);
        var val = this.value;
        poiSearchTimer = setTimeout(function () {
            poiCurrentQ = val;
            poiCurrentPage = 1;
            refreshPoiTable();
        }, 250);
    });

    document.getElementById('poiPageSize').addEventListener('change', function () {
        poiCurrentPageSize = parseInt(this.value);
        poiCurrentPage = 1;
        refreshPoiTable();
    });

    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.poi-page-btn');
        if (btn) {
            var pg = parseInt(btn.dataset.page);
            if (!isNaN(pg) && pg >= 1) { poiCurrentPage = pg; refreshPoiTable(); }
        }
    });

    function refreshPoiTable() {
        var url = '/Admin/KortStederSearch?q=' + encodeURIComponent(poiCurrentQ)
            + '&page=' + poiCurrentPage + '&pageSize=' + poiCurrentPageSize;
        var tbody = document.getElementById('poiTableBody');
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-3"><span class="spinner-border spinner-border-sm" style="color:var(--clr-brand);"></span></td></tr>';
        fetch(url).then(function (r) { return r.text(); }).then(function (html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var nb = doc.getElementById('poiTableBody');
            if (nb) tbody.innerHTML = nb.innerHTML;
            var nc = doc.getElementById('poiCount');
            if (nc) document.getElementById('poiCount').textContent = nc.textContent;
            var nr = doc.getElementById('poiRangeText');
            if (nr) document.getElementById('poiRangeText').textContent = nr.textContent;
            var np = doc.querySelector('.pagination');
            var cp = document.querySelector('.pagination');
            if (np && cp) cp.innerHTML = np.innerHTML;
        });
    }

    var _allPois = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.AllLocations.Select(p => new {
            id   = p.Id,
            lat  = p.Latitude,
            lng  = p.Longitude,
            name = p.Name,
            cat  = p.Category
        })
    ));
    var _existingMarkers = [];

    function addExistingMarkers(map, excludeId) {
        _existingMarkers.forEach(function (m) { map.removeLayer(m); });
        _existingMarkers = [];
        var existingIcon = L.icon({
            iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
            iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
            shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
            iconSize: [20, 33], iconAnchor: [10, 33], popupAnchor: [1, -28]
        });
        _allPois.forEach(function (p) {
            if (excludeId !== undefined && p.id === excludeId) return;
            var m = L.marker([p.lat, p.lng], { icon: existingIcon, opacity: 0.6 })
                .bindTooltip(p.name, { permanent: false })
                .addTo(map);
            _existingMarkers.push(m);
        });
    }

    function fitToExisting(map) {
        if (_allPois.length === 0) { map.setView([56.0, 10.0], 7); return; }
        if (_allPois.length === 1) { map.setView([_allPois[0].lat, _allPois[0].lng], 16); return; }
        var bounds = L.latLngBounds(_allPois.map(function (p) { return [p.lat, p.lng]; }));
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 18 });
    }

    // ── Opret modal – kort ──
    document.getElementById('opretPoiModal').addEventListener('shown.bs.modal', function () {
        loadLeaflet(function () {
            if (!_opretMap) {
                _opretMap = L.map('opretPoiMap').setView([56.0, 10.0], 7);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap', maxZoom: 19 }).addTo(_opretMap);
                _opretMap.on('click', function (e) {
                    document.getElementById('opretLat').value = e.latlng.lat.toFixed(6);
                    document.getElementById('opretLng').value = e.latlng.lng.toFixed(6);
                    if (_opretMarker) { _opretMarker.setLatLng(e.latlng); } else { _opretMarker = L.marker(e.latlng).addTo(_opretMap); }
                });
            }
            _opretMap.invalidateSize();
            addExistingMarkers(_opretMap, undefined);
            if (!_opretMarker) { fitToExisting(_opretMap); }
        });
    });

    document.getElementById('opretPoiModal').addEventListener('hidden.bs.modal', function () {
        if (_opretMarker) { _opretMap.removeLayer(_opretMarker); _opretMarker = null; }
        document.getElementById('opretLat').value = '';
        document.getElementById('opretLng').value = '';
    });

    // ── Rediger modal ──
    var _redigerLat = null, _redigerLng = null;

    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.poi-rediger-btn');
        if (!btn) return;
        document.getElementById('redigerPoiId').value          = btn.dataset.id;
        document.getElementById('redigerPoiName').value        = btn.dataset.name;
        document.getElementById('redigerPoiDescription').value = btn.dataset.description;
        document.getElementById('redigerPoiLat').value         = btn.dataset.lat;
        document.getElementById('redigerPoiLng').value         = btn.dataset.lng;
        _redigerLat = parseFloat(btn.dataset.lat);
        _redigerLng = parseFloat(btn.dataset.lng);
        var sel = document.getElementById('redigerPoiCategory');
        for (var i = 0; i < sel.options.length; i++) { sel.options[i].selected = sel.options[i].value === btn.dataset.category; }
        new bootstrap.Modal(document.getElementById('redigerPoiModal')).show();
    });

    document.getElementById('redigerPoiModal').addEventListener('shown.bs.modal', function () {
        loadLeaflet(function () {
            var lat = _redigerLat;
            var lng = _redigerLng;
            var hasCoords = lat !== null && !isNaN(lat) && lng !== null && !isNaN(lng);
            if (!_redigerMap) {
                _redigerMap = L.map('redigerPoiMap').setView([56.0, 10.0], 7);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap', maxZoom: 19 }).addTo(_redigerMap);
                _redigerMap.on('click', function (e) {
                    _redigerLat = e.latlng.lat;
                    _redigerLng = e.latlng.lng;
                    document.getElementById('redigerPoiLat').value = _redigerLat.toFixed(6);
                    document.getElementById('redigerPoiLng').value = _redigerLng.toFixed(6);
                    if (_redigerMarker) { _redigerMarker.setLatLng(e.latlng); } else { _redigerMarker = L.marker(e.latlng).addTo(_redigerMap); }
                });
            }
            _redigerMap.invalidateSize();
            // Placer den redigerede markør (fuld opacitet) inden vi kalder addExistingMarkers
            if (hasCoords) {
                if (_redigerMarker) { _redigerMarker.setLatLng([lat, lng]); }
                else { _redigerMarker = L.marker([lat, lng]).addTo(_redigerMap); }
            }
            var excludeId = parseInt(document.getElementById('redigerPoiId').value);
            addExistingMarkers(_redigerMap, excludeId);
            // Zoom til alle eksisterende steder (samme adfærd som Opret)
            fitToExisting(_redigerMap);
        });
    });

    // ── Slet modal ──
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.poi-slet-btn');
        if (!btn) return;
        document.getElementById('sletPoiId').value = btn.dataset.id;
        document.getElementById('sletPoiNavn').textContent = btn.dataset.name;
        new bootstrap.Modal(document.getElementById('sletPoiModal')).show();
    });
})();
</script>
