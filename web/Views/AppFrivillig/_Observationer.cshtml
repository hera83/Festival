<style>
    #obs-cam-preview {
        width: 100%;
        max-height: 52vw;
        min-height: 180px;
        border-radius: 12px;
        background: #000;
        object-fit: cover;
        display: block;
    }
    #obs-captured-img {
        width: 100%;
        border-radius: 12px;
        object-fit: cover;
        display: none;
    }
    #obs-captured-video {
        width: 100%;
        border-radius: 12px;
        display: none;
    }
    .obs-choice-card {
        background: var(--clr-surface);
        border: 1px solid rgba(232,93,46,0.25);
        border-radius: 14px;
        padding: 28px 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        -webkit-tap-highlight-color: transparent;
    }
    .obs-choice-card:active { background: rgba(232,93,46,0.08); }
    .obs-choice-card i { font-size: 2.4rem; color: var(--clr-brand); display: block; margin-bottom: 10px; }
    .obs-choice-card span { font-size: 1rem; font-weight: 600; color: var(--clr-text); }
</style>

<div class="fv-page-header">
    <i class="bi bi-binoculars fv-page-icon"></i>
    <h2 class="fv-page-title">Observationer</h2>
</div>

<!-- Ikke logget ind -->
<div id="obs-not-logged-in" style="display:none;">
    <div class="text-center py-5" style="color:var(--clr-text-muted);">
        <i class="bi bi-person-lock" style="font-size:2.8rem;color:var(--clr-brand);opacity:0.7;"></i>
        <p class="mt-3 mb-1 fw-semibold" style="color:var(--clr-text);font-size:1rem;">Afventer login</p>
        <p class="mb-0" style="font-size:0.85rem;">Log ind via <strong>Profil</strong>-fanen for at sende observationer.</p>
    </div>
</div>

<!-- Valg: Foto eller Video -->
<div id="obs-choice" style="display:none;">
    <p style="font-size:0.85rem;color:var(--clr-text-muted);margin-bottom:1rem;">
        Vælg om du vil sende et <strong>foto</strong> eller en <strong>video</strong> til koordinatorteamet.
    </p>
    <div class="row g-3">
        <div class="col-6">
            <div class="obs-choice-card" onclick="obsStartCapture('foto')">
                <i class="bi bi-camera"></i>
                <span>Foto</span>
            </div>
        </div>
        <div class="col-6">
            <div class="obs-choice-card" onclick="obsStartCapture('video')">
                <i class="bi bi-camera-video"></i>
                <span>Video</span>
            </div>
        </div>
    </div>
</div>

<!-- Kamera-preview -->
<div id="obs-capture-screen" style="display:none;">
    <div style="position:relative;">
        <video id="obs-cam-preview" autoplay playsinline muted></video>
        <!-- Vend kamera -->
        <button onclick="obsFlipCamera()" title="Vend kamera"
                style="position:absolute;top:10px;right:10px;
                       background:rgba(0,0,0,0.5);border:none;border-radius:50%;
                       width:40px;height:40px;display:flex;align-items:center;justify-content:center;
                       color:#fff;font-size:1.2rem;cursor:pointer;">
            <i class="bi bi-arrow-repeat"></i>
        </button>
        <!-- Optag-indikator -->
        <div id="obs-rec-indicator" style="display:none;position:absolute;top:10px;left:10px;
             background:rgba(220,53,69,0.85);border-radius:20px;padding:3px 10px;
             font-size:0.75rem;font-weight:700;color:#fff;letter-spacing:0.04em;">
            <i class="bi bi-record-circle me-1"></i>REC
        </div>
    </div>

    <div class="d-flex align-items-center gap-2 mt-3">
        <button onclick="obsBack()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--clr-border);
                       color:var(--clr-text-muted);border-radius:20px;padding:7px 14px;
                       font-size:0.82rem;cursor:pointer;">
            <i class="bi bi-arrow-left"></i>
        </button>
        <button id="obs-capture-btn" onclick="obsCapture()"
                style="flex:1;background:var(--clr-brand);border:none;border-radius:20px;
                       color:#fff;font-size:0.88rem;font-weight:600;padding:10px;cursor:pointer;">
            <i class="bi bi-camera me-1" id="obs-capture-icon"></i>
            <span id="obs-capture-label">Tag billede</span>
        </button>
    </div>
</div>

<!-- Preview + besked + registrer -->
<div id="obs-review-screen" style="display:none;">
    <img id="obs-captured-img" alt="Observation foto" />
    <video id="obs-captured-video" controls></video>
    <canvas id="obs-canvas" style="display:none;"></canvas>

    <div style="margin-top:12px;">
        <label style="font-size:0.8rem;color:var(--clr-text-muted);font-weight:600;margin-bottom:5px;display:block;">
            Besked til koordinator
        </label>
        <textarea id="obs-message" rows="3" placeholder="Beskriv kort hvad du observerer…"
                  style="width:100%;background:var(--clr-bg);border:1px solid var(--clr-border);
                         color:var(--clr-text);border-radius:8px;padding:10px;
                         font-size:0.88rem;resize:vertical;"></textarea>
    </div>

    <div class="d-flex gap-2 mt-2">
        <button onclick="obsRetake()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--clr-border);
                       color:var(--clr-text-muted);border-radius:20px;padding:8px 14px;
                       font-size:0.82rem;cursor:pointer;">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Tag om
        </button>
        <button onclick="obsRegister()"
                style="flex:1;background:var(--clr-brand);border:none;border-radius:20px;
                       color:#fff;font-size:0.88rem;font-weight:600;padding:10px;cursor:pointer;">
            <i class="bi bi-send me-1"></i>Registrer
        </button>
    </div>
</div>

<script>
(function () {
    const stored = localStorage.getItem('fv_volunteer');
    const isLoggedIn = !!stored;
    document.getElementById('obs-not-logged-in').style.display  = isLoggedIn ? 'none' : '';
    document.getElementById('obs-choice').style.display         = isLoggedIn ? '' : 'none';
    if (!isLoggedIn) return;

    const volunteer = JSON.parse(stored);

    let stream        = null;
    let facingMode    = 'environment';
    let currentType   = 'foto'; // 'foto' | 'video'
    let mediaRecorder = null;
    let recordedChunks = [];
    let capturedBlob   = null;
    let capturedExt    = 'jpg';
    let isRecording    = false;

    window.obsStartCapture = async function (type) {
        currentType = type;
        document.getElementById('obs-choice').style.display = 'none';
        document.getElementById('obs-review-screen').style.display = 'none';

        const capLabel = document.getElementById('obs-capture-label');
        const capIcon  = document.getElementById('obs-capture-icon');
        if (type === 'video') {
            capLabel.textContent = 'Start optagelse';
            capIcon.className = 'bi bi-record-circle me-1';
        } else {
            capLabel.textContent = 'Tag billede';
            capIcon.className = 'bi bi-camera me-1';
        }

        await obsStartStream();
        document.getElementById('obs-capture-screen').style.display = '';
    };

    async function obsStartStream() {
        if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        try {
            stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode }, audio: currentType === 'video' });
            document.getElementById('obs-cam-preview').srcObject = stream;
        } catch {
            if (typeof fvToast === 'function') fvToast('Kameratilgang nægtet.', 'error');
        }
    }

    window.obsFlipCamera = async function () {
        facingMode = facingMode === 'environment' ? 'user' : 'environment';
        await obsStartStream();
    };

    window.obsCapture = function () {
        if (currentType === 'foto') {
            obsSnapPhoto();
        } else {
            if (!isRecording) obsStartRecording();
            else obsStopRecording();
        }
    };

    function obsSnapPhoto() {
        const video  = document.getElementById('obs-cam-preview');
        const canvas = document.getElementById('obs-canvas');
        canvas.width  = video.videoWidth;
        canvas.height = video.videoHeight;
        canvas.getContext('2d').drawImage(video, 0, 0);
        canvas.toBlob(blob => {
            capturedBlob = blob;
            capturedExt  = 'jpg';
            obsShowReview();
        }, 'image/jpeg', 0.92);
    }

    function obsStartRecording() {
        recordedChunks = [];
        const mimeType = MediaRecorder.isTypeSupported('video/mp4') ? 'video/mp4' : 'video/webm';
        capturedExt    = mimeType === 'video/mp4' ? 'mp4' : 'webm';
        mediaRecorder  = new MediaRecorder(stream, { mimeType });
        mediaRecorder.ondataavailable = e => { if (e.data.size > 0) recordedChunks.push(e.data); };
        mediaRecorder.onstop = () => {
            capturedBlob = new Blob(recordedChunks, { type: mimeType });
            obsShowReview();
        };
        mediaRecorder.start();
        isRecording = true;
        document.getElementById('obs-rec-indicator').style.display = '';
        const capLabel = document.getElementById('obs-capture-label');
        const capIcon  = document.getElementById('obs-capture-icon');
        capLabel.textContent = 'Stop optagelse';
        capIcon.className = 'bi bi-stop-circle me-1';
    }

    function obsStopRecording() {
        if (mediaRecorder && isRecording) {
            mediaRecorder.stop();
            isRecording = false;
        }
        document.getElementById('obs-rec-indicator').style.display = 'none';
    }

    function obsShowReview() {
        if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        document.getElementById('obs-capture-screen').style.display = 'none';
        document.getElementById('obs-message').value = '';

        const url = URL.createObjectURL(capturedBlob);
        if (currentType === 'foto') {
            const img = document.getElementById('obs-captured-img');
            img.src = url;
            img.style.display = 'block';
            document.getElementById('obs-captured-video').style.display = 'none';
        } else {
            const vid = document.getElementById('obs-captured-video');
            vid.src = url;
            vid.style.display = 'block';
            document.getElementById('obs-captured-img').style.display = 'none';
        }
        document.getElementById('obs-review-screen').style.display = '';
    }

    window.obsRetake = async function () {
        capturedBlob = null;
        document.getElementById('obs-review-screen').style.display = 'none';
        await obsStartCapture(currentType);
    };

    window.obsBack = function () {
        if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        if (isRecording && mediaRecorder) { mediaRecorder.stop(); isRecording = false; }
        document.getElementById('obs-capture-screen').style.display = 'none';
        document.getElementById('obs-rec-indicator').style.display = 'none';
        document.getElementById('obs-choice').style.display = '';
    };

    window.obsRegister = async function () {
        const message = document.getElementById('obs-message').value.trim();
        if (!message) {
            if (typeof fvToast === 'function') fvToast('Skriv en besked om observationen.', 'warning');
            return;
        }
        if (!capturedBlob) {
            if (typeof fvToast === 'function') fvToast('Ingen fil fanget.', 'warning');
            return;
        }

        // Hent GPS-koordinat inden afsendelse (timeout 6 sek, fejler stille)
        let gpsCoords = null;
        if (navigator.geolocation) {
            try {
                gpsCoords = await new Promise((resolve) => {
                    navigator.geolocation.getCurrentPosition(
                        pos => resolve(pos.coords),
                        ()  => resolve(null),
                        { enableHighAccuracy: true, timeout: 6000, maximumAge: 30000 }
                    );
                });
            } catch { /* ignorer */ }
        }

        const fd = new FormData();
        fd.append('volunteerId', volunteer.id);
        fd.append('seasonId',    volunteer.seasonId);
        fd.append('message',     message);
        fd.append('type',        currentType);
        if (gpsCoords) {
            fd.append('latitude',  gpsCoords.latitude);
            fd.append('longitude', gpsCoords.longitude);
        }
        const fileName = currentType === 'foto' ? `obs_${Date.now()}.jpg` : `obs_${Date.now()}.${capturedExt}`;
        fd.append('file', capturedBlob, fileName);

        try {
            const res = await fetch('/AppFrivillig/SendObservation', { method: 'POST', body: fd });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                if (typeof fvToast === 'function') fvToast(err.error || 'Fejl ved afsendelse.', 'error');
                return;
            }
            if (typeof fvToast === 'function') fvToast('Observation sendt til koordinator.', 'success');
            capturedBlob = null;
            document.getElementById('obs-review-screen').style.display = 'none';
            document.getElementById('obs-choice').style.display = '';
        } catch {
            if (typeof fvToast === 'function') fvToast('Netværksfejl – prøv igen.', 'error');
        }
    };
})();
</script>
