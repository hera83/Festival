@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="da" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Frivillig — Festival Vagtstyring</title>
    <script>
        (function () {
            var t = localStorage.getItem('fv_theme') || 'system';
            if (t === 'system') t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest-frivillig.json" />
    <meta name="theme-color" content="#e85d2e" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Frivillig" />
    <link rel="apple-touch-icon" href="/icons/icon-192-frivillig.svg" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
            background: var(--clr-bg);
            color: var(--clr-text);
            overflow: hidden;
        }

        /* ── App shell ── */
        .fv-shell {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        /* ── Top bar ── */
        .app-topbar {
            background: rgba(13, 17, 23, 0.92);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid rgba(255,255,255,0.07);
            transition: background 0.2s;
            padding: 0.7rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.55rem;
            flex-shrink: 0;
            z-index: 10;
        }
        .app-topbar .app-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--clr-text);
            flex: 1;
        }
        .app-topbar .brand-dot { color: var(--clr-brand); }

        /* ── Scrollable content area ── */
        .fv-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.25rem 1rem 1rem;
        }

        /* ── Tab panes ── */
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }

        /* ── Bottom navigation ── */
        .bottom-nav {
            --nav-height: 90px;
            --active-icon: 46px;
            --inactive-icon: 40px;
            flex-shrink: 0;
            position: relative;
            z-index: 50;
            height: calc(var(--nav-height) + env(safe-area-inset-bottom, 0px));
        }

        .nav-surface {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: calc(78px + env(safe-area-inset-bottom, 0px));
            background: rgba(22, 27, 34, 0.94);
            border-top: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 -14px 30px rgba(0,0,0,0.35);
            backdrop-filter: blur(14px);
            transition: background 0.2s;
        }

        /* ── Light mode overrides ── */
        [data-theme="light"] .app-topbar {
            background: rgba(255,255,255,0.92);
            border-bottom-color: rgba(0,0,0,0.10);
        }
        [data-theme="light"] .nav-surface {
            background: rgba(255,255,255,0.94);
            border-top-color: rgba(0,0,0,0.10);
            box-shadow: 0 -14px 30px rgba(0,0,0,0.08);
        }
        [data-theme="light"] .nav-item .nav-icon-wrap {
            background: rgba(0,0,0,0.05);
            border-color: rgba(0,0,0,0.07);
            color: var(--clr-text-muted);
        }
        [data-theme="light"] .nav-item:not(.active):active .nav-icon-wrap {
            background: rgba(0,0,0,0.10);
        }

        .nav-items {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: calc(78px + env(safe-area-inset-bottom, 0px));
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            align-items: center;
            padding: 0 10px;
            padding-bottom: env(safe-area-inset-bottom, 0px);
            z-index: 2;
        }

        .nav-item {
            flex: 1;
            display: grid;
            justify-items: center;
            align-content: center;
            padding-top: 0;
            min-width: 0;
            background: none;
            border: none;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
            outline: none;
            position: relative;
        }

        .nav-item .nav-icon-wrap {
            width: var(--inactive-icon);
            height: var(--inactive-icon);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--clr-text-muted);
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.06);
            transition:
                transform 0.36s cubic-bezier(.34,1.56,.64,1),
                background 0.25s ease,
                color 0.25s ease,
                box-shadow 0.3s ease,
                width 0.24s ease,
                height 0.24s ease;
            transform: translateY(0);
            position: relative;
            z-index: 6;
        }

        .nav-item .nav-label {
            font-size: 0.66rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            color: var(--clr-brand);
            white-space: nowrap;
            max-height: 0;
            opacity: 0;
            margin-top: 0;
            transition:
                max-height 0.25s ease,
                opacity 0.25s ease,
                margin-top 0.25s ease;
            z-index: 6;
            position: relative;
        }

        .nav-item.active {
            padding-top: 0;
            padding-bottom: 0;
            transform: translateY(-10px);
        }
        .nav-item.active .nav-icon-wrap {
            width: var(--active-icon);
            height: var(--active-icon);
            background: linear-gradient(145deg, var(--clr-brand), #ff7a4d);
            color: #ffffff;
            transform: translateY(0);
        }
        .nav-item.active .nav-label {
            max-height: 1.4em;
            opacity: 1;
            margin-top: 7px;
        }

        .nav-item:not(.active):active .nav-icon-wrap {
            transform: scale(0.9);
            background: rgba(255,255,255,0.07);
            color: var(--clr-text);
        }

        /* ── Unread badge on nav icon ── */
        .nav-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            min-width: 17px;
            height: 17px;
            border-radius: 9px;
            background: #e63946;
            color: #fff;
            font-size: 0.62rem;
            font-weight: 700;
            line-height: 17px;
            text-align: center;
            padding: 0 4px;
            border: 2px solid var(--clr-bg);
            pointer-events: none;
            z-index: 10;
            display: none;
        }

        /* ── Page header (bruges i alle partial views) ── */
        .fv-page-header {
            background: linear-gradient(135deg, rgba(232,93,46,0.12) 0%, rgba(232,93,46,0.03) 100%);
            border: 1px solid rgba(232,93,46,0.18);
            border-radius: 10px;
            padding: 0.55rem 0.9rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.65rem;
        }
        .fv-page-icon {
            font-size: 1.25rem;
            color: var(--clr-brand);
            flex-shrink: 0;
        }
        .fv-page-title {
            font-size: 0.95rem;
            font-weight: 700;
            margin: 0;
            color: var(--clr-text);
        }
    </style>
    <style>
        .nav-badge { animation: badge-pop 0.25s cubic-bezier(.34,1.56,.64,1); }
    </style>
</head>
<body>
    <div class="fv-shell">

        <!-- Toast container -->
        <div id="fv-toast-container" style="
            position: fixed;
            top: calc(env(safe-area-inset-top, 0px) + 12px);
            right: 12px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
        "></div>

        <!-- Top bar -->
        <div class="app-topbar">
            <i class="bi bi-person-badge fs-5" style="color:var(--clr-brand);"></i>
            <span class="app-title">Frivillig</span>
        </div>

        <!-- Page content -->
        <div class="fv-content">
            <div id="page-content">
                <!-- Indhold indlæses via fetch -->
            </div>
        </div>

        <!-- Bottom navigation -->
        <nav class="bottom-nav" id="bottom-nav">
            <div class="nav-surface" aria-hidden="true"></div>
            <!-- Ikoner -->
            <div class="nav-items" id="nav-items">
                <button class="nav-item active" data-tab="overblik" data-url="@Url.Action("Overblik", "AppFrivillig")" aria-label="Overblik">
                    <div class="nav-icon-wrap"><i class="bi bi-grid-1x2-fill"></i></div>
                    <span class="nav-label">Overblik</span>
                </button>
                <button class="nav-item" data-tab="vagter" data-url="@Url.Action("Vagter", "AppFrivillig")" aria-label="Vagter">
                    <div class="nav-icon-wrap"><i class="bi bi-calendar-week"></i></div>
                    <span class="nav-label">Vagter</span>
                </button>
                <button class="nav-item" data-tab="observationer" data-url="@Url.Action("Observationer", "AppFrivillig")" aria-label="Observationer">
                    <div class="nav-icon-wrap"><i class="bi bi-binoculars"></i></div>
                    <span class="nav-label">Observationer</span>
                </button>
                <button class="nav-item" data-tab="beskeder" data-url="@Url.Action("Beskeder", "AppFrivillig")" aria-label="Beskeder" id="nav-btn-beskeder">
                    <div class="nav-icon-wrap" style="position:relative;">
                        <i class="bi bi-chat-dots"></i>
                        <span class="nav-badge" id="nav-badge-beskeder"></span>
                    </div>
                    <span class="nav-label">Beskeder</span>
                </button>
                <button class="nav-item" data-tab="profil" data-url="@Url.Action("Profil", "AppFrivillig")" aria-label="Profil">
                    <div class="nav-icon-wrap"><i class="bi bi-person"></i></div>
                    <span class="nav-label">Profil</span>
                </button>
            </div>
        </nav>

    </div>

    <script>
        const contentEl = document.getElementById('page-content');

        function fvToast(message, type) {
            const colors = {
                success: { bg: 'rgba(40,167,69,0.92)', icon: 'bi-check-circle-fill' },
                error:   { bg: 'rgba(220,53,69,0.92)',  icon: 'bi-exclamation-circle-fill' },
                warning: { bg: 'rgba(232,93,46,0.92)',  icon: 'bi-exclamation-triangle-fill' },
                info:    { bg: 'rgba(13,110,253,0.92)', icon: 'bi-info-circle-fill' },
            };
            const c = colors[type] || colors.info;
            const el = document.createElement('div');
            el.style.cssText = `
                background: ${c.bg};
                color: #fff;
                padding: 9px 14px;
                border-radius: 8px;
                font-size: 0.83rem;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 8px;
                backdrop-filter: blur(8px);
                box-shadow: 0 4px 16px rgba(0,0,0,0.35);
                max-width: 260px;
                opacity: 0;
                transform: translateX(20px);
                transition: opacity 0.25s ease, transform 0.25s ease;
                pointer-events: none;
            `;
            el.innerHTML = `<i class="bi ${c.icon}" style="flex-shrink:0;"></i><span>${message}</span>`;
            document.getElementById('fv-toast-container').appendChild(el);
            requestAnimationFrame(() => {
                el.style.opacity = '1';
                el.style.transform = 'translateX(0)';
            });
            setTimeout(() => {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                setTimeout(() => el.remove(), 280);
            }, 3000);
        }

        // Kaldes med en fetch Response. Returnerer true hvis brugeren er fjernet (HTTP 404
        // bekræftet af serveren). Rydder localStorage og navigerer til Profil-fanen.
        // Returnerer false ved netværksfejl eller andre statuskoder – appen fortsætter uændret.
        function fvCheckAuth(res) {
            if (res.status !== 404) return false;
            localStorage.removeItem('fv_volunteer');
            localStorage.removeItem('fv_theme');
            fvToast('Din profil findes ikke længere i systemet. Du er blevet logget ud.', 'warning');
            // Naviger til Profil-fanen så brugeren kan logge ind igen
            const profileBtn = document.querySelector('.nav-item[data-tab="profil"]');
            if (profileBtn && !profileBtn.classList.contains('active')) {
                document.querySelectorAll('.nav-item.active').forEach(b => b.classList.remove('active'));
                profileBtn.classList.add('active');
                loadTab(profileBtn.dataset.url);
            }
            return true;
        }

        async function loadTab(url) {
            contentEl.innerHTML = '<div class="d-flex justify-content-center pt-5"><div class="spinner-border spinner-border-sm" style="color:var(--clr-brand);"></div></div>';
            try {
                const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                contentEl.innerHTML = await res.text();
                // Scripts injected via innerHTML are not executed by the browser — re-run them manually
                contentEl.querySelectorAll('script').forEach(orig => {
                    const s = document.createElement('script');
                    if (orig.src) {
                        s.src = orig.src;
                    } else {
                        s.textContent = orig.textContent;
                    }
                    orig.replaceWith(s);
                });
            } catch {
                contentEl.innerHTML = '<p class="text-muted text-center pt-4">Kunne ikke indlæse siden.</p>';
            }
        }

        document.querySelectorAll('.nav-item[data-tab]').forEach(btn => {
            btn.addEventListener('click', () => {
                if (btn.classList.contains('active')) {
                    // Genindlæs den aktive fane
                    loadTab(btn.dataset.url);
                    return;
                }

                const previous = document.querySelector('.nav-item.active');
                if (previous) previous.classList.remove('active');
                btn.classList.add('active');

                // Start fetch parallelt
                loadTab(btn.dataset.url);
            });
        });

        // Init
        const activeBtn = document.querySelector('.nav-item.active[data-url]');
        if (activeBtn) {
            loadTab(activeBtn.dataset.url);
        }

        // PWA service worker
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw-frivillig.js').catch(() => {});
        }

        // ── Unread badge polling ──────────────────────────────────────
        const navBadge = document.getElementById('nav-badge-beskeder');
        let _prevUnreadCount = null; // null = første kald (ingen lyd)

        function playDing() {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(880, ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(660, ctx.currentTime + 0.15);
                gain.gain.setValueAtTime(0.35, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.45);
                osc.start(ctx.currentTime);
                osc.stop(ctx.currentTime + 0.45);
                osc.onended = () => ctx.close();
            } catch { /* Web Audio ikke tilgængeligt */ }
        }

        async function refreshUnreadBadge() {
            const stored = localStorage.getItem('fv_volunteer');
            if (!stored) { navBadge.style.display = 'none'; return; }
            let vol;
            try { vol = JSON.parse(stored); } catch { return; }
            if (!vol?.id || !vol?.seasonId) { navBadge.style.display = 'none'; return; }

            try {
                const res = await fetch(`/AppFrivillig/BeskederData?volunteerId=${vol.id}&seasonId=${vol.seasonId}`);
                if (!res.ok) return;
                const msgs = await res.json();
                const count = msgs.filter(m => m.hasUnread).length;

                // Spil lyd kun hvis count stiger EFTER første kald
                if (_prevUnreadCount !== null && count > _prevUnreadCount) {
                    playDing();
                }
                _prevUnreadCount = count;

                if (count > 0) {
                    navBadge.textContent = count > 9 ? '9+' : count;
                    navBadge.style.display = 'block';
                } else {
                    navBadge.style.display = 'none';
                }
            } catch { /* netværksfejl – ignorer */ }
        }

        // Kør straks og derefter hvert 30. sekund
        refreshUnreadBadge();
        setInterval(refreshUnreadBadge, 30000);

        // Opdater badge når brugeren vender tilbage til siden
        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible') refreshUnreadBadge();
        });

        // Eksponér så _Beskeder.cshtml kan nulstille badge ved åbning
        window.refreshUnreadBadge = refreshUnreadBadge;

        // ── GPS auto-tracking (hvert 3. sekund, kun ved check-in) ────────
        (function () {
            if (!navigator.geolocation) return;

            window.fvIsCheckedIn = window.fvIsCheckedIn || false;

            function getVol() {
                const s = localStorage.getItem('fv_volunteer');
                if (!s) return null;
                try { return JSON.parse(s); } catch { return null; }
            }

            function sendGpsLocation() {
                if (!window.fvIsCheckedIn) return;
                const vol = getVol();
                if (!vol?.id || !vol?.seasonId) return;

                navigator.geolocation.getCurrentPosition(pos => {
                    if (!window.fvIsCheckedIn) return; // dobbelttjek efter asynkront kald
                    fetch('/AppFrivillig/LogGpsLocation', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            volunteerId: vol.id,
                            seasonId: vol.seasonId,
                            latitude: pos.coords.latitude,
                            longitude: pos.coords.longitude,
                            accuracy: pos.coords.accuracy ?? null,
                            trigger: 'AutoInterval'
                        })
                    }).catch(() => { /* ignorer netværksfejl */ });
                }, () => { /* ignorer GPS-fejl */ }, {
                    enableHighAccuracy: true,
                    timeout: 5000,
                    maximumAge: 0
                });
            }

            // Poll check-in status hvert 30. sekund for at holde fvIsCheckedIn opdateret
            async function pollCheckInStatus() {
                const vol = getVol();
                if (!vol?.id || !vol?.seasonId) { window.fvIsCheckedIn = false; return; }
                try {
                    const res = await fetch(`/AppFrivillig/CheckInStatus?volunteerId=${vol.id}&seasonId=${vol.seasonId}`);
                    if (res.ok) {
                        const data = await res.json();
                        window.fvIsCheckedIn = !!data.isCheckedIn;
                    }
                } catch { /* ignorer netværksfejl */ }
            }

            // Start GPS-interval
            setInterval(sendGpsLocation, 3000);

            // Poll status hvert 30. sekund (første kald sker allerede fra _Overblik via loadOverblik)
            setInterval(pollCheckInStatus, 30000);
        })();
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
</body>
</html>