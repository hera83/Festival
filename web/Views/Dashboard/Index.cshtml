        const postItems = _lastPosts.map(p =>
            `<li><a class="dropdown-item vol-move-item" href="#" data-vid="${volunteerId}" data-vtarget="${escHtml(p.name)}"><i class="bi bi-signpost-2 me-2" style="color:var(--clr-text-muted);"></i>${escHtml(p.name)}</a></li>`
        ).join('');
        panel2.innerHTML = `
            <div style="display:flex;align-items:center;gap:6px;padding:5px 8px 5px;border-bottom:1px solid var(--clr-border);">
                <button id="vol-back-btn" style="background:none;border:none;padding:2px 4px;color:var(--clr-text-muted);cursor:pointer;font-size:0.9rem;line-height:1;border-radius:4px;" title="Tilbage">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span style="font-size:0.75rem;color:var(--clr-text-muted);">Flyt til post</span>
            </div>
            <ul style="list-style:none;margin:0;padding:4px 0;max-height:220px;overflow-y:auto;">
                ${pitItem}
                ${postItems ? '<li><hr class="dropdown-divider" style="border-color:var(--clr-border);margin:3px 0;"></li>' + postItems : ''}
            </ul>`;

        menu.appendChild(panel1);
        menu.appendChild(panel2);
        document.body.appendChild(menu);

        // Events panel 1
        panel1.querySelector('#vol-goto-post-panel').addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            panel1.style.display = 'none';
            panel2.style.display = 'block';
            // Juster menuposition hvis den er ved at gå ud af skærmen
            const r = menu.getBoundingClientRect();
            if (r.bottom > window.innerHeight - 8) {
                menu.style.top = Math.max(8, window.innerHeight - menu.offsetHeight - 8) + 'px';
            }
        });
        panel1.querySelector('#vol-alarm-toggle').addEventListener('click', (e) => {
            e.preventDefault();
            volMenuToggleAlarm(parseInt(menu.dataset.vid));
        });
        panel1.querySelector('#vol-futuremove-btn').addEventListener('click', (e) => {
            e.preventDefault();
            closeVolunteerMenu();
            openFutureMoveModal(parseInt(menu.dataset.vid), menu.dataset.vname);
