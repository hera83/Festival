                    <i class="bi bi-box-arrow-right me-2" style="color:var(--clr-alarm);"></i>Check ud
                </a></li>
            </ul>`;

        // -- Panel 2: Vælg post --
        const panel2 = document.createElement('div');
        panel2.id = 'vol-menu-panel2';
        panel2.style.display = 'none';
