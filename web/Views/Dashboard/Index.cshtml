    // Opdater poster + pit efter en gemt ændring. Hvis der er en anden drag i gang
    // (fx brugeren allerede greb fat i næste frivillig mens forrige flytning blev gemt),
    // ville en fuld gentegning her rive drop-zonen væk under den aktive drag og få
    // dropped til stille at fejle. Udsæt derfor gentegningen til den aktive drag slipper.
    function refreshBoardAfterChange(pitQuery = '') {
        if (_autoRefreshPaused) {
            _pendingBoardRefresh = true;
            _pendingBoardRefreshPitQuery = pitQuery;
            return;
        }
        loadAllPosts();
        loadPitVolunteers(pitQuery);
    }

    // -- Drag & Drop -----------------------------------------------------------
    function onPostDragStart(e) {
        dragPayload = { type: 'post', id: parseInt(this.dataset.postId), element: this };
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
    }

    function onVolunteerDragStart(e) {
        if (e.target.closest('.vol-menu-btn')) { e.preventDefault(); return; }
        dragPayload = {
            type: 'volunteer',
            id: parseInt(this.dataset.volunteerId),
            name: this.dataset.name,
            fromLocation: this.dataset.location,
            element: this
        };
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.stopPropagation();
    }

    function onDragEnd() {
        this.classList.remove('dragging');
        dragPayload = null;
        // Fjern alle drop-zone highlights og insert-indikatorer
        document.querySelectorAll('.drop-zone-active').forEach(el => el.classList.remove('drop-zone-active'));
        document.querySelectorAll('.post-drop-zone-active').forEach(el => el.classList.remove('post-drop-zone-active'));
        document.querySelectorAll('.post-insert-indicator').forEach(el => el.remove());
    }

    // Drop-zone: pit-listen (frivillige kan droppes her → flyttes til Pit)
    let _pitDropZoneAbort = null;
    function setupPitDropZone() {
        if (_pitDropZoneAbort) _pitDropZoneAbort.abort();
        _pitDropZoneAbort = new AbortController();
        const sig = { signal: _pitDropZoneAbort.signal };
        pitList.addEventListener('dragover', e => {
            if (dragPayload?.type !== 'volunteer') return;
            e.preventDefault();
            pitList.classList.add('drop-zone-active');
        }, sig);
        pitList.addEventListener('dragleave', () => pitList.classList.remove('drop-zone-active'), sig);
        pitList.addEventListener('drop', e => {
            e.preventDefault();
            pitList.classList.remove('drop-zone-active');
            if (!dragPayload || dragPayload.type !== 'volunteer') return;
            if (dragPayload.fromLocation === 'Pit') return;
            moveVolunteer(dragPayload.id, 'Pit');
        }, sig);
    }

    // Hjælper: find insert-position og opdater indikator-linje i kolonne
    function _getInsertTarget(colEl, clientY) {
        // Returnerer { beforeCard } hvor beforeCard er det kort man skal indsætte FØR
        // (null = indsæt sidst)
        const cards = [...colEl.querySelectorAll('.post-card:not(.dragging)')];
        for (const card of cards) {
            const box = card.getBoundingClientRect();
            if (clientY < box.top + box.height / 2) return { beforeCard: card };
        }
        return { beforeCard: null };
    }

    function _showInsertIndicator(colEl, clientY) {
        // Fjern gammel indikator
        colEl.querySelectorAll('.post-insert-indicator').forEach(el => el.remove());
        const { beforeCard } = _getInsertTarget(colEl, clientY);
        const indicator = document.createElement('div');
        indicator.className = 'post-insert-indicator';
        if (beforeCard) {
            colEl.insertBefore(indicator, beforeCard);
        } else {
            colEl.appendChild(indicator);
        }
    }

    // Drop-zone: kolonne (poster kan droppes her – både flytte til anden kolonne og reorder inden i kolonne)
    const _colDropZoneAborts = {};
    function setupColumnDropZone(colEl) {
        const key = colEl.id || colEl.dataset.column;
        if (_colDropZoneAborts[key]) _colDropZoneAborts[key].abort();
        _colDropZoneAborts[key] = new AbortController();
        const sig = { signal: _colDropZoneAborts[key].signal };

        colEl.addEventListener('dragover', e => {
            if (dragPayload?.type !== 'post') return;
            e.preventDefault();
            colEl.classList.add('drop-zone-active');
            _showInsertIndicator(colEl, e.clientY);
        }, sig);

        colEl.addEventListener('dragleave', e => {
            // Kun fjern highlight hvis musen forlader hele kolonnen (ikke blot et child-element)
            if (colEl.contains(e.relatedTarget)) return;
            colEl.classList.remove('drop-zone-active');
            colEl.querySelectorAll('.post-insert-indicator').forEach(el => el.remove());
        }, sig);

        colEl.addEventListener('drop', e => {
            e.preventDefault();
            colEl.classList.remove('drop-zone-active');
            colEl.querySelectorAll('.post-insert-indicator').forEach(el => el.remove());
            if (!dragPayload || dragPayload.type !== 'post') return;

            const newCol = parseInt(colEl.dataset.column);
            const draggedCard = dragPayload.element;
            const { beforeCard } = _getInsertTarget(colEl, e.clientY);

            if (draggedCard.dataset.column != newCol) {
                // Flytte til anden kolonne – beregn sortOrder ud fra insert-position
                movePostToColumn(dragPayload.id, newCol, beforeCard);
            } else {
                // Reorder inden for samme kolonne
                reorderPostInColumn(dragPayload.id, colEl, beforeCard);
            }
        }, sig);
    }

    // Drop-zone: frivillig-zone på en post
    function setupVolunteerDropZoneOnPost(zone, postName) {
        zone.addEventListener('dragover', e => {
            if (dragPayload?.type !== 'volunteer') return;
            e.preventDefault();
            e.stopPropagation();
            zone.classList.add('post-drop-zone-active');
        });
        zone.addEventListener('dragleave', () => zone.classList.remove('post-drop-zone-active'));
        zone.addEventListener('drop', e => {
            e.preventDefault();
            e.stopPropagation();
            zone.classList.remove('post-drop-zone-active');
            if (!dragPayload || dragPayload.type !== 'volunteer') return;
            if (dragPayload.fromLocation === postName) return;
            moveVolunteer(dragPayload.id, postName);
        });
    }

    function movePostToColumn(postId, newColumnIndex, beforeCard) {
        const colEl = document.getElementById(`col${newColumnIndex}Posts`);

        // Byg ny rækkefølge for målkolonnen: eksisterende kort + det draggede indsat på insert-position
        const existingCards = [...colEl.querySelectorAll('.post-card')]; // der er ingen .dragging her da kortet er i en anden kolonne
        const insertIdx = beforeCard ? existingCards.indexOf(beforeCard) : existingCards.length;

        // Vi kender ikke det draggede korts DOM-element i målkolonnen endnu –
        // brug et midlertidigt id-array til at beregne rækkefølgen
        const existingIds = existingCards.map(c => parseInt(c.dataset.postId));
        existingIds.splice(insertIdx, 0, postId);

        // Kald UpdateColumn for selve kolonneskiftet og Reorder for den endelige rækkefølge
        postJson('/Post/UpdateColumn', { postId, columnIndex: newColumnIndex })
            .then(res => {
                if (!res.success) { showToast(res.message, 'warning'); refreshBoardAfterChange(); return; }
                // Renummerer hele målkolonnen inkl. det nye kort
                const items = existingIds.map((id, i) => ({ postId: id, sortOrder: i }));
                return postJson('/Post/Reorder', { items });
            })
            .then(res => {
                if (res && !res.success) showToast(res.message, 'warning');
                clearPitSearch();
                refreshBoardAfterChange();
            })
            .catch(() => { showToast('Noget gik galt.', 'error'); refreshBoardAfterChange(); });
    }

    function reorderPostInColumn(postId, colEl, beforeCard) {
        // Byg ny rækkefølge: alle kort i kolonnen ekskl. det der trækkes, indsæt det på ny position
        const allCards = [...colEl.querySelectorAll('.post-card')];
        const dragged = allCards.find(c => parseInt(c.dataset.postId) === postId);
        if (!dragged) return;

        // Fjern det draggede kort fra listen og indsæt på ny position
        const remaining = allCards.filter(c => c !== dragged);
        const insertIdx = beforeCard ? remaining.indexOf(beforeCard) : remaining.length;
        remaining.splice(insertIdx, 0, dragged);

        // Tildel nye SortOrder-værdier
        const items = remaining.map((c, i) => ({ postId: parseInt(c.dataset.postId), sortOrder: i }));

        // Optimistisk DOM-opdatering så det føles øjeblikkeligt
        remaining.forEach(c => colEl.appendChild(c));

        postJson('/Post/Reorder', { items })
            .then(res => { if (!res.success) { showToast(res.message, 'warning'); refreshBoardAfterChange(); } else {
                // Opdater _lastPosts sortOrder lokalt
                items.forEach(item => {
                    const p = _lastPosts.find(x => x.id === item.postId);
                    if (p) p.sortOrder = item.sortOrder;
                });
            }})
            .catch(() => { showToast('Noget gik galt.', 'error'); refreshBoardAfterChange(); });
    }

    function movePost(postId, newColumnIndex) {
        postJson('/Post/UpdateColumn', { postId, columnIndex: newColumnIndex })
            .then(res => { if (res.success) { clearPitSearch(); loadAllPosts(); } else showToast(res.message, 'warning'); })
            .catch(() => showToast('Noget gik galt.', 'error'));
    }

    function moveVolunteer(volunteerId, targetLocation) {
        disabledAlarmVolunteers.delete(volunteerId); // nulstil per-frivillig alarm ved flytning
        postJson('/Dashboard/MoveVolunteer', { volunteerId, targetLocation })
            .then(res => {
                if (res.success) {
                    clearPitSearch();
                    updateCheckedInCount();
                    refreshBoardAfterChange();
                } else {
                    showToast(res.message, 'warning');
                }
            })
            .catch(() => showToast('Noget gik galt.', 'error'));
    }

    // -- Hjælpefunktioner ------------------------------------------------------
    function postJson(url, data) {
        return fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
            body: JSON.stringify(data)
        }).then(r => r.json());
    }

    function getAntiForgeryToken() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        if (el) return el.value;
        const meta = document.querySelector('meta[name="RequestVerificationToken"]');
        if (meta) return meta.content;
        return '';
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function parseLocalDate(value) {
        if (!value) return null;
        return new Date(value);
    }

    // -- SMS skabeloner ----------------------------------------------------------
    (function () {
        const smsModal   = document.getElementById('smsModal');
        const smsSpinner = document.getElementById('smsSpinner');
        const tabContent = document.getElementById('smsTemplateTabContent');
        const savedMsg   = document.getElementById('smsTemplateSavedMsg');
        const saveBtn    = document.getElementById('smsTemplateSaveBtn');
        const resetBtn   = document.getElementById('smsTemplateResetBtn');

        const smsDefaults = {
            CheckIn: 'Hej {{Navn}}, du er nu checket ind til {{Post}}. Tak fordi du hjælper til i dag!',
            CheckOut: 'Hej {{Navn}}, du er nu checket ud fra {{Post}}. Tak for din indsats i dag – vi ses igen snart!',
            Moved: 'Hej {{Navn}}, du er blevet flyttet fra {{FraPost}} til {{TilPost}}. Mød op på den nye post hurtigst muligt.'
        };

        let smsTemplatesLoaded = false;

        function smsTextarea(type) {
            return document.querySelector(`#smsPane-${type} .sms-template-textarea`);
        }

        function smsActiveType() {
            const activePane = tabContent.querySelector('.tab-pane.active');
            return activePane ? activePane.dataset.templateType : null;
        }

        function loadSmsTemplates() {
            smsSpinner.classList.remove('d-none');
            tabContent.classList.add('d-none');
            fetch('/Dashboard/GetSmsTemplates')
                .then(r => r.json())
                .then(data => {
                    smsTextarea('CheckIn').value = data.checkIn;
                    smsTextarea('CheckOut').value = data.checkOut;
                    smsTextarea('Moved').value = data.moved;
                    smsTemplatesLoaded = true;
                })
                .catch(() => showToast('Kunne ikke hente sms-skabeloner.', 'error'))
                .finally(() => {
                    smsSpinner.classList.add('d-none');
                    tabContent.classList.remove('d-none');
                });
        }

        smsModal.addEventListener('shown.bs.modal', () => {
            savedMsg.style.display = 'none';
            if (!smsTemplatesLoaded) loadSmsTemplates();
        });

        document.querySelectorAll('.sms-merge-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const textarea = this.closest('.tab-pane').querySelector('.sms-template-textarea');
                const field = this.dataset.field;
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                textarea.value = textarea.value.slice(0, start) + field + textarea.value.slice(end);
                const cursor = start + field.length;
                textarea.focus();
                textarea.setSelectionRange(cursor, cursor);
            });
        });

        resetBtn.addEventListener('click', () => {
            const type = smsActiveType();
            if (!type) return;
            smsTextarea(type).value = smsDefaults[type];
        });

        saveBtn.addEventListener('click', () => {
            const type = smsActiveType();
            if (!type) return;
            const body = smsTextarea(type).value.trim();
            if (!body) {
                showToast('Teksten må ikke være tom.', 'warning');
                return;
            }
            saveBtn.disabled = true;
            postJson('/Dashboard/SaveSmsTemplate', { type, body })
                .then(res => {
                    if (res.success) {
                        savedMsg.style.display = 'inline-block';
                        setTimeout(() => { savedMsg.style.display = 'none'; }, 2500);
                    } else {
                        showToast(res.message || 'Kunne ikke gemme skabelonen.', 'error');
                    }
                })
                .catch(() => showToast('Noget gik galt. Prøv igen.', 'error'))
                .finally(() => { saveBtn.disabled = false; });
        });
    })();

    // -- Alarm toggle ----------------------------------------------------------
    let alarmsEnabled = true;
    let pitAlarmMinutes = null;
    let _pitAlarmCount = 0;
    const collapsedPosts = new Set();
    const disabledAlarmVolunteers = new Set(); // lokal per-frivillig alarm deaktivering
    let _lastPosts = [];

    // Opdater minimer-alle ikonet baseret på om alle poster er minimerede
    function updateCollapseAllBtn(allPosts) {
        const btn = document.getElementById('collapseAllBtn');
        if (!btn) return;
        const allCollapsed = allPosts.length > 0 && allPosts.every(p => collapsedPosts.has(p.id));
        const icon = btn.querySelector('i');
        if (allCollapsed) {
            icon.className = 'bi bi-arrows-expand';
            btn.title = 'Udvid alle poster';
            btn.style.opacity = '0.5';
        } else {
            icon.className = 'bi bi-arrows-collapse';
            btn.title = 'Minimer alle poster';
            btn.style.opacity = '1';
        }
    }
    const toggleAlarmsBtn = document.getElementById('toggleAlarmsBtn');
    if (toggleAlarmsBtn) {
        toggleAlarmsBtn.addEventListener('click', () => {
            alarmsEnabled = !alarmsEnabled;
            const icon = toggleAlarmsBtn.querySelector('i');
            if (alarmsEnabled) {
                icon.className = 'bi bi-alarm';
                toggleAlarmsBtn.title = 'Deaktiver alarmer';
                toggleAlarmsBtn.style.color = 'var(--clr-text-muted)';
                showToast('Alarmer aktiveret', 'success');
            } else {
                icon.className = 'bi bi-alarm-fill';
                toggleAlarmsBtn.title = 'Aktiver alarmer';
                toggleAlarmsBtn.style.color = 'var(--clr-text-dim)';
                toggleAlarmsBtn.style.opacity = '0.5';
                showToast('Alarmer deaktiveret', 'warn');
            }
            if (alarmsEnabled) toggleAlarmsBtn.style.opacity = '1';
            loadAllPosts();
            loadPitVolunteers(pitSearchInput.value);
        });
    }

    // -- Collapse alle poster --------------------------------------------------
    const collapseAllBtn = document.getElementById('collapseAllBtn');
    if (collapseAllBtn) {
        collapseAllBtn.addEventListener('click', () => {
            const allCollapsed = _lastPosts.length > 0 && _lastPosts.every(p => collapsedPosts.has(p.id));
            if (allCollapsed) {
                // Udvid alle
                _lastPosts.forEach(p => collapsedPosts.delete(p.id));
            } else {
                // Minimer alle
                _lastPosts.forEach(p => collapsedPosts.add(p.id));
            }
            // Re-render alle poster
            for (let c = 1; c <= 5; c++) {
                const col = document.getElementById(`col${c}Posts`);
                if (col) col.innerHTML = '';
            }
            _lastPosts.forEach(p => renderPost(p));
            for (let c = 1; c <= 5; c++) {
                setupColumnDropZone(document.getElementById(`col${c}Posts`));
            }
            updateCollapseAllBtn(_lastPosts);
        });
    }

    // -- Pit alarm modal -------------------------------------------------------
    const pitAlarmModal = document.getElementById('pitAlarmModal');
    const pitAlarmInput = document.getElementById('pitAlarmInput');

    function updateGearIcon() {
        const gearIcon = document.querySelector('#pitSettingsBtn i');
        if (gearIcon) gearIcon.className = pitAlarmMinutes ? 'bi bi-gear-fill' : 'bi bi-gear';
        const badge = document.getElementById('pitAlarmBadge');
        const badgeMin = document.getElementById('pitAlarmBadgeMinutes');
        if (badge && badgeMin) {
            badgeMin.textContent = pitAlarmMinutes ?? '';
            badge.style.display = pitAlarmMinutes ? '' : 'none';
        }
    }

    function syncPitAlarm() {
        return fetch('/Dashboard/GetSetting?key=PitAlarmMinutes')
            .then(r => r.json())
            .then(data => {
                const val = parseInt(data.value);
                pitAlarmMinutes = (!isNaN(val) && val > 0) ? val : null;
                updateGearIcon();
            })
            .catch(() => {});
    }

    pitAlarmModal.addEventListener('show.bs.modal', () => {
        pitAlarmInput.value = pitAlarmMinutes ?? '';
    });

    document.getElementById('savePitAlarmBtn').addEventListener('click', () => {
        const val = parseInt(pitAlarmInput.value);
        pitAlarmMinutes = (!isNaN(val) && val > 0) ? val : null;
        postJson('/Dashboard/SetSetting', { key: 'PitAlarmMinutes', value: pitAlarmMinutes?.toString() ?? '' })
            .catch(() => {});
        bootstrap.Modal.getInstance(pitAlarmModal).hide();
        updateGearIcon();
        loadPitVolunteers(pitSearchInput.value);
    });

    document.getElementById('clearPitAlarmBtn').addEventListener('click', () => {
        pitAlarmMinutes = null;
        pitAlarmInput.value = '';
        postJson('/Dashboard/SetSetting', { key: 'PitAlarmMinutes', value: '' })
            .catch(() => {});
        bootstrap.Modal.getInstance(pitAlarmModal).hide();
        updateGearIcon();
        loadPitVolunteers(pitSearchInput.value);
    });

    // -- Init ------------------------------------------------------------------
    updateCheckedInCount();
    updateNoShowCount();
    syncPitAlarm().then(() => loadPitVolunteers(''));
    loadAllPosts();

    // -- Klient-side alarm-ticker ----------------------------------------------
    // Kører hvert 10. sekund og re-renderer kun de post-cards hvis alarmstatus
    // er skiftet (ny frivillig går over tærsklen) – ingen netværkskald, ingen blink.

    function alarmTick() {
        if (_autoRefreshPaused || document.hidden || !alarmsEnabled || !_lastPosts.length) return;
        const now = Date.now();
        let counterDirty = false;

        _lastPosts.forEach(p => {
            if (!p.alarmAfterMinutes) return;
            const thresh = p.alarmAfterMinutes * 60 * 1000;
            const prev   = _knownAlarmState.get(p.id) || new Set();
            const curr   = new Set();

            (p.volunteers || []).forEach(v => {
                if (disabledAlarmVolunteers.has(v.volunteerId)) return;
                const ms = now - parseLocalDate(v.arrivedAtPost).getTime();
                if (ms >= thresh) curr.add(v.volunteerId);
            });

            // Sammenlign sæt – er der kommet nye eller forsvundet alarmer?
            const changed = curr.size !== prev.size ||
                [...curr].some(id => !prev.has(id)) ||
                [...prev].some(id => !curr.has(id));

            if (changed) {
                _knownAlarmState.set(p.id, curr);
                // Re-render kun dette post-card (DOM-op kun for ændrede)
                const existing = document.querySelector(`[data-post-id="${p.id}"]`);
                if (existing) {
                    existing.remove();
                    renderPost(p);
                }
                counterDirty = true;
            }
        });

        if (counterDirty) updateAlarmCounter();
    }

    setInterval(alarmTick, 10_000);

    // -- Background auto-refresh -----------------------------------------------
    // Poller et let "state hash" endpoint hvert sekund.
    // Kun hvis hash'en er ændret OG brugeren ikke er i gang med noget,
    // hentes de faktiske data og UI opdateres stille og roligt.

    // Lyt på drag-events for at pause refresh under drag
    document.addEventListener('dragstart', () => { _autoRefreshPaused = true; });
    document.addEventListener('dragend',   () => {
        setTimeout(() => {
            _autoRefreshPaused = false;
            if (_pendingBoardRefresh) {
                _pendingBoardRefresh = false;
                loadAllPosts();
                loadPitVolunteers(_pendingBoardRefreshPitQuery);
                _pendingBoardRefreshPitQuery = '';
            }
        }, 500);
    });

    async function backgroundRefresh() {
        // Spring over hvis brugeren er i gang med drag eller søger aktivt
        if (_autoRefreshPaused) return;
        if (document.hidden) return; // tab er ikke synlig

        try {
            const res  = await fetch('/Dashboard/StateHash');
            const data = await res.json();
            const hash = data.hash;

            if (hash === _lastStateHash) return; // ingen ændring

            _lastStateHash = hash;

            // Soft-opdatering: ingen spinner, ingen blink – kun ændrede elementer bygges om
            const pitQ = pitSearchInput.value;
            syncPitAlarm().then(() => loadPitVolunteers(pitQ, true));
            loadAllPosts(true);
            updateCheckedInCount();
            updateNoShowCount();            // Diskret prik der viser at siden er synkroniseret
            if (typeof window.syncSmsFlowButton === 'function') window.syncSmsFlowButton();
            showSyncDot();
        } catch {
            // Netværksfejl – ignorer stille
        }
    }

    function showSyncDot() {
        let dot = document.getElementById('autoSyncDot');
        if (!dot) {
            dot = document.createElement('div');
            dot.id = 'autoSyncDot';
            dot.title = 'Siden er synkroniseret';
            dot.style.cssText = 'position:fixed;bottom:10px;right:14px;width:7px;height:7px;border-radius:50%;background:var(--clr-ok);opacity:0;transition:opacity 0.4s;pointer-events:none;z-index:8000;';
            document.body.appendChild(dot);
        }
        dot.style.opacity = '1';
        clearTimeout(dot._t);
        dot._t = setTimeout(() => { dot.style.opacity = '0'; }, 1800);
    }

    // Sæt hash ved første load så vi ikke refresher unødvendigt med det samme
    fetch('/Dashboard/StateHash').then(r => r.json()).then(d => { _lastStateHash = d.hash; }).catch(() => {});

    setInterval(backgroundRefresh, 1000);
})();
</script>

@* -- QR Pit-scanner: dashboard-knap kobler sig til den globale scanner i _Layout -- *@
<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {
        const btn = document.getElementById('qrPitScanBtn');
        if (!btn) return;

        // Knappens klik delegerer til den globale scanner
        btn.addEventListener('click', function () {
            if (typeof window.toggleQrScanner === 'function') window.toggleQrScanner();
        });

        // Synkronisér knappens udseende med den aktuelle scannertilstand
        // (den globale scanner sætter selv knappens style via updateUI() – men vi
        //  kalder det igen her for at sikre korrekt visning efter DOMContentLoaded)
        if (typeof window.isQrScannerActive === 'function' && window.isQrScannerActive()) {
            btn.style.background  = 'var(--clr-brand)';
            btn.style.color       = '#fff';
            btn.style.borderColor = 'var(--clr-brand)';
            btn.title             = 'QR Scanner – sluk';
        }
    });
})();
</script>

@* -- SMS-flow: global, DB-gemt kontakt der styrer om check-in/check-ud/flytning sender sms -- *@
<script>
(function () {
    const btn = document.getElementById('smsFlowToggleBtn');
    if (!btn) return;
    const icon = btn.querySelector('i');
    const cardStatusText = document.getElementById('smsFlowStatusText');

    function applyState(enabled) {
        btn.dataset.enabled = enabled ? 'true' : 'false';
        if (enabled) {
            icon.className        = 'bi bi-chat-dots-fill';
            btn.style.background  = 'var(--clr-brand)';
            btn.style.color       = '#fff';
            btn.style.borderColor = 'var(--clr-brand)';
            btn.title             = 'SMS-flow – slået til (klik for at slukke)';
        } else {
            icon.className        = 'bi bi-chat-dots';
            btn.style.background  = 'var(--clr-bg)';
            btn.style.color       = 'var(--clr-text-muted)';
            btn.style.borderColor = 'var(--clr-border)';
            btn.title             = 'SMS-flow – slået fra (klik for at tænde)';
        }
        if (cardStatusText) {
            cardStatusText.textContent = enabled ? 'Aktiv' : 'Passiv';
            cardStatusText.style.color = enabled ? 'var(--clr-ok)' : 'var(--clr-text-muted)';
        }
    }

    let smsAutoOffSeen = null;
    let smsAutoOffInitialized = false;

    function syncSmsFlowButton() {
        fetch('/Dashboard/GetSmsFlowStatus')
            .then(r => r.json())
            .then(d => {
                applyState(d.enabled);

                if (!smsAutoOffInitialized) {
                    // Første load: husk den nuværende værdi uden at vise en toast for
                    // en evt. gammel automatisk sluk der skete før siden blev åbnet.
                    smsAutoOffSeen = d.autoOffAt;
                    smsAutoOffInitialized = true;
                    return;
                }

                if (d.autoOffAt && d.autoOffAt !== smsAutoOffSeen) {
                    smsAutoOffSeen = d.autoOffAt;
                    showToast('SMS-flow er stoppet – saldoen er opbrugt.', 'error');
                }
            })
            .catch(() => {});
    }

    function getToken() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        if (el) return el.value;
        const meta = document.querySelector('meta[name="RequestVerificationToken"]');
        return meta ? meta.content : '';
    }

    btn.addEventListener('click', function () {
        const nextEnabled = btn.dataset.enabled !== 'true';
        btn.disabled = true;
        fetch('/Dashboard/SetSmsFlowEnabled', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify({ enabled: nextEnabled })
        })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    applyState(nextEnabled);
                    showToast(nextEnabled ? 'SMS-flow slået til' : 'SMS-flow slået fra', nextEnabled ? 'success' : 'warn');
                } else {
                    showToast(res.message || 'Kunne ikke opdatere sms-flow.', 'error');
                }
            })
            .catch(() => showToast('Noget gik galt. Prøv igen.', 'error'))
            .finally(() => { btn.disabled = false; });
    });

    syncSmsFlowButton();
    window.syncSmsFlowButton = syncSmsFlowButton;
})();
</script>
}
