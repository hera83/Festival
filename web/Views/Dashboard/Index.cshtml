@section Scripts {
<style>
    .card-clickable { transition: outline 0.15s, box-shadow 0.15s; }
    .card-clickable:hover { outline: 2px solid var(--clr-brand); box-shadow: 0 0 0 4px var(--clr-brand-dim); }

    .sms-merge-btn {
        background: var(--clr-bg);
        border: 1px dashed var(--clr-border);
        color: var(--clr-brand);
        font-size: 0.75rem;
        padding: 0.15rem 0.55rem;
        border-radius: 20px;
        transition: border-color 0.12s, background 0.12s;
    }
    .sms-merge-btn:hover { border-color: var(--clr-brand); background: var(--clr-brand-dim); }

    .post-card {
        background: var(--clr-bg);
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-md);
        padding: 0.5rem 0.6rem;
        cursor: grab;
        user-select: none;
    }
    .post-card:active { cursor: grabbing; }
    .post-card.dragging { opacity: 0.4; }

    .volunteer-chip {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.2rem 0.5rem;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-md);
        cursor: grab;
        user-select: none;
        font-size: 0.78rem;
        color: var(--clr-text);
        width: 100%;
        box-sizing: border-box;
    }
    .volunteer-chip:active { cursor: grabbing; }
    .volunteer-chip.dragging { opacity: 0.4; }

    .pit-volunteer-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.2rem 0.4rem;
        border-radius: var(--radius-md);
        cursor: grab;
        user-select: none;
    }
    .pit-volunteer-row:active { cursor: grabbing; }
    .pit-volunteer-row.dragging { opacity: 0.4; }

    .vol-menu-btn { opacity: 0.4; transition: opacity 0.15s; }
    .pit-volunteer-row:hover .vol-menu-btn,
    .volunteer-chip:hover .vol-menu-btn,
    .vol-menu-btn:hover { opacity: 1 !important; }

    #vol-ctx-menu .dropdown-item {
        display: flex;
        align-items: center;
        padding: 6px 14px;
        color: var(--clr-text);
        text-decoration: none;
        cursor: pointer;
        white-space: nowrap;
    }
    #vol-ctx-menu .dropdown-item:hover {
        background: rgba(255,255,255,0.06);
        color: var(--clr-text);
    }

    .drop-zone-active {
        background: rgba(232, 93, 46, 0.06) !important;
        outline: 2px dashed var(--clr-brand);
        outline-offset: -2px;
    }
    .post-drop-zone-active {
        background: rgba(232, 93, 46, 0.08) !important;
        outline: 1px dashed var(--clr-brand);
        outline-offset: -1px;
    }

    .alarm-badge {
        font-size: 0.68rem;
        padding: 0.1rem 0.35rem;
        border-radius: 99px;
        background: var(--clr-warn-bg);
        color: var(--clr-warn);
        white-space: nowrap;
    }
    .alarm-firing {
        border-color: var(--clr-alarm) !important;
        box-shadow: 0 0 0 2px rgba(220,53,69,0.25);
    }
</style>
<script>
(function () {
    // -- Globals --------------------------------------------------------------
    let searchTimer = null;
    let pitSearchTimer = null;
    let dragPayload = null; // { type: 'volunteer'|'post', id, fromLocation, element }
    let _autoRefreshPaused = false; // sættes true under drag/drop
    let _pendingBoardRefresh = false; // en ændring blev gemt mens der var en aktiv drag – opdater når den slipper
    let _pendingBoardRefreshPitQuery = '';
    let _lastStateHash = null;
    let _knownAlarmState = new Map(); // postId → Set<volunteerId> der p.t. viser alarm

    // -- DOM refs -------------------------------------------------------------
    const modal        = document.getElementById('checkInModal');
    const searchInput  = document.getElementById('checkInSearch');
    const searchClear  = document.getElementById('checkInSearchClear');
    const tbody        = document.getElementById('checkInTbody');
    const emptyDiv     = document.getElementById('checkInEmpty');
    const spinner      = document.getElementById('checkInSpinner');
    const tableWrapper = document.getElementById('checkInTableWrapper');

    const pitSearchInput = document.getElementById('pitSearch');
    const pitList        = document.getElementById('pitList');
    const pitEmpty       = null; // Tom-tilstand renderes nu inde i pitList
    const pitSpinner     = document.getElementById('pitSpinner');

    // -- Event delegation for frivillig kontekstmenu --------------------------
    document.addEventListener('pointerdown', (e) => {
        const btn = e.target.closest('.vol-menu-btn');
        if (!btn) return;
        e.stopPropagation();
    });
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.vol-menu-btn');
        if (!btn) return;
        e.stopPropagation();
        e.preventDefault();
        openVolunteerMenu(btn);
    });

    // -- Check-in Modal --------------------------------------------------------
    modal.addEventListener('shown.bs.modal', () => {
        searchInput.value = '';
        searchClear.classList.add('d-none');
        loadVolunteers('');
        searchInput.focus();
    });
    modal.addEventListener('hidden.bs.modal', () => {
        updateCheckedInCount();
        updateNoShowCount();
        loadPitVolunteers('');
        loadAllPosts();
    });
    searchInput.addEventListener('keyup', () => {
        searchClear.classList.toggle('d-none', searchInput.value === '');
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => loadVolunteers(searchInput.value), 250);
    });
    searchClear.addEventListener('click', () => {
        searchInput.value = '';
        searchClear.classList.add('d-none');
        loadVolunteers('');
        searchInput.focus();
    });

    function loadVolunteers(q) {
        spinner.classList.remove('d-none');
        tableWrapper.classList.add('d-none');
        const now = new Date();
        const today = now.getFullYear() + '-' +
            String(now.getMonth() + 1).padStart(2, '0') + '-' +
            String(now.getDate()).padStart(2, '0');
        fetch(`/Dashboard/CheckInSearch?q=${encodeURIComponent(q)}&date=${today}`)
            .then(r => r.json())
            .then(data => { spinner.classList.add('d-none'); tableWrapper.classList.remove('d-none'); renderRows(data); })
            .catch(() => {
                spinner.classList.add('d-none'); tableWrapper.classList.remove('d-none');
                tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3" style="color:var(--clr-alarm)"><i class="bi bi-exclamation-triangle me-1"></i>Fejl ved indlæsning</td></tr>';
                emptyDiv.classList.add('d-none');
            });
    }

    function renderRows(volunteers) {
        tbody.innerHTML = '';
        if (!volunteers || volunteers.length === 0) { emptyDiv.classList.remove('d-none'); return; }
        emptyDiv.classList.add('d-none');
        volunteers.forEach(v => {
            const tr = document.createElement('tr');
            tr.style.borderColor = 'var(--clr-border)';
            const actionBtn = v.isCheckedIn
                ? `<button class="btn btn-sm checkout-btn" data-id="${v.id}" data-name="${escHtml(v.name)}" style="background:var(--clr-warn-bg);color:var(--clr-warn);border:1px solid var(--clr-warn);font-size:0.78rem;"><i class="bi bi-box-arrow-right me-1"></i>Check ud</button>`
                : `<button class="btn btn-sm checkin-btn" data-id="${v.id}" data-name="${escHtml(v.name)}" style="background:var(--clr-ok-bg);color:var(--clr-ok);border:1px solid var(--clr-ok);font-size:0.78rem;"><i class="bi bi-box-arrow-in-right me-1"></i>Check ind</button>`;
            tr.innerHTML = `
                <td><span style="font-weight:600;">${escHtml(v.name)}</span>
                ${v.isCheckedIn ? '<span class="badge-ok ms-2" style="font-size:0.68rem;"><i class="bi bi-check2-circle me-1"></i>Checket ind</span>' : ''}
                ${v.email ? `<br><small style="color:var(--clr-text-muted);">${escHtml(v.email)}</small>` : ''}</td>
                <td style="color:var(--clr-text-muted);">${v.phoneNumber ? escHtml(v.phoneNumber) : '—'}</td>
                <td>${v.hasShiftToday ? '<span class="badge-ok" style="font-size:0.72rem;"><i class="bi bi-check2 me-1"></i>Ja</span>' : '<span style="color:var(--clr-text-dim);font-size:0.8rem;">Ingen vagt</span>'}</td>
                <td class="text-end">${actionBtn}</td>`;
            tbody.appendChild(tr);
        });
        document.querySelectorAll('.checkin-btn').forEach(btn => btn.addEventListener('click', function () { doCheckIn(parseInt(this.dataset.id), this.dataset.name, this); }));
        document.querySelectorAll('.checkout-btn').forEach(btn => btn.addEventListener('click', function () { doCheckOut(parseInt(this.dataset.id), this.dataset.name, this); }));
    }

    function doCheckIn(volunteerId, name, btn) {
        btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        postJson('/Dashboard/CheckIn', { volunteerId })
            .then(res => {
                if (res.success) { showToast(res.message, 'success'); updateCheckedInCount(); updateNoShowCount(); loadVolunteers(searchInput.value); }
                else { showToast(res.message, 'warning'); btn.disabled = false; btn.innerHTML = '<i class="bi bi-box-arrow-in-right me-1"></i>Check ind'; }
            })
            .catch(() => { showToast('Noget gik galt. Prøv igen.', 'error'); btn.disabled = false; btn.innerHTML = '<i class="bi bi-box-arrow-in-right me-1"></i>Check ind'; });
    }

    function doCheckOut(volunteerId, name, btn) {
        if (btn && btn.disabled !== undefined) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
        postJson('/Dashboard/CheckOut', { volunteerId })
            .then(res => {
                if (res.success) {
                    disabledAlarmVolunteers.delete(volunteerId);
                    showToast(res.message, 'success'); updateCheckedInCount(); updateNoShowCount(); loadVolunteers(searchInput.value);
                    clearPitSearch(); loadPitVolunteers(''); loadAllPosts();
                }
                else { showToast(res.message, 'warning'); if (btn && btn.disabled !== undefined) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-box-arrow-right me-1"></i>Check ud'; } }
            })
            .catch(() => { showToast('Noget gik galt. Prøv igen.', 'error'); if (btn && btn.disabled !== undefined) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-box-arrow-right me-1"></i>Check ud'; } });
    }

    // -- Tæller ----------------------------------------------------------------
    function updateCheckedInCount() {
        fetch('/Dashboard/GetCheckedInCount').then(r => r.json()).then(data => {
            const el = document.getElementById('checkedInCount');
            if (el) el.textContent = data.count;
            const pit = document.getElementById('pitCount');
            if (pit) pit.textContent = data.pitCount;
        }).catch(() => {});
    }
    window.updateCheckedInCount = updateCheckedInCount;

    function updateNoShowCount() {
        fetch('/Dashboard/GetNoShowCount').then(r => r.json()).then(data => {
            const el = document.getElementById('noShowCount');
            if (el) el.textContent = data.count;
        }).catch(() => {});
    }

    // -- Udeblivelser Modal ----------------------------------------------------
    const noShowModal      = document.getElementById('noShowModal');
    const noShowSearchInput = document.getElementById('noShowSearch');
    const noShowSearchClear = document.getElementById('noShowSearchClear');
    const noShowTbody      = document.getElementById('noShowTbody');
    const noShowEmpty      = document.getElementById('noShowEmpty');
    const noShowSpinner    = document.getElementById('noShowSpinner');
    const noShowWrapper    = document.getElementById('noShowTableWrapper');
    const noShowFooter     = document.getElementById('noShowFooterCount');
    let noShowSearchTimer  = null;
    let _lastNoShows       = [];

    noShowModal.addEventListener('shown.bs.modal', () => {
        noShowSearchInput.value = '';
        noShowSearchClear.classList.add('d-none');
        loadNoShows('');
        noShowSearchInput.focus();
    });

    noShowSearchInput.addEventListener('keyup', () => {
        noShowSearchClear.classList.toggle('d-none', noShowSearchInput.value === '');
        clearTimeout(noShowSearchTimer);
        noShowSearchTimer = setTimeout(() => loadNoShows(noShowSearchInput.value), 250);
    });

    noShowSearchClear.addEventListener('click', () => {
        noShowSearchInput.value = '';
        noShowSearchClear.classList.add('d-none');
        loadNoShows('');
        noShowSearchInput.focus();
    });

    function loadNoShows(q) {
        noShowSpinner.classList.remove('d-none');
        noShowWrapper.classList.add('d-none');
        fetch(`/Dashboard/GetNoShowList?q=${encodeURIComponent(q || '')}`)
            .then(r => r.json())
            .then(data => {
                _lastNoShows = data;
                noShowSpinner.classList.add('d-none');
                noShowWrapper.classList.remove('d-none');
                renderNoShowRows(data);
            })
            .catch(() => {
                noShowSpinner.classList.add('d-none');
                noShowWrapper.classList.remove('d-none');
                noShowTbody.innerHTML = '<tr><td colspan="3" class="text-center py-3" style="color:var(--clr-alarm)"><i class="bi bi-exclamation-triangle me-1"></i>Fejl ved indlæsning</td></tr>';
                noShowEmpty.classList.add('d-none');
            });
    }

    function renderNoShowRows(list) {
        noShowTbody.innerHTML = '';
        if (!list || list.length === 0) {
            noShowEmpty.classList.remove('d-none');
            noShowFooter.textContent = '';
            return;
        }
        noShowEmpty.classList.add('d-none');
        noShowFooter.textContent = `${list.length} udeblivelse${list.length !== 1 ? 'r' : ''}`;
        list.forEach(v => {
            const tr = document.createElement('tr');
            tr.style.borderColor = 'var(--clr-border)';
            const phone = v.phoneNumber
                ? `<span style="color:var(--clr-info);"><i class="bi bi-telephone me-1"></i>${escHtml(v.phoneNumber)}</span>`
                : '<span style="color:var(--clr-text-dim);">—</span>';
            const start = parseLocalDate(v.earliestStart);
            const startStr = start.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' });
            const minsLate = Math.floor((Date.now() - start.getTime()) / 60000);
            const lateLabel = minsLate > 0
                ? `<span class="badge-warn ms-2" style="font-size:0.68rem;"><i class="bi bi-clock me-1"></i>${minsLate} min forsinket</span>`
                : '';
            tr.innerHTML = `
                <td><span style="font-weight:600;">${escHtml(v.name)}</span>${lateLabel}</td>
                <td>${phone}</td>
                <td style="color:var(--clr-text-muted);white-space:nowrap;">${startStr}</td>`;
            noShowTbody.appendChild(tr);
        });
    }

    // -- Pitten ----------------------------------------------------------------
    pitSearchInput.addEventListener('keyup', () => {
        clearTimeout(pitSearchTimer);
        pitSearchTimer = setTimeout(() => loadPitVolunteers(pitSearchInput.value), 250);
    });

    function loadPitVolunteers(q, silent = false) {
        if (silent && _autoRefreshPaused) return; // drag er i gang – drop opdateringen
        if (!silent) {
            pitSpinner.classList.remove('d-none');
            pitList.classList.add('d-none');
        }
        fetch(`/Dashboard/GetPitVolunteers?q=${encodeURIComponent(q || '')}`)
            .then(r => r.json())
            .then(data => {
                if (silent && _autoRefreshPaused) return; // drag startede mens fetch kørte
                if (!silent) pitSpinner.classList.add('d-none');
                renderPitList(data, q || '');
            })
            .catch(() => {
                if (!silent) {
                    pitSpinner.classList.add('d-none');
                    pitList.innerHTML = '<div class="text-center py-3" style="color:var(--clr-alarm)"><i class="bi bi-exclamation-triangle me-1"></i>Fejl ved indlæsning</div>';
                    pitList.classList.remove('d-none');
                }
            });
    }
    window.loadPitVolunteers = loadPitVolunteers;

    function renderPitList(volunteers, q) {
        hideVolunteerHistoryPopup();
        pitList.classList.remove('d-none');
        const hasQuery = q && q.trim() !== '';

        // Filtrer post-chips baseret på søgningen
        filterPostChips(hasQuery ? volunteers.map(v => v.volunteerId) : null);

        const pitVolunteers = volunteers.filter(v => v.currentLocation === 'Pit' || !v.currentLocation);

        if (!hasQuery && pitVolunteers.length === 0) {
            pitList.innerHTML = `<div id="pitEmpty" class="text-center py-4" style="color:var(--clr-text-muted);">
                <i class="bi bi-person-x" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0">Ingen i pitten</p>
            </div>`;
            setupPitDropZone();
            return;
        }

        if (hasQuery && volunteers.length === 0) {
            pitList.innerHTML = `<div id="pitEmpty" class="text-center py-4" style="color:var(--clr-text-muted);">
                <i class="bi bi-search" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0">Ingen resultater</p>
            </div>`;
            setupPitDropZone();
            return;
        }

        // Sorter: alarmerede øverst, derefter alfabetisk
        const now = Date.now();
        const withAlarm = (v) => alarmsEnabled && pitAlarmMinutes && v.arrivedAtPit
            && !disabledAlarmVolunteers.has(v.volunteerId)
                    ? (now - parseLocalDate(v.arrivedAtPit).getTime()) >= pitAlarmMinutes * 60 * 1000
            : false;

        // Opdater pit alarm count og den globale tæller
        _pitAlarmCount = pitVolunteers.filter(v => withAlarm(v)).length;
        updateAlarmCounter();

        const sorted = [...pitVolunteers].sort((a, b) => {
            const aFiring = withAlarm(a);
            const bFiring = withAlarm(b);
            if (aFiring && !bFiring) return -1;
            if (!aFiring && bFiring) return 1;
            return a.name.localeCompare(b.name);
        });

        // Byg ny DOM
        pitList.innerHTML = '';

        // Vis pit-frivillige
        sorted.forEach(v => {
            const firing = withAlarm(v);
            const alarmMuted = disabledAlarmVolunteers.has(v.volunteerId);
            const row = document.createElement('div');
            row.className = 'pit-volunteer-row';
            if (firing) row.style.cssText = 'border-left:3px solid var(--clr-alarm);padding-left:0.4rem;';
            row.draggable = true;
            row.dataset.volunteerId = v.volunteerId;
            row.dataset.name = v.name;
            row.dataset.location = 'Pit';
            row.innerHTML = `
                <div style="width:26px;height:26px;border-radius:50%;background:${firing ? 'var(--clr-alarm-bg)' : 'var(--clr-brand-dim)'};display:flex;align-items:center;justify-content:center;flex-shrink:0;color:${firing ? 'var(--clr-alarm)' : 'var(--clr-brand)'};font-weight:700;font-size:0.75rem;">
                    ${escHtml(v.name).charAt(0).toUpperCase()}
                </div>
                <span style="font-size:0.875rem;color:var(--clr-text);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(v.name)}</span>
                ${elapsedBadgeHtml(v.arrivedAtPit)}
                ${firing ? '<i class="bi bi-exclamation-triangle-fill" style="color:var(--clr-alarm);font-size:0.75rem;" title="Over alarmtid"></i>' : ''}
                ${alarmMuted ? '<i class="bi bi-bell-slash" style="color:var(--clr-text-muted);font-size:0.7rem;" title="Alarm deaktiveret"></i>' : ''}
                <button class="vol-menu-btn" data-vid="${v.volunteerId}" data-vname="${escHtml(v.name)}" data-vloc="Pit" draggable="false"
                    style="background:none;border:none;padding:0 2px;color:var(--clr-text-muted);font-size:0.85rem;cursor:pointer;flex-shrink:0;line-height:1;margin-left:4px;">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>`
            row.addEventListener('dragstart', onVolunteerDragStart);
            row.addEventListener('dragend', onDragEnd);
            attachVolunteerHistoryHover(row, v.volunteerId);
            pitList.appendChild(row);
        });

        // Vis frivillige i poster som søgeresultat (ikke i Pit)
        const postVolunteers = volunteers.filter(v => v.currentLocation && v.currentLocation !== 'Pit');
        if (hasQuery && postVolunteers.length > 0) {
            const sep = document.createElement('div');
            sep.style.cssText = 'font-size:0.7rem;color:var(--clr-text-muted);padding:0.4rem 0.25rem 0.1rem;text-transform:uppercase;letter-spacing:0.05em;';
            sep.textContent = 'I post';
            pitList.appendChild(sep);
            postVolunteers.forEach(v => {
                const row = document.createElement('div');
                row.className = 'pit-volunteer-row';
                row.style.opacity = '0.7';
                row.innerHTML = `
                    <div style="width:26px;height:26px;border-radius:50%;background:var(--clr-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--clr-text-muted);font-weight:700;font-size:0.75rem;border:1px solid var(--clr-border);">
                        ${escHtml(v.name).charAt(0).toUpperCase()}
                    </div>
                    <span style="font-size:0.875rem;color:var(--clr-text);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(v.name)}</span>
                    <span style="font-size:0.7rem;color:var(--clr-text-muted);white-space:nowrap;">${escHtml(v.currentLocation)}</span>
                    ${elapsedBadgeHtml(v.arrivedAtPit)}
                    <button class="vol-menu-btn" data-vid="${v.volunteerId}" data-vname="${escHtml(v.name)}" data-vloc="${escHtml(v.currentLocation)}" draggable="false"
                        style="background:none;border:none;padding:0 2px;color:var(--clr-text-muted);font-size:0.85rem;cursor:pointer;flex-shrink:0;line-height:1;margin-left:4px;">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>`;
                attachVolunteerHistoryHover(row, v.volunteerId);
                pitList.appendChild(row);
            });
        }

        setupPitDropZone();
    }

    // Skjul/vis volunteer-chips i poster baseret på søgning
    function filterPostChips(matchingIds) {
        document.querySelectorAll('.volunteer-chip').forEach(chip => {
            if (!matchingIds) {
                chip.style.display = '';
            } else {
                chip.style.display = matchingIds.includes(parseInt(chip.dataset.volunteerId)) ? '' : 'none';
            }
        });
    }

    // Ryd søgefeltet og nulstil visningen
    function clearPitSearch() {
        if (pitSearchInput.value === '') return;
        pitSearchInput.value = '';
        filterPostChips(null);
    }

    // -- Poster ----------------------------------------------------------------
    function loadAllPosts(silent = false) {
        fetch('/Post/GetAll').then(r => r.json()).then(posts => {
            if (silent && _autoRefreshPaused) return; // drag er i gang – drop opdateringen
            renderAllPosts(posts);
        }).catch(() => {});
    }

    function renderAllPosts(posts) {
        hideVolunteerHistoryPopup();
        _lastPosts = posts;
        _knownAlarmState.clear(); // nulstil alarmtilstand så tickeren re-evaluerer
        // Ryd alle 5 kolonner og rebuild synkront (ingen visuel blink da JS er single-threaded)
        for (let c = 1; c <= 5; c++) {
            const col = document.getElementById(`col${c}Posts`);
            if (col) col.innerHTML = '';
        }
        posts.forEach(p => renderPost(p));
        for (let c = 1; c <= 5; c++) {
            setupColumnDropZone(document.getElementById(`col${c}Posts`));
        }

        const postsEl = document.getElementById('activePostsCount');
        if (postsEl) postsEl.textContent = posts.length;

        updateAlarmCounter();
        updateCollapseAllBtn(posts);
    }

    function updateAlarmCounter() {
        const alarmsEl = document.getElementById('activeAlarmsCount');
        if (!alarmsEl) return;
        const now = Date.now();
        let postAlarmCount = 0;
        if (alarmsEnabled) {
            _lastPosts.forEach(p => {
                if (!p.alarmAfterMinutes) return;
                (p.volunteers || []).forEach(v => {
                    if (disabledAlarmVolunteers.has(v.volunteerId)) return;
                            const ms = now - parseLocalDate(v.arrivedAtPost).getTime();
                    if (ms >= p.alarmAfterMinutes * 60 * 1000) postAlarmCount++;
                });
            });
        }
        const total = postAlarmCount + _pitAlarmCount;
        alarmsEl.textContent = total;
        alarmsEl.style.color = total > 0 ? 'var(--clr-alarm)' : 'var(--clr-text)';
    }

    function renderPost(p) {
        const col = document.getElementById(`col${p.columnIndex}Posts`);
        if (!col) return;

        const card = document.createElement('div');
        card.className = 'post-card';
        card.draggable = true;
        card.dataset.postId = p.id;
        card.dataset.postName = p.name;
        card.dataset.column = p.columnIndex;

        const alarmBadge = (alarmsEnabled && p.alarmAfterMinutes)
            ? `<span class="alarm-badge ms-1"><i class="bi bi-bell-fill me-1"></i>${p.alarmAfterMinutes} min</span>`
            : '';

        // Check om nogen frivillige er over alarmtiden
        const now = Date.now();
        const firingVolunteers = alarmsEnabled ? (p.volunteers || []).filter(v => {
            if (!p.alarmAfterMinutes) return false;
            if (disabledAlarmVolunteers.has(v.volunteerId)) return false;
                            const ms = now - parseLocalDate(v.arrivedAtPost).getTime();
            return ms >= p.alarmAfterMinutes * 60 * 1000;
        }) : [];
        const alarmFiring = firingVolunteers.length > 0;

        const isCollapsed = collapsedPosts.has(p.id);
        const volunteerCount = (p.volunteers || []).length;

        card.innerHTML = `
            <div class="d-flex align-items-center justify-content-between mb-1">
                <div class="d-flex align-items-center gap-1" style="font-size:0.82rem;font-weight:600;color:var(--clr-text);flex:1;min-width:0;cursor:pointer;" data-collapse-toggle>
                    <i class="bi bi-signpost-2" style="color:var(--clr-brand);font-size:0.78rem;"></i>
                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(p.name)}</span>
                    ${alarmBadge}
                    ${alarmFiring ? `<span style="color:var(--clr-alarm);font-size:0.75rem;" title="${firingVolunteers.length} frivillig(e) har oversteget alarmtiden"><i class="bi bi-exclamation-triangle-fill"></i></span>` : ''}
                </div>
                <div class="d-flex align-items-center gap-1" style="flex-shrink:0;">
                    <button class="btn btn-sm post-collapse-btn" title="${isCollapsed ? 'Udvid post' : 'Minimer post'}"
                            style="padding:0.1rem 0.3rem;background:none;border:none;color:var(--clr-text-dim);font-size:0.8rem;">
                        <i class="bi ${isCollapsed ? 'bi-chevron-down' : 'bi-chevron-up'}"></i>
                    </button>
                    <div class="dropdown" style="line-height:1;">
                        <button class="btn btn-sm post-menu-btn" data-bs-toggle="dropdown" aria-expanded="false"
                                style="padding:0.1rem 0.3rem;background:none;border:none;color:var(--clr-text-dim);font-size:0.8rem;" title="Indstillinger">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" style="background:var(--clr-surface);border:1px solid var(--clr-border);min-width:130px;">
                            <li>
                                <button class="dropdown-item edit-post-btn d-flex align-items-center gap-2"
                                        data-post-id="${p.id}" data-post-name="${escHtml(p.name)}" data-alarm="${p.alarmAfterMinutes ?? ''}"
                                        style="color:var(--clr-text);font-size:0.82rem;">
                                    <i class="bi bi-pencil" style="color:var(--clr-info);"></i> Rediger
                                </button>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color:var(--clr-border);margin:0.25rem 0;"></li>
                            <li>
                                <button class="dropdown-item delete-post-btn d-flex align-items-center gap-2"
                                        data-post-id="${p.id}" data-post-name="${escHtml(p.name)}" data-volunteer-count="${volunteerCount}"
                                        style="color:var(--clr-alarm);font-size:0.82rem;">
                                    <i class="bi bi-trash3"></i> Slet
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="post-volunteer-zone d-flex flex-column gap-1" data-post-name="${escHtml(p.name)}" style="min-height:${isCollapsed ? '0' : '32px'};padding-top:${isCollapsed ? '0' : '4px'};${isCollapsed ? 'display:none!important;' : ''}">
                ${(p.volunteers || []).map(v => volunteerChipHtml(v, p.name, p.alarmAfterMinutes)).join('')}
            </div>
            ${isCollapsed ? `<div class="post-collapsed-summary" style="font-size:0.75rem;color:var(--clr-text-muted);padding-top:0.1rem;">
                <i class="bi bi-people" style="margin-right:0.25rem;"></i>${volunteerCount} frivillig${volunteerCount !== 1 ? 'e' : ''}
                ${alarmFiring ? `<span style="color:var(--clr-alarm);margin-left:0.4rem;"><i class="bi bi-exclamation-triangle-fill"></i> Alarm</span>` : ''}
            </div>` : ''}`;

        card.addEventListener('dragstart', onPostDragStart);
        card.addEventListener('dragend', onDragEnd);

        // Collapse toggle via knap og header-klik
        const collapseBtn = card.querySelector('.post-collapse-btn');
        const collapseToggle = card.querySelector('[data-collapse-toggle]');
        const toggleCollapse = (e) => {
            e.stopPropagation();
            if (collapsedPosts.has(p.id)) collapsedPosts.delete(p.id);
            else collapsedPosts.add(p.id);
            // Re-render kun denne post
            const parent = card.parentElement;
            card.remove();
            renderPost(p);
            updateCollapseAllBtn(_lastPosts);
            // Genåbn den nye card i samme parent
            if (parent) {
                const newCard = parent.querySelector(`[data-post-id="${p.id}"]`);
                // kort er allerede appended af renderPost
            }
        };
        collapseBtn.addEventListener('click', toggleCollapse);
        collapseToggle.addEventListener('click', toggleCollapse);

        card.querySelector('.edit-post-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            const btn = e.currentTarget;
            openEditPostModal(parseInt(btn.dataset.postId), btn.dataset.postName, btn.dataset.alarm);
        });

        card.querySelector('.delete-post-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            const btn = e.currentTarget;
            openDeletePostModal(parseInt(btn.dataset.postId), btn.dataset.postName, parseInt(btn.dataset.volunteerCount) || 0);
        });

        // Setup volunteer drop-zone på posten
        const vZone = card.querySelector('.post-volunteer-zone');
        setupVolunteerDropZoneOnPost(vZone, p.name);

        // Drag events for volunteer chips
        card.querySelectorAll('.volunteer-chip').forEach(chip => {
            chip.addEventListener('dragstart', onVolunteerDragStart);
            chip.addEventListener('dragend', onDragEnd);
            attachVolunteerHistoryHover(chip, parseInt(chip.dataset.volunteerId));
        });

        if (alarmFiring) card.classList.add('alarm-firing');

        // Indsæt i korrekt rækkefølge baseret på _lastPosts-sorteringen,
        // så re-renderede kort (fx ved alarmtick) ikke hopper til bunden.
        const postsInCol = _lastPosts.filter(x => x.columnIndex === p.columnIndex);
        const myIdx = postsInCol.findIndex(x => x.id === p.id);
        const nextPost = postsInCol[myIdx + 1];
        if (nextPost) {
            const nextCard = col.querySelector(`[data-post-id="${nextPost.id}"]`);
            if (nextCard) col.insertBefore(card, nextCard);
            else col.appendChild(card);
        } else {
            col.appendChild(card);
        }
    }

    function volunteerChipHtml(v, postName, alarmAfterMinutes) {
        let alarmIcon = '';
        if (alarmsEnabled && alarmAfterMinutes && !disabledAlarmVolunteers.has(v.volunteerId)) {
                    const ms = Date.now() - parseLocalDate(v.arrivedAtPost).getTime();
            if (ms >= alarmAfterMinutes * 60 * 1000) {
                alarmIcon = `<i class="bi bi-exclamation-triangle-fill" style="color:var(--clr-alarm);font-size:0.7rem;" title="Over alarmtid"></i>`;
            }
        }
        const alarmMuted = disabledAlarmVolunteers.has(v.volunteerId);
        return `<span class="volunteer-chip" draggable="true" data-volunteer-id="${v.volunteerId}" data-name="${escHtml(v.name)}" data-location="${escHtml(postName)}">
            <span style="width:20px;height:20px;border-radius:50%;background:var(--clr-brand-dim);display:inline-flex;align-items:center;justify-content:center;color:var(--clr-brand);font-weight:700;font-size:0.65rem;flex-shrink:0;">
                ${escHtml(v.name).charAt(0).toUpperCase()}
            </span>
            <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(v.name)}</span>
            ${elapsedBadgeHtml(v.arrivedAtPost)}
            ${alarmIcon}
            ${alarmMuted ? `<i class="bi bi-bell-slash" style="color:var(--clr-text-muted);font-size:0.65rem;" title="Alarm deaktiveret"></i>` : ''}
            <button class="vol-menu-btn" data-vid="${v.volunteerId}" data-vname="${escHtml(v.name)}" data-vloc="${escHtml(postName)}" draggable="false"
                style="background:none;border:none;padding:0 2px;color:var(--clr-text-muted);font-size:0.8rem;cursor:pointer;flex-shrink:0;line-height:1;">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
        </span>`;
    }

    // -- Frivillig historik-popup (hover) ---------------------------------------
    // Viser hvornår en frivillig kom til sin nuværende post/pit, og hvor længe de
    // har været der, samt tidligere poster i samme check-in-session.
    let _volHistoryPopup = null;
    let _volHistoryTicker = null;
    let _volHistoryHideTimer = null;
    let _volHistoryShowTimer = null;
    let _volHistoryReqId = 0;
    const VOL_HISTORY_HOVER_DELAY_MS = 2000;

    function attachVolunteerHistoryHover(el, volunteerId) {
        el.addEventListener('mouseenter', () => {
            clearTimeout(_volHistoryShowTimer);
            _volHistoryShowTimer = setTimeout(() => showVolunteerHistoryPopup(el, volunteerId), VOL_HISTORY_HOVER_DELAY_MS);
        });
        el.addEventListener('mouseleave', () => {
            clearTimeout(_volHistoryShowTimer);
            clearTimeout(_volHistoryHideTimer);
            _volHistoryHideTimer = setTimeout(closeVolunteerHistoryPopup, 80);
        });
    }

    // Lukker kun den viste popup — rører ikke en evt. ny, allerede planlagt visning
    // for et element brugeren i mellemtiden er begyndt at hovere.
    function closeVolunteerHistoryPopup() {
        clearTimeout(_volHistoryHideTimer);
        clearInterval(_volHistoryTicker);
        _volHistoryTicker = null;
        if (_volHistoryPopup) { _volHistoryPopup.remove(); _volHistoryPopup = null; }
    }

    // Fuld nulstilling — bruges når DOM'en genopbygges (fx ved auto-refresh),
    // så en ventende visning ikke dukker op for et element der ikke længere findes.
    function hideVolunteerHistoryPopup() {
        clearTimeout(_volHistoryShowTimer);
        closeVolunteerHistoryPopup();
    }

    function showVolunteerHistoryPopup(el, volunteerId) {
        clearTimeout(_volHistoryHideTimer);
        const reqId = ++_volHistoryReqId;

        fetch(`/Dashboard/GetVolunteerHistory?volunteerId=${volunteerId}`)
            .then(r => r.json())
            .then(data => {
                if (reqId !== _volHistoryReqId) return; // en ny hover er startet i mellemtiden
                if (!el.isConnected) return; // elementet blev fjernet (fx pga. re-render)
                closeVolunteerHistoryPopup();
                if (!data.hasCheckIn || !data.history || data.history.length === 0) return;
                renderVolunteerHistoryPopup(el, data.history);
            })
            .catch(() => {});
    }

    function formatDuration(mins) {
        if (mins < 1) return '<1 min';
        if (mins < 60) return `${mins} min`;
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        return m > 0 ? `${h}t ${m}min` : `${h}t`;
    }

    // -- Elapsed-time badge (lille badge i frivillig-elementet: "1 t 32 m") -----
    // Bruges i pit-rækker og post-chips til at vise hvor længe en frivillig har
    // været på sin nuværende post/pit. Tikkes hvert sekund af elapsedTick(),
    // som kun skriver til DOM'en når den viste tekst faktisk ændrer sig.
    function formatElapsedBadge(mins) {
        if (mins < 1) return '<1 m';
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        if (h === 0) return `${m} m`;
        return m > 0 ? `${h} t ${m} m` : `${h} t`;
    }

    function elapsedBadgeHtml(arrivedAt) {
        if (!arrivedAt) return '';
        const mins = Math.max(0, Math.round((Date.now() - parseLocalDate(arrivedAt).getTime()) / 60000));
        return `<span class="elapsed-badge" data-arrived-at="${escHtml(arrivedAt)}">${formatElapsedBadge(mins)}</span>`;
    }

    function elapsedTick() {
        if (document.hidden) return;
        const now = Date.now();
        document.querySelectorAll('.elapsed-badge[data-arrived-at]').forEach(el => {
            const arrivedAt = el.dataset.arrivedAt;
            if (!arrivedAt) return;
            const mins = Math.max(0, Math.round((now - parseLocalDate(arrivedAt).getTime()) / 60000));
            const text = formatElapsedBadge(mins);
            if (el.textContent !== text) el.textContent = text;
        });
    }

    setInterval(elapsedTick, 1000);

    function renderVolunteerHistoryPopup(el, history) {
        const popup = document.createElement('div');
        popup.id = 'vol-history-popup';
        popup.style.cssText = `position:fixed;z-index:9998;min-width:190px;max-width:260px;background:var(--clr-surface);border:1px solid var(--clr-border);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,0.5);font-size:0.78rem;padding:8px 10px;pointer-events:none;`;
        document.body.appendChild(popup);
        _volHistoryPopup = popup;

        const renderContent = () => {
            if (!_volHistoryPopup) return;
            const now = Date.now();
            const rows = [...history].reverse().map(h => {
                const t = parseLocalDate(h.occurredAt);
                const timeStr = t.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' });
                const mins = h.isCurrent
                    ? Math.max(0, Math.round((now - t.getTime()) / 60000))
                    : h.durationMinutes;
                const locLabel = h.location === 'Pit' ? 'Pitten' : (h.location || '—');
                return `<div style="display:flex;align-items:baseline;gap:6px;padding:2px 0;${h.isCurrent ? 'color:var(--clr-text);font-weight:600;' : 'color:var(--clr-text-muted);'}">
                    <i class="bi ${h.isCurrent ? 'bi-geo-alt-fill' : 'bi-geo-alt'}" style="font-size:0.7rem;flex-shrink:0;"></i>
                    <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(locLabel)}</span>
                    <span style="white-space:nowrap;">${timeStr} · ${formatDuration(mins)}</span>
                </div>`;
            }).join('');
            _volHistoryPopup.innerHTML = `<div style="font-size:0.68rem;color:var(--clr-text-muted);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:4px;">Historik i dag</div>${rows}`;
            positionPopup();
        };

        const positionPopup = () => {
            if (!_volHistoryPopup || !el.isConnected) { closeVolunteerHistoryPopup(); return; }
            const rect = el.getBoundingClientRect();
            const popH = _volHistoryPopup.offsetHeight;
            const popW = _volHistoryPopup.offsetWidth;
            let top = rect.bottom + 6;
            let left = rect.left;
            if (top + popH > window.innerHeight - 8) top = rect.top - popH - 6;
            if (left + popW > window.innerWidth - 8) left = window.innerWidth - popW - 8;
            if (left < 4) left = 4;
            _volHistoryPopup.style.top = top + 'px';
            _volHistoryPopup.style.left = left + 'px';
        };

        renderContent();
        // Tik varigheden på den aktuelle post live, i samme rytme som dashboardets øvrige opdateringer.
        _volHistoryTicker = setInterval(renderContent, 1000);
    }

    // -- Frivillig kontekstmenu ------------------------------------------------
    let _volMenuOpen = null;
    let _volMenuAbort = null; // AbortController til "klik udenfor"-lytteren

    function openVolunteerMenu(btn) {
