                            tabindex="-1" aria-label="Ryd søgning">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div id="noShowSpinner" class="text-center py-3 d-none">
                    <div class="spinner-border spinner-border-sm" style="color:var(--clr-brand);"></div>
                </div>

                <div id="noShowTableWrapper">
                    <table class="table table-hover" style="color:var(--clr-text);">
                        <thead>
                            <tr style="color:var(--clr-text-muted);font-size:0.8rem;border-color:var(--clr-border);">
                                <th>Navn</th>
                                <th>Telefon</th>
                                <th>Vagtstart</th>
                            </tr>
                        </thead>
                        <tbody id="noShowTbody">
                            <tr>
                                <td colspan="3" class="text-center py-3" style="color:var(--clr-text-muted);">
                                    <div class="spinner-border spinner-border-sm me-2" style="color:var(--clr-brand);"></div>Henter...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div id="noShowEmpty" class="text-center py-4 d-none" style="color:var(--clr-text-muted);">
                        <i class="bi bi-check2-circle" style="font-size:2rem;color:var(--clr-ok);"></i>
                        <p class="mt-2 mb-0">Ingen udeblivelser – alle er mødt op!</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <span id="noShowFooterCount" style="font-size:0.8rem;color:var(--clr-text-muted);margin-right:auto;"></span>
                <button type="button" class="btn btn-sm" style="background:var(--clr-bg);color:var(--clr-text-muted);border-color:var(--clr-border);" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Luk
                </button>
            </div>
        </div>
    </div>
</div>

<!-- SMS Modal -->
<div class="modal fade" id="smsModal" tabindex="-1" aria-labelledby="smsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="smsModalLabel">
                    <i class="bi bi-chat-dots me-2" style="color:var(--clr-info);"></i>SMS
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3" style="font-size:0.83rem;color:var(--clr-text-muted);">
                    Skabeloner for de sms'er der sendes til en frivillig ved check-in, check-ud og flytning i dashboardet.
                    Klik på et fletfelt for at indsætte det i teksten.
                </p>

                <ul class="nav nav-tabs mb-3" id="smsTemplateTabs" role="tablist" style="border-bottom:1px solid var(--clr-border);">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="smsTab-CheckIn" data-bs-toggle="tab" data-bs-target="#smsPane-CheckIn" type="button" role="tab">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Check-in
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="smsTab-CheckOut" data-bs-toggle="tab" data-bs-target="#smsPane-CheckOut" type="button" role="tab">
                            <i class="bi bi-box-arrow-right me-2"></i>Check-ud
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="smsTab-Moved" data-bs-toggle="tab" data-bs-target="#smsPane-Moved" type="button" role="tab">
                            <i class="bi bi-arrow-left-right me-2"></i>Flytning
                        </button>
                    </li>
                </ul>

                <div id="smsSpinner" class="text-center py-3">
                    <div class="spinner-border spinner-border-sm" style="color:var(--clr-brand);"></div>
                </div>

                <div class="tab-content d-none" id="smsTemplateTabContent">
                    <div class="tab-pane fade show active" id="smsPane-CheckIn" role="tabpanel" data-template-type="CheckIn">
                        <div class="d-flex flex-wrap gap-1 mb-2">
