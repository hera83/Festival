                e.preventDefault();
                volMenuMove(parseInt(a.dataset.vid), a.dataset.vtarget);
            });
        });

        // Positioner menuen
        const menuW = 220;
        const menuH = 190;
        let top = rect.bottom + 4;
        let left = rect.right - menuW;
        if (left < 4) left = 4;
        if (top + menuH > window.innerHeight - 8) top = rect.top - menuH - 4;
        menu.style.top = top + 'px';
        menu.style.left = left + 'px';

        _volMenuOpen = menu;

        // Luk ved klik udenfor – brug AbortController så lytteren kan fjernes præcist
        _volMenuAbort = new AbortController();
        setTimeout(() => {
            document.addEventListener('click', closeVolunteerMenu, { signal: _volMenuAbort.signal });
        }, 10);
    }

    function closeVolunteerMenu() {
        if (_volMenuAbort) { _volMenuAbort.abort(); _volMenuAbort = null; }
        if (_volMenuOpen) { _volMenuOpen.remove(); _volMenuOpen = null; }
    }

    function volMenuMove(volunteerId, targetLocation) {
        closeVolunteerMenu();
        disabledAlarmVolunteers.delete(volunteerId);
        moveVolunteer(volunteerId, targetLocation);
    }

    function volMenuToggleAlarm(volunteerId) {
        closeVolunteerMenu();
        if (disabledAlarmVolunteers.has(volunteerId)) {
            disabledAlarmVolunteers.delete(volunteerId);
            showToast('Alarm aktiveret igen.', 'info');
        } else {
            disabledAlarmVolunteers.add(volunteerId);
            showToast('Alarm deaktiveret for denne frivillig.', 'info');
        }
        // Opdater visning
        loadPitVolunteers(pitSearchInput.value);
        if (_lastPosts.length) renderAllPosts(_lastPosts);
        updateAlarmCounter();
    }

    function volMenuCheckOut(volunteerId, name) {
        closeVolunteerMenu();
        // Simuler et checkout via doCheckOut — find eller opret en knap-reference
        const fakeBtn = { disabled: false, innerHTML: '' };
        doCheckOut(volunteerId, name, fakeBtn);
    }

    // -- Fremtidig flyt --------------------------------------------------------
    let _futureMoveCurrentId = null;

    function openFutureMoveModal(volunteerId, name) {
        _futureMoveCurrentId = null;
        document.getElementById('futureMoveVolunteerId').value = volunteerId;
        document.getElementById('futureMoveVolunteerName').textContent = name;
        document.getElementById('futureMoveMinutes').value = '';
        document.getElementById('futureMoveExistingAlert').classList.add('d-none');

        // Byg destination-dropdown
        const sel = document.getElementById('futureMoveTarget');
        sel.innerHTML = '<option value="Pit">Pitten</option>';
        _lastPosts.forEach(p => {
            const opt = document.createElement('option');
            opt.value = p.name;
            opt.textContent = p.name;
            sel.appendChild(opt);
        });

        // Tjek om der allerede er en planlagt flytning
        fetch(`/Dashboard/GetScheduledMove?volunteerId=${volunteerId}`)
            .then(r => r.json())
            .then(data => {
                if (data.hasPending) {
                    _futureMoveCurrentId = data.id;
                    const alertEl = document.getElementById('futureMoveExistingAlert');
                    alertEl.classList.remove('d-none');
                    document.getElementById('futureMoveExistingText').textContent =
                        `Planlagt flytning til "${data.targetLocation}" om ca. ${data.minsLeft} min. Ny planlægning erstatter denne.`;
                }
            }).catch(() => {});

        bootstrap.Modal.getOrCreateInstance(document.getElementById('futureMoveModal')).show();
    }

    document.getElementById('futureMoveCancel').addEventListener('click', () => {
        if (!_futureMoveCurrentId) return;
        postJson('/Dashboard/CancelScheduledMove', { moveId: _futureMoveCurrentId })
            .then(res => {
                if (res.success) {
                    showToast(res.message, 'info');
                    _futureMoveCurrentId = null;
                    document.getElementById('futureMoveExistingAlert').classList.add('d-none');
                } else {
                    showToast(res.message, 'warning');
                }
            }).catch(() => showToast('Noget gik galt.', 'error'));
    });

    document.getElementById('futureMoveConfirmBtn').addEventListener('click', () => {
        const volunteerId = parseInt(document.getElementById('futureMoveVolunteerId').value);
        const targetLocation = document.getElementById('futureMoveTarget').value;
        const minsVal = document.getElementById('futureMoveMinutes').value.trim();
        const delayMinutes = minsVal ? parseInt(minsVal) : 0;

        if (!delayMinutes || delayMinutes < 1) { showToast('Angiv antal minutter (mindst 1).', 'warning'); return; }

        const btn = document.getElementById('futureMoveConfirmBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        postJson('/Dashboard/ScheduleFutureMove', { volunteerId, targetLocation, delayMinutes })
            .then(res => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-clock-history me-1"></i>Planlæg flytning';
                if (res.success) {
                    showToast(res.message, 'success');
                    bootstrap.Modal.getInstance(document.getElementById('futureMoveModal')).hide();
                } else {
                    showToast(res.message, 'warning');
                }
            }).catch(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-clock-history me-1"></i>Planlæg flytning';
                showToast('Noget gik galt. Prøv igen.', 'error');
            });
    });

