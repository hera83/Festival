                    <i class="bi bi-chevron-right" style="font-size:0.7rem;color:var(--clr-text-muted);"></i>
                </a></li>
                <li><a class="dropdown-item" href="#" id="vol-alarm-toggle">
                    <i class="bi ${isMuted ? 'bi-bell' : 'bi-bell-slash'} me-2" style="color:${isMuted ? 'var(--clr-ok)' : 'var(--clr-warn)'};"></i>${isMuted ? 'Aktiver alarm' : 'Deaktiver alarm'}
                </a></li>
                <li><a class="dropdown-item" href="#" id="vol-futuremove-btn">
                    <i class="bi bi-clock-history me-2" style="color:var(--clr-info);"></i>Fremtidig flyt
