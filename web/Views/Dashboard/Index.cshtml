        panel1.querySelector('#vol-checkout-btn').addEventListener('click', (e) => {
            e.preventDefault();
            volMenuCheckOut(parseInt(menu.dataset.vid), menu.dataset.vname);
        });

        // Events panel 2
        panel2.querySelector('#vol-back-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            panel2.style.display = 'none';
            panel1.style.display = 'block';
            // Sæt menuen tilbage til normal størrelse
            const r = menu.getBoundingClientRect();
            if (r.bottom > window.innerHeight - 8) {
                menu.style.top = Math.max(8, window.innerHeight - menu.offsetHeight - 8) + 'px';
            }
        });
        panel2.querySelectorAll('.vol-move-item').forEach(a => {
