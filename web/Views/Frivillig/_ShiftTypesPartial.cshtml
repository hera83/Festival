@model web.Models.ShiftTypesPagedViewModel

@* Søgefelt — aldrig erstattet af AJAX *@
<div class="d-flex align-items-center justify-content-between mb-3 gap-2">
    <div class="input-group input-group-sm" style="max-width: 340px;">
        <span class="input-group-text" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
            <i class="bi bi-search"></i>
        </span>
        <input type="text" id="stSearchInput" class="form-control form-control-sm"
               placeholder="Søg vagttype navn…"
               style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text);"
               autocomplete="off" />
        <button type="button" id="stSearchClear" class="btn btn-sm d-none"
                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted); border-left: none;"
                tabindex="-1" aria-label="Ryd søgning">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <button type="button" id="btnOpenCreateSt" class="btn btn-sm"
            style="background: var(--clr-brand); color: #fff; border: none; white-space: nowrap;">
        <i class="bi bi-plus-square me-1"></i>Opret vagttype
    </button>
</div>

@* Opret-modal *@
<div class="modal fade" id="createStModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-border);">
            <div id="createStModalBody">
                <div class="modal-body text-center py-5" style="color: var(--clr-text-muted);">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Rediger-modal *@
<div class="modal fade" id="editStModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-border);">
            <div id="editStModalBody">
                <div class="modal-body text-center py-5" style="color: var(--clr-text-muted);">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Resultat-zone — kun denne div overskrives ved søgning/sideskift *@
<div id="st-result-zone">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-diagram-3 me-2"></i>Vagttyper (<span>@Model.TotalCount</span>)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="color: var(--clr-text);">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--clr-border);">
                                <th class="ps-3">Navn</th>
                                <th>Start</th>
                                <th>Slut</th>
                                <th class="pe-3" style="width:110px;"></th>
                            </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ShiftTypes.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4" style="color: var(--clr-text-muted);">
                                    <i class="bi bi-diagram-3 fs-4 d-block mb-1"></i>
                                    Ingen vagttyper fundet
                                </td>
                            </tr>
                        }
                        @foreach (var st in Model.ShiftTypes)
                        {
                            <tr style="border-bottom: 1px solid var(--clr-border);">
                                <td class="ps-3 align-middle fw-semibold">@st.ShiftName</td>
                                <td class="align-middle">@st.StartTime.ToString("dd-MM-yyyy HH:mm")</td>
                                <td class="align-middle">@st.EndTime.ToString("dd-MM-yyyy HH:mm")</td>
                                <td class="pe-3 align-middle text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="button" class="btn btn-sm btn-secondary st-edit-btn"
                                                title="Rediger vagttype"
                                                data-id="@st.Id">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm st-delete-btn"
                                                style="background: var(--clr-alarm); color: #fff; border: none;"
                                                title="Slet vagttype"
                                                data-id="@st.Id" data-name="@st.ShiftName"
                                                data-bs-toggle="modal" data-bs-target="#deleteStModal">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <span style="color: var(--clr-text-muted); font-size: 0.85rem;">
            @if (Model.TotalCount == 0) { <span>Ingen resultater</span> }
            else { <span>@Model.RangeFrom–@Model.RangeTo af @Model.TotalCount</span> }
        </span>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: var(--clr-text-muted);">
                <span>Pr. side</span>
                <select id="stPageSizeSelect" class="form-select form-select-sm"
                        style="width: auto; background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text); font-size: 0.85rem;">
                    @foreach (var size in new[] { 10, 25, 50 })
                    {
                        if (Model.PageSize == size) { <!option value="@size" selected>@size</!option> }
                        else { <!option value="@size">@size</!option> }
                    }
                </select>
            </div>
            <nav aria-label="Sidenavigation">
                <ul class="pagination pagination-sm mb-0">
                    @{
                        var cp = Model.Page; var tp = Model.TotalPages;
                        var shown = new System.Collections.Generic.SortedSet<int> { 1, Math.Max(1, tp) };
                        for (var i = Math.Max(1, cp - 1); i <= Math.Min(Math.Max(1, tp), cp + 1); i++) shown.Add(i);
                    }
                    <li class="page-item @(cp == 1 ? "disabled" : "")">
                        <button class="page-link st-page-btn" data-page="@(cp - 1)" @(cp == 1 ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @{ int? lastShown = null; }
                    @foreach (var p in shown)
                    {
                        if (lastShown.HasValue && p - lastShown.Value > 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link" style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">…</span>
                            </li>
                        }
                        <li class="page-item @(p == cp ? "active" : "")">
                            <button class="page-link st-page-btn" data-page="@p"
                                    style="@(p == cp ? "background: var(--clr-brand); border-color: var(--clr-brand); color: #fff;" : "background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);")">@p</button>
                        </li>
                        lastShown = p;
                    }
                    <li class="page-item @(cp >= tp ? "disabled" : "")">
                        <button class="page-link st-page-btn" data-page="@(cp + 1)" @(cp >= tp ? "disabled" : "")
                                style="background: var(--clr-surface); border-color: var(--clr-border); color: var(--clr-text-muted);">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@* Slet vagttype modal *@
<div class="modal fade" id="deleteStModal" tabindex="-1" aria-labelledby="deleteStModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--clr-surface); border: 1px solid var(--clr-border); color: var(--clr-text);">
            <div class="modal-header" style="border-bottom: 1px solid var(--clr-border);">
                <h5 class="modal-title" id="deleteStModalLabel"><i class="bi bi-exclamation-triangle me-2" style="color: var(--clr-alarm);"></i>Slet vagttype</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body">
                <p>Er du sikker på, at du vil slette vagttypen <strong id="deleteStName"></strong>?</p>
                <p class="mb-0" style="color: var(--clr-alarm); font-size: 0.9rem;"><i class="bi bi-exclamation-circle me-1"></i>Alle vagter med denne vagttype fjernes fra alle frivillige.</p>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--clr-border);">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Annuller</button>
                <button type="button" class="btn btn-sm" id="deleteStConfirm"
                        style="background: var(--clr-alarm); color: #fff; border: none;">
                    <i class="bi bi-trash3 me-1"></i>Slet
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var searchUrl    = '@Url.Action("ShiftTypesSearch", "Frivillig")';
    var createFormUrl = '@Url.Action("GetCreateShiftTypeForm", "Frivillig")';
    var createPostUrl = '@Url.Action("CreateShiftType", "Frivillig")';
    var editFormUrl   = '@Url.Action("GetEditShiftTypeForm", "Frivillig")';
    var editPostUrl   = '@Url.Action("UpdateShiftType", "Frivillig")';
    var deleteUrl    = '@Url.Action("DeleteShiftType",  "Frivillig")';
    var debounce;
    var currentSize  = @Model.PageSize;
    var currentPage  = @Model.Page;

    async function loadPage(page, size) {
        currentPage = page;
        currentSize = size;
        var q   = document.getElementById('stSearchInput').value.trim();
        var url = searchUrl + '?q=' + encodeURIComponent(q) + '&page=' + page + '&pageSize=' + size;
        try {
            var res = await fetch(url);
            if (!res.ok) { showToast('Kunne ikke hente vagttyper.', 'error'); return; }
            var doc  = new DOMParser().parseFromString(await res.text(), 'text/html');
            var zone = doc.getElementById('st-result-zone');
            if (!zone) return;
            document.getElementById('st-result-zone').innerHTML = zone.innerHTML;
            bindZoneEvents();
        } catch (e) {
            showToast('Netværksfejl – prøv igen.', 'error');
        }
    }

    function bindZoneEvents() {
        var sel = document.getElementById('stPageSizeSelect');
        if (sel) sel.addEventListener('change', function () { loadPage(1, parseInt(this.value)); });
        document.querySelectorAll('.st-page-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var p = parseInt(this.dataset.page);
                if (!isNaN(p) && p >= 1) loadPage(p, currentSize);
            });
        });
        bindRowActions();
    }

    // ── Opret / rediger ──────────────────────────────────────────
    var createModalEl = document.getElementById('createStModal');
    var editModalEl   = document.getElementById('editStModal');
    var bsCreateModal = new bootstrap.Modal(createModalEl);
    var bsEditModal   = new bootstrap.Modal(editModalEl);

    document.getElementById('btnOpenCreateSt').addEventListener('click', async function () {
        try {
            var res = await fetch(createFormUrl);
            if (!res.ok) { showToast('Kunne ikke åbne opret-formular.', 'error'); return; }
            document.getElementById('createStModalBody').innerHTML = await res.text();
            bsCreateModal.show();
            bindCreateForm();
        } catch (e) {
            showToast('Netværksfejl – prøv igen.', 'error');
        }
    });

    function bindRowActions() {
        document.querySelectorAll('.st-edit-btn').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var id = parseInt(this.dataset.id);
                if (!id) return;
                try {
                    var res = await fetch(editFormUrl + '?id=' + id);
                    if (!res.ok) { showToast('Kunne ikke åbne rediger-formular.', 'error'); return; }
                    document.getElementById('editStModalBody').innerHTML = await res.text();
                    bsEditModal.show();
                    bindEditForm();
                } catch (e) {
                    showToast('Netværksfejl – prøv igen.', 'error');
                }
            });
        });
    }

    function bindCreateForm() {
        var form = document.getElementById('createShiftTypeForm');
        if (!form) return;
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var submitBtn = document.getElementById('createShiftTypeSubmit');
            submitBtn.disabled = true;
            try {
                var res = await fetch(createPostUrl, { method: 'POST', body: new FormData(form) });
                var json = await res.json();
                if (json.success) {
                    bsCreateModal.hide();
                    showToast(json.message, 'success');
                    document.dispatchEvent(new CustomEvent('frivillig:countsChanged'));
                    await loadPage(1, currentSize);
                } else {
                    showToast(json.message, 'error');
                }
            } catch (err) {
                showToast('Netværksfejl – kunne ikke oprette vagttype.', 'error');
            } finally {
                submitBtn.disabled = false;
            }
        });
    }

    function bindEditForm() {
        var form = document.getElementById('editShiftTypeForm');
        if (!form) return;
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var submitBtn = document.getElementById('editShiftTypeSubmit');
            submitBtn.disabled = true;
            try {
                var res = await fetch(editPostUrl, { method: 'POST', body: new FormData(form) });
                var json = await res.json();
                if (json.success) {
                    bsEditModal.hide();
                    showToast(json.message, 'success');
                    await loadPage(currentPage, currentSize);
                } else {
                    showToast(json.message, 'error');
                }
            } catch (err) {
                showToast('Netværksfejl – kunne ikke opdatere vagttype.', 'error');
            } finally {
                submitBtn.disabled = false;
            }
        });
    }

    // ── Søgning ───────────────────────────────────────────────────
    var stInput = document.getElementById('stSearchInput');
    var stClear = document.getElementById('stSearchClear');

    stInput.addEventListener('input', function () {
        stClear.classList.toggle('d-none', this.value === '');
    });
    stClear.addEventListener('click', function () {
        stInput.value = '';
        stClear.classList.add('d-none');
        loadPage(1, currentSize);
        stInput.focus();
    });
    stInput.addEventListener('keyup', function () {
        clearTimeout(debounce);
        debounce = setTimeout(function () { loadPage(1, currentSize); }, 250);
    });

    // ── Slet-modal ────────────────────────────────────────────────
    var deleteModalEl   = document.getElementById('deleteStModal');
    var bsDeleteModal   = new bootstrap.Modal(deleteModalEl);
    var pendingDeleteId = null;

    deleteModalEl.addEventListener('show.bs.modal', function (event) {
        var btn = event.relatedTarget;
        pendingDeleteId = parseInt(btn.dataset.id);
        document.getElementById('deleteStName').textContent = btn.dataset.name;
    });

    document.getElementById('deleteStConfirm').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        var btn = this;
        btn.disabled = true;
        try {
            var fd = new FormData();
            fd.append('id', pendingDeleteId);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
            var res  = await fetch(deleteUrl, { method: 'POST', body: fd });
            var json = await res.json();
            bsDeleteModal.hide();
            if (json.success) {
                showToast(json.message, 'success');
                document.dispatchEvent(new CustomEvent('frivillig:countsChanged'));
                await loadPage(currentPage, currentSize);
            } else {
                showToast(json.message, 'error');
            }
        } catch (e) {
            bsDeleteModal.hide();
            showToast('Netværksfejl – kunne ikke slette.', 'error');
        } finally {
            btn.disabled = false;
            pendingDeleteId = null;
        }
    });

    bindZoneEvents();
})();
</script>
